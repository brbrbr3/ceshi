/* reset */
page {
  background-color: #EEF2FF;
  height: 100%;
  font-size: 16px;
  line-height: 1.6;
  color: #1E293B;
  display: flex;
  justify-content: center;
}
page>view {
  width: 100vw;
  max-width: 600px;
}
checkbox, radio{
  margin-right: 5px;
}
button{
  margin-top: 10px;
  margin-bottom: 10px;
}
form{
  width: 100%;
}
input {
  width: 100%;
}

/* lib */
.strong{
  font-weight: bold;
}
.tc{
  text-align: center;
}

/* 业务样式 */
.office-page {
  min-height: 100%;
  background: #EEF2FF;
  color: #1E293B;
}

.office-gradient-header {
  padding: calc(100rpx + env(safe-area-inset-top)) 32rpx 0;
  background: linear-gradient(135deg, #1D4ED8 0%, #3B82F6 100%);
  color: #FFFFFF;
  border-bottom-left-radius: 60rpx;
  border-bottom-right-radius: 60rpx;
  box-sizing: border-box;
}

.office-header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.office-content {
  position: relative;
  z-index: 2;
  padding: 0 24rpx 40rpx;
  box-sizing: border-box;
}

.office-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  box-shadow: 0 16rpx 42rpx rgba(37, 99, 235, 0.08);
}

.office-glass-card {
  background: rgba(255, 255, 255, 0.1);
  border: 3rpx solid rgba(255, 255, 255, 0.48);
  box-shadow: 3rpx 3rpx 2rpx rgba(255, 255, 255, 0.42);
  backdrop-filter: blur(15px);
}

.office-section {
  margin-top: 28rpx;
}

.office-section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.office-section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1E293B;
}

.office-link {
  font-size: 24rpx;
  color: #2563EB;
}

.office-muted {
  color: #94A3B8;
}

.office-divider {
  height: 1rpx;
  background: rgba(37, 99, 235, 0.1);
}

.office-chip-scroll {
  white-space: nowrap;
}

.office-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 28rpx;
  margin-right: 16rpx;
  border-radius: 999rpx;
  background: #FFFFFF;
  color: #4B6080;
  font-size: 24rpx;
  box-shadow: 0 8rpx 18rpx rgba(37, 99, 235, 0.06);
}

.office-chip.is-active {
  background: #2563EB;
  color: #FFFFFF;
  box-shadow: 0 14rpx 28rpx rgba(37, 99, 235, 0.2);
}

.office-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 1;
}

.office-btn-primary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 32rpx;
  border-radius: 999rpx;
  background: #2563EB;
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 600;
  box-shadow: 0 14rpx 28rpx rgba(37, 99, 235, 0.16);
}

.office-btn-secondary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 32rpx;
  border-radius: 999rpx;
  background: #EFF6FF;
  color: #2563EB;
  font-size: 24rpx;
  font-weight: 600;
}

.office-icon-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.16);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 28rpx;
}

.office-avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 38rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
}

.office-empty {
  padding: 80rpx 24rpx;
  text-align: center;
  color: #94A3B8;
}

.office-search {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 0 28rpx;
  height: 88rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  box-shadow: 0 12rpx 28rpx rgba(37, 99, 235, 0.06);
}

.office-search input {
  flex: 1;
  font-size: 26rpx;
  color: #1E293B;
}

.office-search-placeholder {
  color: #94A3B8;
}

.office-fab {
  position: fixed;
  right: 40rpx;
  bottom: calc(170rpx + env(safe-area-inset-bottom));
  width: 104rpx;
  height: 104rpx;
  border-radius: 52rpx;
  background: linear-gradient(135deg, #1D4ED8 0%, #3B82F6 100%);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 54rpx;
  box-shadow: 0 18rpx 36rpx rgba(37, 99, 235, 0.28);
  z-index: 9;
}

.auth-page {
  min-height: 100%;
  padding: calc(56rpx + env(safe-area-inset-top)) 28rpx 40rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #DBEAFE 0%, #EEF2FF 34%, #F8FAFC 100%);
}

.auth-hero {
  padding: 28rpx 12rpx 24rpx;
}

.auth-brand {
  width: 88rpx;
  height: 88rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #1D4ED8 0%, #3B82F6 100%);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 700;
  box-shadow: 0 16rpx 34rpx rgba(37, 99, 235, 0.2);
}

.auth-title {
  margin-top: 28rpx;
  font-size: 48rpx;
  line-height: 1.25;
  font-weight: 700;
  color: #0F172A;
}

.auth-subtitle {
  margin-top: 14rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #475569;
}

.auth-tip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 28rpx;
}

.auth-tip-pill {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(37, 99, 235, 0.1);
  color: #1D4ED8;
  font-size: 22rpx;
  font-weight: 600;
}

.auth-card {
  margin-top: 20rpx;
  padding: 32rpx 28rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.08);
}

.auth-card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0F172A;
}

.auth-card-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #64748B;
}

.auth-wechat-panel {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 28rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #ECFDF5 0%, #F0FDF4 100%);
}

.auth-wechat-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #22C55E 0%, #16A34A 100%);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
}

.auth-wechat-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #166534;
}

.auth-wechat-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #15803D;
}

.auth-submit-btn {
  width: 100%;
  height: 92rpx;
  margin-top: 28rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #1D4ED8 0%, #3B82F6 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 16rpx 30rpx rgba(37, 99, 235, 0.18);
}

.auth-submit-btn::after {
  border: none;
}

.auth-note {
  margin-top: 18rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #64748B;
  margin-bottom: 60rpx;
}

.auth-status-card {
  overflow: hidden;
}

.auth-status-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.auth-status-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0F172A;
}

.auth-status-tag {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.auth-status-card.is-pending {
  border: 1rpx solid rgba(245, 158, 11, 0.22);
  background: linear-gradient(180deg, #FFFFFF 0%, #FFFBEB 100%);
}

.auth-status-card.is-pending .auth-status-tag {
  background: #FEF3C7;
  color: #B45309;
}

.auth-status-card.is-rejected {
  border: 1rpx solid rgba(239, 68, 68, 0.2);
  background: linear-gradient(180deg, #FFFFFF 0%, #FEF2F2 100%);
}

.auth-status-card.is-rejected .auth-status-tag {
  background: #FEE2E2;
  color: #B91C1C;
}

.auth-status-card.is-approved {
  border: 1rpx solid rgba(34, 197, 94, 0.2);
  background: linear-gradient(180deg, #FFFFFF 0%, #F0FDF4 100%);
}

.auth-status-card.is-approved .auth-status-tag {
  background: #DCFCE7;
  color: #15803D;
}

.auth-status-card.is-error {
  border: 1rpx solid rgba(148, 163, 184, 0.2);
}

.auth-status-card.is-error .auth-status-tag {
  background: #E2E8F0;
  color: #475569;
}

.auth-status-desc,
.auth-status-extra,
.auth-status-time {
  margin-top: 14rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #64748B;
}

.auth-status-extra {
  color: #1E293B;
}

.auth-bottom-link {
  margin-top: 24rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 600;
  color: #2563EB;
}

.auth-form {
  margin-top: 28rpx;
}

.auth-field + .auth-field {
  margin-top: 24rpx;
}

.auth-field-label {
  margin-bottom: 14rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #1E293B;
}

.auth-input-shell,
.auth-picker-shell {
  display: flex;
  align-items: center;
  min-height: 92rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  background: #F8FAFC;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.auth-picker-shell.is-placeholder,
.auth-input-placeholder {
  color: #94A3B8;
}

.auth-input-shell:focus-within {
  border-color: #93C5FD;
  background: #FFFFFF;
}

.auth-input-shell input {
  width: 100%;
  font-size: 26rpx;
  color: #0F172A;
}

.auth-picker-value {
  flex: 1;
  font-size: 26rpx;
  color: #0F172A;
}

.auth-picker-arrow {
  margin-left: 16rpx;
  font-size: 28rpx;
  color: #94A3B8;
}

.auth-segment {
  display: flex;
  gap: 16rpx;
}

.auth-segment-item {
  flex: 1;
  height: 88rpx;
  border-radius: 24rpx;
  background: #F8FAFC;
  color: #475569;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border: 2rpx solid transparent;
}

.auth-segment-item.is-active {
  background: #EFF6FF;
  border-color: #93C5FD;
  color: #2563EB;
  font-weight: 600;
}

.auth-review-banner {
  margin-top: 20rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: #FEF2F2;
  color: #B91C1C;
}

.auth-review-title {
  font-size: 24rpx;
  font-weight: 600;
}

.auth-review-text {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.7;
}
