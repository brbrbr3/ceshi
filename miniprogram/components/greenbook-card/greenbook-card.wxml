<view
  class="greenbook-card"
  style="height: {{item.imageRatios[0] ? (cardWidth / item.imageRatios[0] + 80) : (cardWidth + 80)}}px;"
  bindtap="handleCardTap"
  data-index="{{index}}"
  data-item="{{item}}"
>
  <!-- 图片 -->
  <image
    class="greenbook-card-image"
    mode="aspectFill"
    src="{{item.images[0]}}"
    lazy-load
    style="height: {{item.imageRatios[0] ? (cardWidth / item.imageRatios[0]) : cardWidth}}px;"
  />
  <!-- 图片数量标记 -->
  <view class="greenbook-card-image-count" wx:if="{{item.images.length > 1}}">
    {{item.images.length}}
  </view>

  <!-- 文字区域 -->
  <view class="greenbook-card-desc">
    <view class="greenbook-card-title">{{item.title || item.content}}</view>
    <view class="greenbook-card-footer">
      <image class="greenbook-card-avatar" src="{{item.authorAvatar}}" wx:if="{{item.authorAvatar}}" />
      <view class="greenbook-card-avatar-placeholder" wx:else>{{item.authorName[0] || '?'}}</view>
      <text class="greenbook-card-nickname">{{item.authorName}}</text>
      <view class="greenbook-card-like {{item.isLiked ? 'is-liked' : ''}}" catchtap="handleLike">
        <text>{{item.isLiked ? '❤️' : '🤍'}}</text>
        <text wx:if="{{item.likeCount > 0}}">{{item.likeCount}}</text>
      </view>
    </view>
  </view>
</view>
