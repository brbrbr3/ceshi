.greenbook-card {
  border-radius: 16rpx;
  overflow: hidden;
  flex-shrink: 0;
  width: 100%;
  background-color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  position: relative;
  display: flex;
  flex-direction: column;
}

.greenbook-card-image {
  width: 100%;
  background-color: #F1F5F9;
  flex-shrink: 0;
}

.greenbook-card-image-count {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #FFFFFF;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.greenbook-card-desc {
  padding: 16rpx;
}

.greenbook-card-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #1E293B;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  margin-bottom: 12rpx;
}

.greenbook-card-footer {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: #64748B;
}

.greenbook-card-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.greenbook-card-avatar-placeholder {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #16A34A, #22C55E);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.greenbook-card-nickname {
  flex: 1;
  padding-left: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.greenbook-card-like {
  display: flex;
  align-items: center;
  gap: 2rpx;
  flex-shrink: 0;
  padding: 4rpx 0;
}

.greenbook-card-like.is-liked {
  transform: scale(1.1);
}

.greenbook-card-like text {
  font-size: 22rpx;
}
