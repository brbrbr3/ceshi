/* approval-card 组件样式 */
/* 大部分样式继承自页面，此处仅定义组件特有样式 */

.approval-list-card {
  padding: 24rpx;
}

.approval-list-card + .approval-list-card {
  margin-top: 20rpx;
}

.approval-list-top,
.approval-person,
.approval-person-row,
.approval-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.approval-person {
  gap: 18rpx;
}

.approval-person-main {
  flex: 1;
}

.approval-person-row {
  justify-content: flex-start;
  gap: 10rpx;
}

.approval-person-name {
  font-size: var(--fs-30);
  font-weight: 600;
  color: #1E293B;
}

.approval-person-sub {
  font-size: var(--fs-22);
  color: #94A3B8;
}

.approval-type-title {
  margin-top: 22rpx;
  font-size: var(--fs-30);
  font-weight: 600;
  color: #1E293B;
}

.approval-detail {
  margin-top: 12rpx;
  font-size: var(--fs-22);
  color: #4B6080;
}

.approval-meta {
  margin-top: 8rpx;
  font-size: var(--fs-22);
  color: #94A3B8;
}

.approval-time {
  margin-top: 10rpx;
  font-size: var(--fs-22);
  color: #94A3B8;
}

.approval-urgent {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #FFEBEE;
  color: #F44336;
  font-size: var(--fs-18);
}

/* 操作按钮 */
.approval-actions {
  gap: 18rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(37, 99, 235, 0.1);
}

.approval-reject-btn,
.approval-approve-btn {
  flex: 1;
  height: 78rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--fs-24);
  font-weight: 600;
  transition: all 0.3s ease;
  position: relative;
}

.approval-reject-btn {
  background: #F8FAFC;
  color: #4B6080;
}

.approval-reject-btn.is-disabled,
.approval-approve-btn.is-disabled {
  opacity: 0.6;
  pointer-events: none;
}

/* 加载动画 */
.approval-reject-btn.is-disabled::after,
.approval-approve-btn.is-disabled::after {
  content: '';
  position: absolute;
  right: 20rpx;
  width: 24rpx;
  height: 24rpx;
  border: 3rpx solid currentColor;
  border-top-color: transparent;
  border-right-color: transparent;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  opacity: 0.8;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* 进度条样式 */
.approval-progress {
  margin-top: 16rpx;
  padding: 24rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
}

.approval-progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.approval-progress-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.approval-progress-step {
  font-size: var(--fs-24);
  font-weight: 600;
  color: #1E293B;
}

.approval-progress-text {
  font-size: var(--fs-22);
  color: #9CA3AF;
}

.approval-progress-bar {
  width: 100%;
  height: 8rpx;
  background: #E5E7EB;
  border-radius: 4rpx;
  overflow: hidden;
}

.approval-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #2563EB 0%, #1D4ED8 100%);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}
