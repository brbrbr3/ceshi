/* datetime-picker.wxss */

/* 容器 */
.datetime-picker {
  position: relative;
  width: 100%;
}

/* 触发器 */
.picker-trigger {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
  border-radius: 16rpx;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.picker-trigger::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border: 2rpx solid transparent;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.picker-trigger:active {
  transform: scale(0.98);
}

.picker-trigger:active::before {
  border-color: rgba(37, 99, 235, 0.3);
}

/* 触发器样式变体 */
.picker-trigger--default {
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
}

.picker-trigger--card {
  background: #FFFFFF;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.picker-trigger--border {
  background: transparent;
  border: 2rpx solid #E2E8F0;
}

.picker-trigger--border::before {
  display: none;
}

/* 禁用状态 */
.picker-trigger--disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* 显示值 */
.picker-value {
  font-size: 28rpx;
  color: #1E293B;
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.picker-placeholder {
  color: #94A3B8;
  font-weight: 400;
}

/* 图标 */
.picker-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  background: rgba(37, 99, 235, 0.1);
  border-radius: 50%;
  transition: all 0.3s ease;
}

.icon-arrow {
  font-size: 20rpx;
  color: #2563EB;
  transition: transform 0.3s ease;
}

/* 遮罩层 */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.6);
  z-index: 1000;
  opacity: 0;
  transition: opacity 0.3s ease;
  backdrop-filter: blur(4px);
}

.picker-mask--show {
  opacity: 1;
}

/* 弹出层 */
.picker-popup {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 1001;
  transform: translateY(100%);
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.12);
  overflow: hidden;
}

.picker-popup--show {
  transform: translateY(0);
}

/* 头部 */
.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 40rpx;
  background: linear-gradient(180deg, #FFFFFF 0%, #FAFAFA 100%);
}

.picker-btn {
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  transition: all 0.2s ease;
  position: relative;
  overflow: hidden;
}

.picker-btn::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  transform: translate(-50%, -50%);
  transition: width 0.3s ease, height 0.3s ease;
}

.picker-btn:active::after {
  width: 200%;
  height: 200%;
}

.picker-btn--cancel {
  color: #64748B;
  background: rgba(100, 116, 139, 0.1);
}

.picker-btn--cancel:active {
  background: rgba(100, 116, 139, 0.2);
}

.picker-btn--confirm {
  color: #FFFFFF;
  background: linear-gradient(135deg, #2563EB 0%, #1D4ED8 100%);
  font-weight: 500;
}

.picker-btn--confirm:active {
  background: linear-gradient(135deg, #1D4ED8 0%, #1E40AF 100%);
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1E293B;
  letter-spacing: 1rpx;
}

/* 分隔线 */
.picker-divider {
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, #E2E8F0 20%, #E2E8F0 80%, transparent 100%);
}

/* 选择器视图 */
.picker-view {
  height: 450rpx;
  padding: 0 20rpx;
}

/* 列项 */
.picker-column-item {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #1E293B;
  font-weight: 500;
}

.picker-column-num {
  font-size: 36rpx;
  font-weight: 600;
  color: #2563EB;
  min-width: 48rpx;
  text-align: center;
}

.picker-column-unit {
  font-size: 24rpx;
  color: #64748B;
  margin-left: 4rpx;
  font-weight: 400;
}

.picker-column-item--weekday {
  font-size: 30rpx;
  font-weight: 500;
  color: #1E293B;
}

.picker-column-item--weekday .picker-column-num {
  display: none;
}

/* 选中效果 */
picker-view-column:first-child .picker-column-item:first-child {
  margin-top: 0;
}

/* 安全区域 */
.picker-safe-area {
  height: env(safe-area-inset-bottom);
  min-height: 20rpx;
  background: #FFFFFF;
}

/* 深色模式支持 */
@media (prefers-color-scheme: dark) {
  .picker-trigger {
    background: linear-gradient(135deg, #1E293B 0%, #334155 100%);
  }
  
  .picker-value:not(.picker-placeholder) {
    color: #F1F5F9;
  }
  
  .picker-popup {
    background: #1E293B;
  }
  
  .picker-header {
    background: linear-gradient(180deg, #1E293B 0%, #0F172A 100%);
  }
  
  .picker-title {
    color: #F1F5F9;
  }
  
  .picker-btn--cancel {
    background: rgba(148, 163, 184, 0.2);
    color: #94A3B8;
  }
  
  .picker-column-item {
    color: #F1F5F9;
  }
  
  .picker-column-unit {
    color: #94A3B8;
  }
}

/* 动画关键帧 */
@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

/* 涟漪效果 */
@keyframes ripple {
  to {
    transform: translate(-50%, -50%) scale(2);
    opacity: 0;
  }
}
