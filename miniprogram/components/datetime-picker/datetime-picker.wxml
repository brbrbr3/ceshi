<view class="datetime-picker">
  <!-- 触发器 -->
  <view class="picker-trigger picker-trigger--{{type}} {{disabled ? 'picker-trigger--disabled' : ''}}" bindtap="showPicker">
    <text class="picker-value {{displayText ? '' : 'picker-placeholder'}}">{{displayText || placeholder}}</text>
    <view class="picker-icon">
      <text class="icon-arrow">▼</text>
    </view>
  </view>

  <!-- 遮罩层 -->
  <view 
    class="picker-mask {{visible ? 'picker-mask--show' : ''}}" 
    wx:if="{{visible}}" 
    bindtap="onMaskTap"
    animation="{{maskAnimation}}"
  ></view>

  <!-- 弹出层 -->
  <view 
    class="picker-popup {{visible ? 'picker-popup--show' : ''}}" 
    wx:if="{{visible}}" 
    catchtouchmove="stopPropagation"
    animation="{{animationData}}"
  >
    <!-- 头部 -->
    <view class="picker-header">
      <view class="picker-btn picker-btn--cancel" bindtap="cancelPicker">
        <text>取消</text>
      </view>
      <view class="picker-title">选择日期时间</view>
      <view class="picker-btn picker-btn--confirm" bindtap="confirmPicker">
        <text>确定</text>
      </view>
    </view>

    <!-- 分隔线装饰 -->
    <view class="picker-divider"></view>

    <!-- 选择器 -->
    <picker-view 
      class="picker-view" 
      value="{{pickerValue}}" 
      bindchange="onPickerChange"
      indicator-style="height: 44px;"
      mask-style="background-image: linear-gradient(to bottom, rgba(255,255,255,0.95), rgba(255,255,255,0.6)), linear-gradient(to top, rgba(255,255,255,0.95), rgba(255,255,255,0.6));"
    >
      <!-- 年份列 -->
      <picker-view-column wx:if="{{showYear}}">
        <view wx:for="{{years}}" wx:key="*this" class="picker-column-item">
          <text class="picker-column-num">{{item}}</text>
          <text class="picker-column-unit">年</text>
        </view>
      </picker-view-column>

      <!-- 月份列 -->
      <picker-view-column wx:if="{{showMonth}}">
        <view wx:for="{{months}}" wx:key="*this" class="picker-column-item">
          <text class="picker-column-num">{{item < 10 ? '0' + item : item}}</text>
          <text class="picker-column-unit">月</text>
        </view>
      </picker-view-column>

      <!-- 日期列 -->
      <picker-view-column wx:if="{{showDay}}">
        <view wx:for="{{days}}" wx:key="*this" class="picker-column-item">
          <text class="picker-column-num">{{item < 10 ? '0' + item : item}}</text>
          <text class="picker-column-unit">日</text>
        </view>
      </picker-view-column>

      <!-- 星期列 -->
      <picker-view-column wx:if="{{showWeekday}}">
        <view wx:for="{{weekdays}}" wx:key="*this" class="picker-column-item picker-column-item--weekday">
          <text>{{item}}</text>
        </view>
      </picker-view-column>

      <!-- 小时列 -->
      <picker-view-column wx:if="{{showHour}}">
        <view wx:for="{{hours}}" wx:key="*this" class="picker-column-item">
          <text class="picker-column-num">{{item < 10 ? '0' + item : item}}</text>
          <text class="picker-column-unit">时</text>
        </view>
      </picker-view-column>

      <!-- 分钟列 -->
      <picker-view-column wx:if="{{showMinute}}">
        <view wx:for="{{minutes}}" wx:key="*this" class="picker-column-item">
          <text class="picker-column-num">{{item < 10 ? '0' + item : item}}</text>
          <text class="picker-column-unit">分</text>
        </view>
      </picker-view-column>

      <!-- 秒列 -->
      <picker-view-column wx:if="{{showSecond}}">
        <view wx:for="{{seconds}}" wx:key="*this" class="picker-column-item">
          <text class="picker-column-num">{{item < 10 ? '0' + item : item}}</text>
          <text class="picker-column-unit">秒</text>
        </view>
      </picker-view-column>
    </picker-view>

    <!-- 底部安全区域 -->
    <view class="picker-safe-area"></view>
  </view>
</view>
