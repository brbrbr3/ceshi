/* approval-detail 详情弹窗组件样式 */

/* 弹窗遮罩 */
.approval-modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.42);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 24rpx;
  box-sizing: border-box;
  z-index: 20;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transition: opacity 0.3s ease, visibility 0.3s ease;
}

.approval-modal-mask.is-visible {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
}

/* 弹窗卡片 - flex布局，标题栏固定 */
.approval-modal-card {
  display: flex;
  flex-direction: column;
  width: 100%;
  border-radius: 32rpx;
  background: #FFFFFF;
  box-sizing: border-box;
  height: 85vh;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  overflow: hidden;
}

/* 打开动画：遮罩可见时卡片从底部滑入 */
.approval-modal-mask.is-visible .approval-modal-card {
  transform: translateY(0);
}

/* 标题栏 - 固定不滚动 */
.approval-modal-head {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 15rpx;
}

/* 可滚动内容区 */
.approval-modal-scroll {
  flex: 1;
  overflow: hidden;
  padding: 0rpx;
  padding-top: 24rpx;
}

.approval-modal-title {
  font-size: var(--fs-30);
  font-weight: 600;
  color: #1E293B;
}

.approval-modal-sub {
  font-size: var(--fs-24);
  color: #94A3B8;
}

.approval-modal-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: #F8FAFC;
  color: #64748B;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--fs-32);
}

/* 详情内容 */
.approval-modal-body {
  margin-top: 24rpx;
}

.approval-modal-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx ;
}

.approval-modal-row + .approval-modal-row {
  margin-top: 18rpx;
}

.approval-modal-label {
  font-size: var(--fs-24);
  color: #94A3B8;
}

.approval-modal-value {
  font-size: var(--fs-24);
  color: #1E293B;
  font-weight: 500;
}

/* 表格类型字段样式 */
.approval-modal-table-section {
  margin-top: 24rpx;
  margin-right: 8rpx;
}

.approval-modal-table-title {
  font-size: var(--fs-24);
  color: #94A3B8;
  margin-bottom: 12rpx;
  display: block;
}

.approval-modal-table {
  width: 100%;
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid #E2E8F0;
}

.approval-modal-table-header {
  display: flex;
  background: #F1F5F9;
}

.approval-modal-table-header .approval-modal-table-cell {
  font-size: var(--fs-24);
  font-weight: 600;
  color: #475569;
  padding: 14rpx 8rpx;
  text-align: center;
  overflow-wrap: break-word;
}

.approval-modal-table-row {
  display: flex;
  border-top: 1rpx solid #F1F5F9;
}

.approval-modal-table-row + .approval-modal-table-row {
  border-top: 1rpx solid #F1F5F9;
}

.approval-modal-table-row .approval-modal-table-cell {
  font-size: var(--fs-24);
  color: #334155;
  padding: 12rpx 8rpx;
  text-align: center;
  overflow-wrap: break-word;
}

.approval-modal-table-empty {
  font-size: var(--fs-24);
  color: #9CA3AF;
  text-align: center;
  padding: 24rpx 0;
}

.approval-detail-status-value{
  margin-top: -35rpx;
}

.approval-modal-remark {
  margin-top: 24rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: #F8FAFC;
  color: #475569;
  font-size: var(--fs-24);
  line-height: 1.7;
}

/* 进度条样式 */
.approval-modal-progress {
  margin-top: 24rpx;
  padding: 24rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
}

.approval-modal-progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.approval-modal-progress-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.approval-modal-progress-step {
  font-size: var(--fs-24);
  font-weight: 600;
  color: #1E293B;
}

.approval-modal-progress-text {
  font-size: var(--fs-24);
  color: #9CA3AF;
}

.approval-modal-progress-bar {
  width: 100%;
  height: 8rpx;
  background: #E5E7EB;
  border-radius: 4rpx;
  overflow: hidden;
}

.approval-modal-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #2563EB 0%, #1D4ED8 100%);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

/* 审批历史 */
.approval-modal-logs {
  margin-top: 24rpx;
  padding: 24rpx;
  background: #F8FAFC;
  border-radius: 12rpx;
}

.approval-modal-logs-title {
  font-size: var(--fs-28);
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 16rpx;
}

.approval-modal-logs-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.approval-modal-logs-item {
  padding: 16rpx;
  background: #FFFFFF;
  border-radius: 8rpx;
  border-left: 3rpx solid #2563EB;
}

.approval-modal-logs-item.is-error {
  border-left-color: #DC2626;
}

.approval-modal-logs-item.is-approved {
  border-left-color: #16A34A;
}

.approval-modal-logs-action {
  font-size: var(--fs-26);
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 8rpx;
}

.approval-modal-logs-step {
  font-size: var(--fs-24);
  color: #6B7280;
  margin-bottom: 6rpx;
}

.approval-modal-logs-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.approval-modal-logs-operator {
  font-size: var(--fs-24);
  color: #6B7280;
  font-weight: 500;
}

.approval-modal-logs-time {
  font-size: var(--fs-24);
  color: #9CA3AF;
}

.approval-modal-logs-desc {
  font-size: var(--fs-24);
  color: #6B7280;
  line-height: 1.6;
  padding-top: 8rpx;
  border-top: 1rpx solid #F3F4F6;
  margin-top: 8rpx;
}

/* 空状态提示 */
.approval-modal-logs-empty {
  font-size: var(--fs-24);
  color: #9CA3AF;
  text-align: center;
  padding: 32rpx 0;
  line-height: 1.6;
}

/* 操作按钮 */
.approval-modal-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(37, 99, 235, 0.1);
}

.approval-reject-btn,
.approval-approve-btn {
  flex: 1;
  height: 78rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--fs-24);
  font-weight: 600;
  transition: all 0.3s ease;
  position: relative;
}

.approval-reject-btn {
  background: #F8FAFC;
  color: #4B6080;
}

.approval-reject-btn.is-disabled,
.approval-approve-btn.is-disabled {
  opacity: 0.6;
  pointer-events: none;
}

/* 加载动画 */
.approval-reject-btn.is-disabled::after,
.approval-approve-btn.is-disabled::after {
  content: '';
  position: absolute;
  right: 20rpx;
  width: 24rpx;
  height: 24rpx;
  border: 3rpx solid currentColor;
  border-top-color: transparent;
  border-right-color: transparent;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  opacity: 0.8;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* 中止申请按钮 */
.approval-modal-terminate {
  margin-top: 24rpx;
  padding: 24rpx;
  background: #FEE2E2;
  border-radius: 12rpx;
  border: 1rpx solid #FCA5A5;
}

.approval-modal-terminate-text {
  font-size: var(--fs-24);
  color: #991B1B;
  margin-bottom: 16rpx;
  line-height: 1.6;
}

.approval-terminate-btn {
  width: 100%;
  background: #DC2626;
  color: #FFFFFF;
  border: none;
  border-radius: 16rpx;
  height: 88rpx;
  font-size: var(--fs-28);
  font-weight: 600;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  position: relative;
}

.approval-terminate-btn.is-disabled {
  opacity: 0.6;
  pointer-events: none;
}

.approval-terminate-btn.is-disabled::after {
  content: '';
  position: absolute;
  right: 20rpx;
  width: 28rpx;
  height: 28rpx;
  border: 3rpx solid #FFFFFF;
  border-top-color: transparent;
  border-right-color: transparent;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  opacity: 0.8;
}

/* 复制申请按钮 */
.approval-modal-copy {
  margin-top: 24rpx;
  padding: 24rpx;
  background: #FEF3C7;
  border-radius: 12rpx;
  border: 1rpx solid #FCD34D;
}

.approval-modal-copy-text {
  font-size: var(--fs-24);
  color: #92400E;
  margin-bottom: 16rpx;
  line-height: 1.6;
}

.approval-copy-btn {
  width: 100%;
  background: linear-gradient(135deg, #2563EB 0%, #1D4ED8 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 16rpx;
  height: 88rpx;
  font-size: var(--fs-28);
  font-weight: 600;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
}

.approval-copy-btn::after {
  border: none;
}
