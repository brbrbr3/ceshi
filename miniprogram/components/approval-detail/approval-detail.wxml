<view class="approval-modal-mask {{animVisible ? 'is-visible' : ''}}" catchtouchmove="noop" bindtap="handleClose">
  <view class="approval-modal-card" catchtap="noop">
    <!-- 标题栏 -->
    <view class="approval-modal-head">
      <view>
        <view class="approval-modal-title">{{request.name}}的{{request.requestType}}详情</view>
        <view class="approval-modal-sub">{{request.requestNo}}</view>
      </view>
      <view class="approval-modal-close" bindtap="handleClose">×</view>
    </view>

    <!-- 详情内容 -->
    <view class="approval-modal-body">
      <!-- 动态字段列表 -->
      <block wx:for="{{detailFields}}" wx:key="field">
        <view class="approval-modal-row">
          <text class="approval-modal-label">{{item.label}}</text>
          <text class="approval-modal-value">{{item.value}}</text>
        </view>
      </block>

      <!-- 当前状态 -->
      <view class="approval-modal-row">
        <text class="approval-modal-label">当前状态</text>
        <text class="approval-modal-value" style="color: {{request.status === 'approved' ? '#16A34A' : request.status === 'rejected' ? '#DC2626' : request.status === 'terminated' ? '#DC2626' : '#D97706'}};">
          {{request.status === 'approved' ? '已通过' : request.status === 'rejected' ? '已驳回' : request.status === 'terminated' ? '已中止' : '待审批'}}
        </text>
      </view>

      <!-- 审批备注 -->
      <view wx:if="{{request.reviewRemark}}" class="approval-modal-remark">{{request.reviewRemark}}</view>

      <!-- 进度条（工作流步骤>=2且待审批时显示） -->
      <block wx:if="{{request.progress.totalSteps >= 2 && request.status === 'pending' && request.progress}}">
        <view class="approval-modal-progress">
          <view class="approval-modal-progress-header">
            <view class="approval-modal-progress-info">
              <view class="approval-modal-progress-step">第 {{request.progress.currentStep}}/{{request.progress.totalSteps}} 步</view>
              <view class="approval-modal-progress-text">{{request.progress.currentText}}</view>
            </view>
          </view>
          <view class="approval-modal-progress-bar">
            <view class="approval-modal-progress-fill" style="width: {{request.progress.percent}}%;"></view>
          </view>
        </view>
      </block>
    </view>

    <!-- 审批历史 -->
    <view wx:if="{{request}}" class="approval-modal-logs">
      <view class="approval-modal-logs-title">审批历史</view>
      <view wx:if="{{workflowLogs && workflowLogs.length > 0}}" class="approval-modal-logs-list">
        <view wx:for="{{workflowLogs}}" wx:key="_id" wx:for-index="idx" class="approval-modal-logs-item {{item.action === 'reject' || item.action === 'terminate' ? 'is-error' : ''}} {{item.action === 'approve' ? 'is-approved' : ''}}">
          <view class="approval-modal-logs-action">{{item.actionText}}</view>
          <view class="approval-modal-logs-info">
            <text class="approval-modal-logs-operator">{{idx === 0 && item.action === 'start' ? request.name : item.operatorName}}</text>
            <text class="approval-modal-logs-time">{{item.formattedTime}}</text>
          </view>
          <view wx:if="{{item.description}}" class="approval-modal-logs-desc">{{item.description}}</view>
        </view>
      </view>
      <view wx:else class="approval-modal-logs-empty">
        {{request.status === 'pending' ? '申请已提交，暂无审批历史' : '暂无审批历史记录'}}
      </view>
    </view>

    <!-- 审批操作按钮 -->
    <view wx:if="{{canReview && request.status === 'pending' && request.isCurrentApprover}}" class="approval-modal-actions">
      <view class="approval-reject-btn {{actionLoading ? 'is-disabled' : ''}}" bindtap="handleReject">
        {{actionLoading ? '处理中' : '驳回'}}
      </view>
      <view class="office-btn-primary approval-approve-btn {{actionLoading ? 'is-disabled' : ''}}" bindtap="handleApprove">
        {{actionLoading ? '处理中' : '同意'}}
      </view>
    </view>

    <!-- 申请人中止申请按钮 -->
    <view wx:if="{{request.status === 'pending' && request.openid === currentOpenid}}" class="approval-modal-terminate">
      <view class="approval-modal-terminate-text">作为申请人，您可以随时中止此申请</view>
      <view class="approval-terminate-btn {{actionLoading ? 'is-disabled' : ''}}" bindtap="handleTerminate">
        {{actionLoading ? '处理中' : '中止申请'}}
      </view>
    </view>

    <!-- 就医申请被驳回后的复制申请按钮 -->
    <view wx:if="{{request.status === 'rejected' && request.orderType === 'medical_application' && request.openid === currentOpenid}}" class="approval-modal-copy">
      <view class="approval-modal-copy-text">该申请已被驳回，是否依据此申请信息重新创建？</view>
      <view class="office-btn-primary approval-copy-btn" bindtap="handleCopyMedical">重新创建申请</view>
    </view>
  </view>
</view>
