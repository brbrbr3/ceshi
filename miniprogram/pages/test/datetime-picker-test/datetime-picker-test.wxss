/* datetime-picker-test.wxss */

.test-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #F8FAFC 0%, #EEF2FF 50%, #F8FAFC 100%);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 页面头部 */
.page-header {
  padding: 48rpx 32rpx 32rpx;
  text-align: center;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1E293B;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.header-desc {
  font-size: 26rpx;
  color: #64748B;
  line-height: 1.6;
}

/* 区块 */
.section {
  padding: 24rpx 32rpx;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 24rpx;
}

.title-icon {
  margin-right: 12rpx;
  font-size: 32rpx;
}

.clear-btn {
  margin-left: auto;
  font-size: 24rpx;
  color: #64748B;
  font-weight: 400;
}

/* 测试卡片 */
.test-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(0, 0, 0, 0.02);
}

.card-header {
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 8rpx;
}

.card-desc {
  font-size: 24rpx;
  color: #94A3B8;
}

.card-content {
  margin-bottom: 16rpx;
}

.card-actions {
  display: flex;
  gap: 16rpx;
  padding-top: 8rpx;
  border-top: 1rpx solid #F1F5F9;
}

/* 按钮 */
.action-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 32rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.2s ease;
  background: linear-gradient(135deg, #2563EB 0%, #1D4ED8 100%);
  color: #FFFFFF;
}

.action-btn:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.action-btn--small {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
}

.action-btn--ghost {
  background: transparent;
  color: #64748B;
  border: 1rpx solid #E2E8F0;
}

.action-btn--ghost:active {
  background: #F8FAFC;
}

/* 结果列表 */
.results-list {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.result-item {
  padding: 24rpx;
  border-bottom: 1rpx solid #F1F5F9;
}

.result-item:last-child {
  border-bottom: none;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.result-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1E293B;
}

.result-time {
  font-size: 22rpx;
  color: #94A3B8;
}

.result-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #2563EB;
  margin-bottom: 12rpx;
  letter-spacing: 1rpx;
}

.result-detail {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 24rpx;
  color: #64748B;
}

.separator {
  color: #E2E8F0;
}

/* 空状态 */
.empty-state {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 64rpx 32rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #94A3B8;
}

/* 文档卡片 */
.doc-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.doc-section {
  margin-bottom: 24rpx;
}

.doc-section:last-child {
  margin-bottom: 0;
}

.doc-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 16rpx;
  padding-left: 12rpx;
  border-left: 4rpx solid #2563EB;
}

.doc-table {
  background: #F8FAFC;
  border-radius: 12rpx;
  padding: 16rpx;
}

.doc-row {
  display: flex;
  align-items: flex-start;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #E2E8F0;
}

.doc-row:last-child {
  border-bottom: none;
}

.doc-prop {
  flex-shrink: 0;
  width: 180rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #2563EB;
  font-family: 'SF Mono', 'Consolas', monospace;
}

.doc-desc {
  flex: 1;
  font-size: 24rpx;
  color: #64748B;
  line-height: 1.5;
}

.code-block {
  background: #1E293B;
  border-radius: 12rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.code-block text {
  font-size: 22rpx;
  font-family: 'SF Mono', 'Consolas', monospace;
  color: #E2E8F0;
  line-height: 1.6;
}

/* 底部间距 */
.bottom-spacing {
  height: 48rpx;
}
