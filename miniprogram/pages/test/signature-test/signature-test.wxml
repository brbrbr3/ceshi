<view class="test-container">
  <view class="test-header">
    <text class="test-title">签字板测试</text>
  </view>

  <view class="test-actions">
    <button class="test-btn" type="primary" bindtap="openSignature">打开签字板</button>
  </view>

  <!-- 签名预览 -->
  <view class="test-preview" wx:if="{{signImage}}">
    <view class="test-preview-title">签名结果预览</view>
    <image class="test-preview-img" src="{{signImage}}" mode="aspectFit" bindtap="previewImage" />
    <view class="test-preview-actions">
      <button class="test-btn-sm" size="mini" bindtap="clearResult">清除结果</button>
    </view>
  </view>

  <!-- 签字板组件 -->
  <signature-pad
    show="{{showSignature}}"
    penColor="#000000"
    bind:confirm="onSignConfirm"
    bind:cancel="onSignCancel" />
</view>
