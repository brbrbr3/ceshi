.test-container {
  padding: 40rpx;
}

.test-header {
  margin-bottom: 40rpx;
}

.test-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.test-actions {
  margin-bottom: 40rpx;
}

.test-preview {
  margin-top: 40rpx;
}

.test-preview-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #555;
  margin-bottom: 20rpx;
}

.test-preview-img {
  width: 100%;
  height: 300rpx;
  border: 2rpx dashed #ddd;
  border-radius: 12rpx;
  background: #fafafa;
}

.test-preview-actions {
  margin-top: 20rpx;
  display: flex;
  justify-content: center;
}
