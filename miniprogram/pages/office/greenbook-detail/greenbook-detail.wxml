<view class="gb-detail-page" style="{{fontStyle}}">
  <!-- 顶部固定：发帖人信息 -->
  <view class="gb-detail-header" style="padding-top: {{statusBarHeight}}px;">
    <view class="gb-detail-header-inner">
      <view class="gb-detail-back" bindtap="handleBack">
        <view class="gb-detail-back-icon"></view>
      </view>
      <view class="gb-detail-author-fixed">
        <image class="gb-detail-author-avatar" src="{{post.authorAvatar}}" wx:if="{{post && post.authorAvatar}}" />
        <view class="gb-detail-author-avatar-placeholder" wx:elif="{{post}}">{{post.authorName[0] || '?'}}</view>
        <text class="gb-detail-author-name">{{post ? post.authorName : ''}}</text>
      </view>
      <view class="gb-detail-more" bindtap="handleMore">
        <text>···</text>
      </view>
    </view>
  </view>

  <!-- 可滚动内容 -->
  <scroll-view
    scroll-y
    class="gb-detail-scroll"
    style="margin-top: {{statusBarHeight + 44}}px;"
    show-scrollbar="{{false}}"
    enhanced
    bindscrolltolower="loadMoreComments"
  >
    <view wx:if="{{post}}">
      <!-- 图片 Swiper -->
      <swiper
        style="width: 100%; height: {{swiperHeight}}px;"
        indicator-dots
        indicator-color="rgba(0,0,0,0.3)"
        indicator-active-color="#FFFFFF"
        circular
        bindchange="handleSwiperChange"
      >
        <swiper-item wx:for="{{post.images}}" wx:key="*this" wx:for-item="img">
          <image class="gb-detail-image" mode="aspectFill" src="{{img}}" />
        </swiper-item>
      </swiper>

      <!-- 图片计数 -->
      <view class="gb-detail-image-counter" wx:if="{{post.images.length > 1}}">
        {{currentImage + 1}} / {{post.images.length}}
      </view>

      <!-- 详情内容 -->
      <view class="gb-detail-content">
        <!-- 标题 -->
        <view class="gb-detail-title" wx:if="{{post.title}}">{{post.title}}</view>

        <!-- 正文 -->
        <view class="gb-detail-body">{{post.content}}</view>

        <!-- 话题标签 -->
        <view class="gb-detail-tags" wx:if="{{post.tags && post.tags.length > 0}}">
          <text class="gb-detail-tag" wx:for="{{post.tags}}" wx:key="*this">#{{item}}</text>
        </view>

        <!-- 交互栏 -->
        <view class="gb-detail-actions">
          <view class="gb-detail-action" bindtap="handleLike">
            <text class="gb-detail-action-icon {{isLiked ? 'is-liked' : ''}}">{{isLiked ? '❤️' : '🤍'}}</text>
            <text>{{likeCount}}</text>
          </view>
          <view class="gb-detail-action">
            <text class="gb-detail-action-icon">💬</text>
            <text>{{commentCount}}</text>
          </view>
          <view class="gb-detail-action" bindtap="handleCollect">
            <text class="gb-detail-action-icon {{isCollected ? 'is-collected' : ''}}">{{isCollected ? '⭐' : '☆'}}</text>
            <text>{{collectCount}}</text>
          </view>
        </view>

        <!-- 评论区 -->
        <view class="gb-detail-comments">
          <view class="gb-detail-comments-title">评论 ({{commentCount}})</view>

          <!-- 评论列表 -->
          <view wx:if="{{comments.length > 0}}">
            <view class="gb-detail-comment" wx:for="{{comments}}" wx:key="_id" wx:for-item="comment">
              <!-- 左侧头像 -->
              <view class="gb-detail-comment-avatar-wrap">
                <image class="gb-detail-comment-avatar" src="{{comment.authorAvatar}}" wx:if="{{comment.authorAvatar}}" />
                <view class="gb-detail-comment-avatar-placeholder" wx:else>{{comment.authorName[0] || '?'}}</view>
              </view>
              
              <!-- 中间内容 -->
              <view class="gb-detail-comment-center">
                <text class="gb-detail-comment-name">{{comment.authorName}}</text>
                <view class="gb-detail-comment-text">{{comment.content}}</view>
                <view class="gb-detail-comment-bottom">
                  <text class="gb-detail-comment-time">{{comment.createdAt ? formatTime(comment.createdAt) : ''}}</text>
                  <text class="gb-detail-comment-reply-btn" bindtap="handleReplyComment" data-comment-id="{{comment._id}}" data-author-name="{{comment.authorName}}">回复</text>
                </view>

                <!-- 二级回复（缩进） -->
                <view class="gb-detail-replies" wx:if="{{comment.replies && comment.replies.length > 0}}">
                  <view class="gb-detail-reply" wx:for="{{comment.replies}}" wx:key="_id" wx:for-item="reply">
                    <text class="gb-detail-reply-name">{{reply.authorName}}</text>
                    <text class="gb-detail-if-reply-to-name" wx:if="{{reply.replyToName}}"> 回复 <text class="gb-detail-reply-to">{{reply.replyToName}}</text></text>
                    <text class="gb-detail-reply-text">：{{reply.content}}</text>
                  </view>
                  <view class="gb-detail-more-replies" wx:if="{{comment.replyCount > 3}}" bindtap="handleReplyComment" data-comment-id="{{comment._id}}" data-author-name="{{comment.authorName}}">
                    查看全部 {{comment.replyCount}} 条回复 >
                  </view>
                </view>
              </view>
              
              <!-- 右侧点赞 -->
              <view class="gb-detail-comment-like" bindtap="handleLikeComment" data-comment-id="{{comment._id}}">
                <text class="gb-detail-comment-like-icon {{comment.isLiked ? 'is-liked' : ''}}">{{comment.isLiked ? '❤️' : '🤍'}}</text>
                <text class="gb-detail-comment-like-count" wx:if="{{comment.likeCount > 0}}">{{comment.likeCount}}</text>
              </view>
            </view>
          </view>

          <view class="gb-detail-empty" wx:else>
            <text>暂无评论，快来说点什么吧~</text>
          </view>

          <!-- 加载更多评论 -->
          <view class="gb-detail-load-more" wx:if="{{commentHasMore}}" bindtap="loadMoreComments">
            <text>加载更多评论</text>
          </view>
        </view>

        <!-- 底部安全区域 -->
        <view style="height: 120rpx;"></view>
      </view>
    </view>
  </scroll-view>

  <!-- 底部评论输入栏 -->
  <view class="gb-detail-footer" style="padding-bottom: env(safe-area-inset-bottom);">
    <view class="gb-detail-reply-hint" wx:if="{{replyTarget}}">
      <text>回复 @{{replyTarget.authorName}}</text>
      <text class="gb-detail-reply-cancel" bindtap="handleCancelReply"> x</text>
    </view>
    <view class="gb-detail-footer-inner">
      <input
        class="gb-detail-input"
        placeholder="说点什么..."
        value="{{commentContent}}"
        bindinput="handleCommentInput"
        bindconfirm="handleSendComment"
        focus="{{false}}"
        confirm-type="send"
      />
      <view class="gb-detail-send-btn {{commentContent ? 'is-active' : ''}}" bindtap="handleSendComment">
        <text>发送</text>
      </view>
    </view>
  </view>
</view>
