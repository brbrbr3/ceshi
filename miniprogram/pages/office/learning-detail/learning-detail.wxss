/* pages/office/learning-detail/learning-detail.wxss */
.learning-detail-page {
  min-height: 100%;
}

/* 红色头部 */
.learning-detail-header {
  padding: 60rpx 40rpx 90rpx;
  background: linear-gradient(135deg, #B91C1C 0%, #DC2626 50%, #EF4444 100%) !important;
}

.ld-page-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
}

.ld-article-title {
  margin-top: 8rpx;
  font-size: 42rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.3;
}

.ld-content {
  margin-top: -60rpx;
  padding: 0 24rpx 40rpx;
}

.ld-card {
  padding: 32rpx;
}

/* 作者信息 */
.ld-author-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.ld-author-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #FEE2E2;
  flex-shrink: 0;
}

.ld-author-info {
  flex: 1;
}

.ld-author-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
}

.ld-author-meta {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #94A3B8;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.ld-meta-dot {
  font-size: 16rpx;
}

.ld-pinned-tag {
  font-size: 20rpx;
  color: #FFFFFF;
  background: linear-gradient(135deg, #DC2626, #B91C1C);
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.ld-divider {
  height: 1rpx;
  background-color: rgba(185, 28, 28, 0.08);
  margin: 24rpx 0;
}

/* 文章内容 */
.ld-body {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 8rpx 0;
}

.ld-body rich-text {
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
  word-break: break-all;
}

.ld-body-text {
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
}

/* 操作区域 */
.ld-actions {
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(185, 28, 28, 0.06);
}

.btn-delete {
  width: 100%;
  background-color: #FEE2E2;
  color: #B91C1C;
  border: none;
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 20rpx 0;
}

.btn-delete:active {
  background-color: #FECACA;
}

/* 加载状态 */
.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid #e0e0e0;
  border-top-color: #DC2626;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
  margin-left: 16rpx;
}
