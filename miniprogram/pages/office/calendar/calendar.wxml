<!--全馆日程页面-->
<view class="calendar-page">
  <!-- 标准头部设计 -->
  <view class="office-gradient-header">
    <view class="office-header-top calendar-header-top">
      <view>
        <view class="calendar-title">全馆日程</view>
        <view class="calendar-subtitle">查看全馆日程（周视图）与节假日安排</view>
      </view>
      <view class="calendar-config-btn" bindtap="handleConfigTap">配置节假日</view>
    </view>
  </view>

  <!-- 日历区域 -->
  <view class="calendar-container">
    <calendar 
      id="calendar" 
      view="{{calendarView}}" 
      weekstart="{{0}}" 
      marks="{{marks}}" 
      custom-nav-bar="{{true}}" 
      bindload="handleCalendarLoad" 
      bindclick="handleCalendarClick" 
      bindchange="handleCalendarChange"
      bindviewchange="handleViewChange"
      style="--wc-primary: #2563EB; --wc-bg-light: #FFFFFF;" 
    />
  </view>

  <!-- 时间轴日程列表（仅周视图显示） -->
  <view class="schedule-section" wx:if="{{isWeekView}}">
    <!-- 日期标题 -->
    <view class="schedule-date-header">
      <view class="schedule-date-title">{{selectedDateText}}</view>
      <view class="schedule-date-count">{{schedules.all.length}} 项日程</view>
    </view>

    <!-- 全天日程区域 -->
    <view class="all-day-section" wx:if="{{schedules.allDay.length > 0}}">
      <view class="all-day-label">全天</view>
      <view class="all-day-events">
        <view 
          class="all-day-event" 
          wx:for="{{schedules.allDay}}" 
          wx:key="_id"
          style="background: {{item.color}}20; border-left-color: {{item.color}};"
          bindtap="handleScheduleTap"
          data-schedule="{{item}}"
        >
          <text class="all-day-event-title">{{item.title}}</text>
        </view>
      </view>
    </view>

    <!-- 时间轴主体 -->
    <scroll-view 
      class="timeline-scroll" 
      scroll-y="true"
      scroll-into-view="{{currentTimeView}}"
      enhanced="true"
      show-scrollbar="false"
    >
      <view class="timeline-container">
        <!-- 小时网格 -->
        <view class="timeline-grid">
          <view 
            class="hour-row" 
            wx:for="{{hours}}" 
            wx:key="*this"
            id="hour-{{item}}"
          >
            <view class="hour-label">{{item < 10 ? '0' + item : item}}:00</view>
            <!-- Hour-line似乎没有必要，因为已经有了timeline-grid，注释掉
            <view class="hour-line"></view> -->
          </view>
        </view>

        <!-- 日程条（绝对定位） -->
        <view class="schedule-bars">
          <view 
            class="schedule-bar" 
            wx:for="{{schedules.timed}}" 
            wx:key="_id"
            style="top: {{item.top}}rpx; height: {{item.height}}rpx; left: {{item.left}}rpx; width: {{item.width}}rpx; background: {{item.color}};"
            bindtap="handleScheduleTap"
            data-schedule="{{item}}"
          >
            <text class="schedule-bar-title">{{item.title}}</text>
            <text class="schedule-bar-time" wx:if="{{item.height > 60}}">{{item.startTime}} - {{item.endTime}}</text>
          </view>
        </view>

        <!-- 当前时间红线 -->
        <view 
          class="current-time-line" 
          wx:if="{{showCurrentTime}}"
          style="top: {{currentTimeTop}}rpx;"
        >
          <text class="current-time-label">{{currentTimeText}}</text>
          <view class="current-time-dot"></view>
          <view class="current-time-bar"></view>
        </view>
      </view>
    </scroll-view>

    <!-- 添加日程按钮 -->
    <view class="add-schedule-btn" bindtap="handleAddSchedule">
      <text class="add-schedule-icon">+</text>
    </view>
  </view>

  <!-- 日程详情弹窗 -->
  <view class="detail-popup-mask {{showDetailPopup ? 'is-visible' : ''}}" catchtouchmove="stopPropagation" bindtap="hideDetailPopup">
    <view class="detail-popup-container" catchtap="stopPropagation">
      <!-- 弹窗头部 -->
      <view class="detail-popup-header">
        <view class="detail-popup-close" bindtap="hideDetailPopup">×</view>
        <view class="detail-popup-title">日程详情</view>
        <view class="detail-popup-edit" bindtap="handleEditFromDetail">编辑</view>
      </view>

      <!-- 详情内容 -->
      <scroll-view class="detail-popup-scroll" scroll-y="true" enhanced="true" show-scrollbar="false">
        <view class="detail-popup-content" wx:if="{{detailSchedule}}">
          <!-- 标题区域 -->
          <view class="detail-header">
            <view class="detail-type-dot" style="background: {{detailSchedule.color}};"></view>
            <text class="detail-title">{{detailSchedule.title}}</text>
            <text class="detail-type-name">{{detailSchedule.typeName}}</text>
          </view>

          <!-- 时间信息 -->
          <view class="detail-section">
            <view class="detail-section-title">时间</view>
            <view class="detail-time-info">
              <view class="detail-time-row" wx:if="{{detailSchedule.isAllDay}}">
                <text class="detail-time-label">全天</text>
                <text class="detail-time-value">{{detailSchedule.startDate}}</text>
              </view>
              <view class="detail-time-row" wx:else>
                <text class="detail-time-label">开始</text>
                <text class="detail-time-value">{{detailSchedule.startDate}} {{detailSchedule.startTime}}</text>
              </view>
              <view class="detail-time-row" wx:if="{{!detailSchedule.isAllDay}}">
                <text class="detail-time-label">结束</text>
                <text class="detail-time-value">{{detailSchedule.endDate}} {{detailSchedule.endTime}}</text>
              </view>
            </view>
          </view>

          <!-- 重复信息 -->
          <view class="detail-section" wx:if="{{detailSchedule.repeat && detailSchedule.repeat !== 'none'}}">
            <view class="detail-section-title">重复</view>
            <view class="detail-repeat-info">
              <text class="detail-repeat-label">{{detailSchedule.repeatLabel || (detailSchedule.repeat === 'daily' ? '每天' : detailSchedule.repeat === 'weekly' ? '每周' : detailSchedule.repeat === 'monthly' ? '每月' : detailSchedule.repeat === 'workdayDaily' ? '工作日每天' : detailSchedule.repeat === 'workdayWeekly' ? '工作日每周' : '不重复')}}</text>
              <text class="detail-repeat-end" wx:if="{{detailSchedule.repeatEndDate}}">至 {{detailSchedule.repeatEndDate}}</text>
            </view>
          </view>

          <!-- 地点 -->
          <view class="detail-section" wx:if="{{detailSchedule.location}}">
            <view class="detail-section-title">地点</view>
            <text class="detail-section-value">{{detailSchedule.location}}</text>
          </view>

          <!-- 备注 -->
          <view class="detail-section" wx:if="{{detailSchedule.description}}">
            <view class="detail-section-title">备注</view>
            <text class="detail-section-value">{{detailSchedule.description}}</text>
          </view>

          <!-- 创建者 -->
          <view class="detail-section" wx:if="{{detailSchedule.creatorName}}">
            <view class="detail-section-title">创建者</view>
            <text class="detail-section-value">{{detailSchedule.creatorName}}</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 日程编辑弹窗 -->
  <view class="schedule-popup-mask {{showSchedulePopup ? 'is-visible' : ''}}" catchtouchmove="stopPropagation" bindtap="hideSchedulePopup">
    <view class="schedule-popup-container" catchtap="stopPropagation">
      <!-- 弹窗头部 -->
      <view class="schedule-popup-header">
        <view class="schedule-popup-cancel" bindtap="hideSchedulePopup">取消</view>
        <view class="schedule-popup-title">{{editingSchedule ? '编辑日程' : '新建日程'}}</view>
        <view class="schedule-popup-save" bindtap="handleSaveSchedule">完成</view>
      </view>

      <!-- 表单内容 -->
      <scroll-view class="schedule-popup-scroll" scroll-y="true" enhanced="true" show-scrollbar="false">
        <view class="schedule-popup-form">
          <!-- 标题输入 -->
          <view class="schedule-form-card">
            <view class="schedule-field">
              <view class="schedule-field-label">标题</view>
              <input 
                class="schedule-input" 
                placeholder="请输入日程标题" 
                value="{{scheduleForm.title}}"
                bindinput="handleTitleInput"
                maxlength="50"
              />
            </view>
          </view>

          <!-- 全天开关 -->
          <view class="schedule-form-card">
            <view class="schedule-field schedule-field-row">
              <view class="schedule-field-label">全天</view>
              <switch 
                checked="{{scheduleForm.isAllDay}}" 
                color="#2563EB"
                bindchange="handleAllDayChange"
              />
            </view>
          </view>

          <!-- 时间选择 -->
          <view class="schedule-form-card">
            <!-- 开始时间 -->
            <view class="schedule-field">
              <view class="schedule-field-label">开始</view>
              <view class="schedule-picker-full">
                <datetime-picker 
                  value="{{scheduleForm.startDatetime}}"
                  fields="{{scheduleForm.isAllDay ? ['year', 'month', 'day'] : ['year', 'month', 'day', 'hour', 'minute']}}"
                  start-date="2020-01-01"
                  end-date="2030-12-31"
                  bind:change="handleStartDatetimeChange"
                />
              </view>
            </view>

            <!-- 结束时间 -->
            <view class="schedule-field">
              <view class="schedule-field-label">结束</view>
              <view class="schedule-picker-full">
                <datetime-picker 
                  value="{{scheduleForm.endDatetime}}"
                  fields="{{scheduleForm.isAllDay ? ['year', 'month', 'day'] : ['year', 'month', 'day', 'hour', 'minute']}}"
                  start-date="2020-01-01"
                  end-date="2030-12-31"
                  bind:change="handleEndDatetimeChange"
                />
              </view>
            </view>
          </view>

          <!-- 类型和重复 -->
          <view class="schedule-form-card">
            <!-- 类型选择 -->
            <view class="schedule-field schedule-field-clickable" bindtap="handleTypeTap">
              <view class="schedule-field-label">
                <view class="schedule-type-dot" style="background: {{scheduleForm.color}};"></view>
                <text>类型</text>
              </view>
              <view class="schedule-field-value">
                <text class="schedule-field-value-content">{{scheduleForm.typeName}}</text>
                <text class="schedule-picker-arrow">›</text>
              </view>
            </view>

            <!-- 重复设置 -->
            <view class="schedule-field schedule-field-clickable" bindtap="handleRepeatTap">
              <view class="schedule-field-label">重复</view>
              <view class="schedule-field-value">
                <text class="schedule-field-value-content">{{scheduleForm.repeatLabel}}</text>
                <text class="schedule-picker-arrow">›</text>
              </view>
            </view>

            <!-- 重复截止日期（仅当选择了重复类型时显示） -->
            <view class="schedule-field schedule-field-clickable" wx:if="{{scheduleForm.repeat !== 'none'}}" bindtap="handleRepeatEndDateTap">
              <view class="schedule-field-label">截止日期</view>
              <view class="schedule-field-value">
                <text class="schedule-field-value-content {{scheduleForm.repeatEndDate ? '' : 'is-placeholder'}} schedule-field-value-content-repeatEndDate">
                  {{scheduleForm.repeatEndDate || '请选择截止日期'}}
                </text>
                <text class="schedule-picker-arrow">›</text>
              </view>
            </view>
          </view>

          <!-- 地点和备注 -->
          <view class="schedule-form-card">
            <view class="schedule-field">
              <view class="schedule-field-label">地点</view>
              <input 
                class="schedule-input" 
                placeholder="选填" 
                value="{{scheduleForm.location}}"
                bindinput="handleLocationInput"
                maxlength="50"
              />
            </view>
            <view class="schedule-field">
              <view class="schedule-field-label">备注</view>
              <textarea 
                class="schedule-textarea" 
                placeholder="选填" 
                value="{{scheduleForm.description}}"
                bindinput="handleDescriptionInput"
                maxlength="200"
                auto-height
              />
            </view>
          </view>

          <!-- 删除按钮（编辑模式） -->
          <view class="schedule-delete-btn" wx:if="{{editingSchedule}}" bindtap="handleDeleteSchedule">
            删除日程
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 类型选择弹窗 -->
  <view class="type-popup-mask {{showTypePopup ? 'is-visible' : ''}}" catchtouchmove="stopPropagation" bindtap="hideTypePopup">
    <view class="type-popup-container" catchtap="stopPropagation">
      <view class="type-popup-header">
        <view class="type-popup-title">选择类型</view>
        <view class="type-popup-close" bindtap="hideTypePopup">×</view>
      </view>
      <view class="type-list">
        <view 
          class="type-item {{scheduleForm.type === item.type ? 'is-active' : ''}}" 
          wx:for="{{typeOptions}}" 
          wx:key="type"
          bindtap="handleSelectType"
          data-type="{{item.type}}"
        >
          <view class="type-item-dot" style="background: {{item.color}};"></view>
          <text class="type-item-name">{{item.name}}</text>
          <view class="type-item-check" wx:if="{{scheduleForm.type === item.type}}">✓</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 重复选择弹窗 -->
  <view class="type-popup-mask {{showRepeatPopup ? 'is-visible' : ''}}" catchtouchmove="stopPropagation" bindtap="hideRepeatPopup">
    <view class="type-popup-container" catchtap="stopPropagation">
      <view class="type-popup-header">
        <view class="type-popup-title">重复设置</view>
        <view class="type-popup-close" bindtap="hideRepeatPopup">×</view>
      </view>
      <view class="type-list">
        <view 
          class="type-item {{scheduleForm.repeat === item.value ? 'is-active' : ''}}" 
          wx:for="{{repeatOptions}}" 
          wx:key="value"
          bindtap="handleSelectRepeat"
          data-value="{{item.value}}"
        >
          <text class="type-item-name">{{item.label}}</text>
          <view class="type-item-check" wx:if="{{scheduleForm.repeat === item.value}}">✓</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 重复截止日期选择弹窗 -->
  <view class="type-popup-mask {{showRepeatEndDatePicker ? 'is-visible' : ''}}" catchtouchmove="stopPropagation" bindtap="hideRepeatEndDatePicker">
    <view class="type-popup-container" catchtap="stopPropagation">
      <view class="type-popup-header">
        <view class="type-popup-title">选择截止日期</view>
        <view class="type-popup-close" bindtap="hideRepeatEndDatePicker">×</view>
      </view>
      <view class="date-picker-container">
        <datetime-picker 
          value="{{scheduleForm.repeatEndDate || scheduleForm.startDatetime}}"
          fields="{{['year', 'month', 'day']}}"
          start-date="{{scheduleForm.startDatetime ? scheduleForm.startDatetime.split(' ')[0] : ''}}"
          end-date="{{maxRepeatEndDate}}"
          bind:change="handleRepeatEndDateChange"
        />
      </view>
    </view>
  </view>

  <!-- 配置弹窗 -->
  <view class="config-popup-mask {{showConfigPopup ? 'is-visible' : ''}}" catchtouchmove="stopPropagation" bindtap="hideConfigPopup">
    <view class="config-popup-container" catchtap="stopPropagation">
      <!-- 固定头部：标题 + 年份选择 -->
      <view class="config-popup-fixed-header">
        <view class="config-popup-header">
          <view class="config-popup-title">配置法定节假日</view>
          <view class="config-popup-close" bindtap="hideConfigPopup">×</view>
        </view>
        <view class="config-field">
          <view class="config-field-label">配置</view>
          <picker mode="selector" range="{{yearOptions}}" value="{{yearOptions.indexOf(configYear)}}" bindchange="handleYearChange">
            <view class="config-year-picker">
              <text>{{configYear}}</text>
              <text class="config-picker-arrow">▼</text>
            </view>
          </picker>
          <view class="config-field-label-inline">年节假日</view>
        </view>
      </view>

      <!-- 可滚动区域：节假日列表 -->
      <scroll-view class="config-popup-scroll" scroll-y="true" enhanced="true" show-scrollbar="false">
        <view class="config-popup-form">
          <view class="config-holidays-list">
            <view class="config-holiday-item" wx:for="{{holidays}}" wx:key="index">
              <view class="config-holiday-label">第{{index + 1}}个节假日</view>
              <datetime-picker value="{{item.date}}" fields="{{['year', 'month', 'day']}}" start-date="{{configYear}}-01-01" end-date="{{configYear}}-12-31" bind:change="handleDateChange" data-index="{{index}}" />
              <view class="config-delete-btn" bindtap="handleDeleteHoliday" data-index="{{index}}">×</view>
            </view>
          </view>
        </view>
      </scroll-view>

      <!-- 固定底部：添加 + 提交按钮 -->
      <view class="config-popup-footer">
        <view class="config-add-btn" bindtap="handleAddHoliday">
          <text class="config-add-icon">+</text>
          <text>添加节假日</text>
        </view>
        <button class="config-submit-btn" loading="{{submitting}}" disabled="{{submitting}}" bindtap="handleSubmitConfig">
          提交配置
        </button>
      </view>
    </view>
  </view>
</view>
