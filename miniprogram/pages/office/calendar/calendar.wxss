/* 本馆日历页面样式 */

.calendar-page {
  min-height: 100vh;
  background: #EEF2FF;
}

.calendar-header-top{
  margin-bottom: -100rpx;
}

/* 头部标题 */
.calendar-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.calendar-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

/* 配置按钮 */
.calendar-config-btn {
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 600;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

/* 日历容器 */
.calendar-container {
  padding: 24rpx 0 0;
}

/* 配置弹窗遮罩 */
.config-popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 9999;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.config-popup-mask.is-visible {
  opacity: 1;
  visibility: visible;
}

/* 配置弹窗容器 */
.config-popup-container {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  height: 80vh;
  display: flex;
  flex-direction: column;
  margin: 0 20rpx 0;
}

.config-popup-mask.is-visible .config-popup-container {
  transform: translateY(0);
}

/* 固定头部区域（标题 + 年份选择） */
.config-popup-fixed-header {
  flex-shrink: 0;
}

/* 配置弹窗头部 */
.config-popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #F1F5F9;
}

/* 弹窗标题 */
.config-popup-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1E293B;
}

.config-popup-close {
  font-size: 48rpx;
  color: #94A3B8;
  line-height: 1;
  padding: 0 8rpx;
}

/* 年份选择 */
.config-field {
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx;
  border-bottom: 1rpx solid #F1F5F9;
}

/* 可滚动区域 */
.config-popup-scroll {
  flex: 1;
  height: 0;
  overflow: hidden;
}

/* 配置表单（scroll-view 内部） */
.config-popup-form {
  padding: 24rpx 32rpx;
}

.config-field-label {
  font-size: 28rpx;
  color: #1E293B;
  font-weight: 500;
}

.config-field-label-inline {
  font-size: 28rpx;
  color: #1E293B;
  font-weight: 500;
}

.config-year-picker {
  display: flex;
  align-items: center;
  background: #F8FAFC;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  margin: 0 16rpx;
}

.config-year-picker text:first-child {
  font-size: 28rpx;
  color: #2563EB;
  font-weight: 600;
}

.config-picker-arrow {
  font-size: 20rpx;
  color: #94A3B8;
  margin-left: 8rpx;
}

/* 节假日列表 */
.config-holidays-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.config-holiday-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.config-holiday-label {
  font-size: 26rpx;
  color: #64748B;
  width: 180rpx;
  flex-shrink: 0;
}

.config-date-picker {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 0 24rpx;
  height: 80rpx;
}

.config-date-picker text:first-child {
  font-size: 28rpx;
  color: #1E293B;
}

.config-delete-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FEE2E2;
  border-radius: 50%;
  font-size: 32rpx;
  color: #DC2626;
  flex-shrink: 0;
}

/* 添加按钮 */
.config-add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
  background: #EFF6FF;
  border: 2rpx dashed #2563EB;
  color: #2563EB;
}

.config-add-icon {
  font-size: 36rpx;
  font-weight: 600;
}

/* 弹窗底部（固定提交按钮） */
.config-popup-footer {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #F1F5F9;
  flex-shrink: 0;
  z-index: 100;
}

/* 提交按钮 */
.config-submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #2563EB 0%, #4F46E5 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
}

.config-submit-btn[disabled] {
  background: #94A3B8;
}

/* ========================================
   时间轴日程列表样式
   ======================================== */

/* 日程区域容器 */
.schedule-section {
  margin: 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  position: relative;
  box-shadow: 0 8rpx 32rpx rgba(37, 99, 235, 0.08);
}

/* 日期标题 */
.schedule-date-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #F1F5F9;
}

.schedule-date-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1E293B;
}

.schedule-date-count {
  font-size: 26rpx;
  color: #64748B;
}

/* 全天日程区域 */
.all-day-section {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #F1F5F9;
  background: #F8FAFC;
}

.all-day-label {
  width: 80rpx;
  font-size: 24rpx;
  color: #64748B;
  flex-shrink: 0;
  padding-top: 8rpx;
}

.all-day-events {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.all-day-event {
  padding: 12rpx 20rpx;
  border-radius: 12rpx;
  border-left: 4rpx solid;
  flex-shrink: 0;
}

.all-day-event-title {
  font-size: 26rpx;
  color: #1E293B;
  font-weight: 500;
}

/* 时间轴滚动区域 */
.timeline-scroll {
  height: 600rpx;
  position: relative;
}

.timeline-container {
  position: relative;
  min-height: 100%;
}

/* 小时网格 */
.timeline-grid {
  position: relative;
}

.hour-row {
  display: flex;
  align-items: flex-start;
  height: 100rpx;
  border-bottom: 1rpx solid #F1F5F9;
}

.hour-label {
  width: 80rpx;
  font-size: 22rpx;
  color: #94A3B8;
  text-align: center;
  padding-top: 4rpx;
  flex-shrink: 0;
}

/* .hour-line {
  flex: 1;
  height: 1rpx;
  background: #E2E8F0;
  margin-top: 16rpx;
} */

/* 日程条容器 */
.schedule-bars {
  position: absolute;
  top: 0;
  left: 80rpx;
  right: 16rpx;
  bottom: 0;
  pointer-events: none;
}

/* 日程条 */
.schedule-bar {
  position: absolute;
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
  box-sizing: border-box;
  pointer-events: auto;
  overflow: hidden;
  min-height: 50rpx;
  opacity: 0.9;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.schedule-bar-title {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 500;
  display: block;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.2);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.schedule-bar-time {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.9);
  display: block;
  margin-top: 4rpx;
}

/* 当前时间红线 */
.current-time-line {
  position: absolute;
  left: 80rpx;
  right: 16rpx;
  display: flex;
  align-items: center;
  pointer-events: none;
  z-index: 100;
}

.current-time-label {
  position: absolute;
  left: -76rpx;
  font-size: 20rpx;
  color: #EF4444;
  font-weight: 600;
  width: 72rpx;
  text-align: right;
}

.current-time-dot {
  width: 16rpx;
  height: 16rpx;
  background: #EF4444;
  border-radius: 50%;
  flex-shrink: 0;
  box-shadow: 0 0 8rpx rgba(239, 68, 68, 0.5);
}

.current-time-bar {
  flex: 1;
  height: 2rpx;
  background: #EF4444;
  box-shadow: 0 0 4rpx rgba(239, 68, 68, 0.5);
}

/* 添加日程按钮 */
.add-schedule-btn {
  position: absolute;
  right: 32rpx;
  bottom: 32rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #2563EB 0%, #4F46E5 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.4);
  z-index: 50;
}

.add-schedule-icon {
  font-size: 48rpx;
  color: #FFFFFF;
  font-weight: 300;
}

/* ========================================
   日程编辑弹窗样式
   ======================================== */

/* 弹窗遮罩 */
.schedule-popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 10000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.schedule-popup-mask.is-visible {
  opacity: 1;
  visibility: visible;
}

/* 弹窗容器 */
.schedule-popup-container {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #F8FAFC;
  border-radius: 32rpx 32rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
}

.schedule-popup-mask.is-visible .schedule-popup-container {
  transform: translateY(0);
}

/* 弹窗头部 */
.schedule-popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #E2E8F0;
  border-radius: 32rpx 32rpx 0 0;
  flex-shrink: 0;
}

.schedule-popup-cancel {
  font-size: 28rpx;
  color: #64748B;
  padding: 8rpx 16rpx;
}

.schedule-popup-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1E293B;
}

.schedule-popup-save {
  font-size: 28rpx;
  color: #2563EB;
  font-weight: 600;
  padding: 8rpx 16rpx;
}

/* 弹窗滚动区域 */
.schedule-popup-scroll {
  flex: 1;
  height: 0;
  overflow: hidden;
}

.schedule-popup-form {
  padding: 24rpx;
}

/* 表单卡片 */
.schedule-form-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 8rpx 24rpx;
  margin-bottom: 20rpx;
}

/* 表单字段 */
.schedule-field {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F1F5F9;
}

.schedule-field:last-child {
  border-bottom: none;
}

.schedule-field-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.schedule-field-clickable {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.schedule-field-label {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #1E293B;
  font-weight: 500;
}

.schedule-field-value {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #64748B;
}

/* 类型颜色点 */
.schedule-type-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

/* 输入框 */
.schedule-input {
  width: 100%;
  height: 80rpx;
  font-size: 28rpx;
  color: #1E293B;
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 0 20rpx;
  margin-top: 12rpx;
}

.schedule-textarea {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  color: #1E293B;
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  margin-top: 12rpx;
}

/* 时间选择行 */
.schedule-time-row {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
}

/* datetime-picker 包装器样式 */
.schedule-picker-wrapper {
  flex: 1;
  background: #F8FAFC;
  border-radius: 16rpx;
  overflow: hidden;
}

.schedule-picker-wrapper.schedule-picker-time {
  flex: 0 0 180rpx;
}

/* 选择器样式 */
.schedule-picker {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 0 20rpx;
  height: 80rpx;
}

.schedule-picker text:first-child {
  font-size: 28rpx;
  color: #1E293B;
}

.schedule-picker-time {
  flex: 0 0 180rpx;
}

.schedule-picker-arrow {
  font-size: 28rpx;
  color: #94A3B8;
}

/* 删除按钮 */
.schedule-delete-btn {
  text-align: center;
  padding: 32rpx;
  color: #EF4444;
  font-size: 28rpx;
  font-weight: 500;
}

/* ========================================
   类型选择弹窗样式
   ======================================== */

.type-popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 10001;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.type-popup-mask.is-visible {
  opacity: 1;
  visibility: visible;
}

.type-popup-container {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.type-popup-mask.is-visible .type-popup-container {
  transform: translateY(0);
}

.type-popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #F1F5F9;
}

.type-popup-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1E293B;
}

.type-popup-close {
  font-size: 48rpx;
  color: #94A3B8;
  line-height: 1;
}

/* 类型列表 */
.type-list {
  padding: 16rpx 0;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.type-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  transition: background 0.2s ease;
}

.type-item:active {
  background: #F8FAFC;
}

.type-item.is-active {
  background: #EFF6FF;
}

.type-item-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.type-item-name {
  flex: 1;
  font-size: 30rpx;
  color: #1E293B;
}

.type-item-check {
  font-size: 32rpx;
  color: #2563EB;
  font-weight: 600;
}
