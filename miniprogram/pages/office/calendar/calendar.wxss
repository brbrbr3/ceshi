/* 本馆日历页面样式 */

.calendar-page {
  min-height: 100vh;
  background: #EEF2FF;
}

.calendar-header-top{
  margin-bottom: -100rpx;
}

/* 头部标题 */
.calendar-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.calendar-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

/* 配置按钮 */
.calendar-config-btn {
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 600;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

/* 日历容器 */
.calendar-container {
  padding: 24rpx 0 0;
}

/* 配置弹窗遮罩 */
.config-popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 9999;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.config-popup-mask.is-visible {
  opacity: 1;
  visibility: visible;
}

/* 配置弹窗容器 */
.config-popup-container {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  height: 80vh;
  display: flex;
  flex-direction: column;
  margin: 0 20rpx 0;
}

.config-popup-mask.is-visible .config-popup-container {
  transform: translateY(0);
}

/* 固定头部区域（标题 + 年份选择） */
.config-popup-fixed-header {
  flex-shrink: 0;
}

/* 配置弹窗头部 */
.config-popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #F1F5F9;
}

/* 弹窗标题 */
.config-popup-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1E293B;
}

.config-popup-close {
  font-size: 48rpx;
  color: #94A3B8;
  line-height: 1;
  padding: 0 8rpx;
}

/* 年份选择 */
.config-field {
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx;
  border-bottom: 1rpx solid #F1F5F9;
}

/* 可滚动区域 */
.config-popup-scroll {
  flex: 1;
  height: 0;
  overflow: hidden;
}

/* 配置表单（scroll-view 内部） */
.config-popup-form {
  padding: 24rpx 32rpx;
}

.config-field-label {
  font-size: 28rpx;
  color: #1E293B;
  font-weight: 500;
}

.config-field-label-inline {
  font-size: 28rpx;
  color: #1E293B;
  font-weight: 500;
}

.config-year-picker {
  display: flex;
  align-items: center;
  background: #F8FAFC;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  margin: 0 16rpx;
}

.config-year-picker text:first-child {
  font-size: 28rpx;
  color: #2563EB;
  font-weight: 600;
}

.config-picker-arrow {
  font-size: 20rpx;
  color: #94A3B8;
  margin-left: 8rpx;
}

/* 节假日列表 */
.config-holidays-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.config-holiday-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.config-holiday-label {
  font-size: 26rpx;
  color: #64748B;
  width: 180rpx;
  flex-shrink: 0;
}

.config-date-picker {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 0 24rpx;
  height: 80rpx;
}

.config-date-picker text:first-child {
  font-size: 28rpx;
  color: #1E293B;
}

.config-delete-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FEE2E2;
  border-radius: 50%;
  font-size: 32rpx;
  color: #DC2626;
  flex-shrink: 0;
}

/* 添加按钮 */
.config-add-btn {
  height: 96rpx;
  font-size: 32rpx;
  text-align: center;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
  background: #EFF6FF;
  border: 2rpx dashed #2563EB;
  color: #2563EB;
}

.config-add-icon {
  font-size: 36rpx;
  font-weight: 600;
}

/* 弹窗底部（固定提交按钮） */
.config-popup-footer {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #F1F5F9;
  flex-shrink: 0;
  z-index: 100;
}

/* 提交按钮 */
.config-submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #2563EB 0%, #4F46E5 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
}

.config-submit-btn[disabled] {
  background: #94A3B8;
}
