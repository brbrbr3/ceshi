<view class="cp-page">
  <!-- 渐变色头部 - 青蓝色 -->
  <view class="office-gradient-header cp-header">
    <view class="cp-header-content">
      <view class="cp-title">购车管理</view>
      <view class="cp-subtitle">提交购车申请，追踪购车流程</view>
    </view>
  </view>

  <!-- Tab 切换栏 -->
  <view class="cp-tab-bar" wx:if="{{isOfficeStaff}}">
    <view class="cp-tab-item {{currentTab === 'mine' ? 'is-active' : ''}}" bindtap="handleTabSwitch" data-tab="mine">
      <text>我的购车</text>
    </view>
    <view class="cp-tab-item {{currentTab === 'manage' ? 'is-active' : ''}}" bindtap="handleTabSwitch" data-tab="manage">
      <text>购车管理</text>
    </view>
  </view>

  <!-- 内容区域 -->
  <view class="cp-content">
    <!-- 区域标题 + 添加按钮（仅我的购车tab显示） -->
    <view class="cp-section-header" wx:if="{{currentTab === 'mine'}}">
      <view class="cp-section-title">{{currentTab === 'manage' ? '全部购车记录' : '我的购车记录'}}</view>
      <view class="cp-add-btn" bindtap="showApplicationForm">
        <text class="cp-add-text">+ 添加购车申请</text>
      </view>
    </view>
    <view class="cp-section-header" wx:else>
      <view class="cp-section-title">全员购车记录</view>
    </view>

    <!-- 列表区域 -->
    <scroll-view scroll-y class="cp-list-scroll" enhanced show-scrollbar="{{false}}">
      <view class="cp-list">
        <view class="cp-card" wx:for="{{recordList}}" wx:key="_id" bindtap="showRecordDetail" data-record="{{item}}">
          <!-- 卡片头部：车型/品牌 + 类型标签 + 状态标签 -->
          <view class="cp-card-header">
            <view class="cp-car-model">{{item.type === 'purchase_loan' ? (item.carModel || '借款申请') : (item.type === 'purchase_application' ? (item.brand || '购车申请') : item.carModel)}}</view>
            <view class="cp-type-tag" wx:if="{{item.type === 'purchase_loan'}}" style="background:#ECFEFF; color:#0891B2;">购车借款申请</view>
            <view class="cp-type-tag" wx:elif="{{item.type === 'purchase_application'}}" style="background:#ECFEFF; color:#0891B2;">购车申请</view>
            <view class="cp-type-tag" wx:elif="{{item.type === 'purchase_process'}}" style="background:#ECFEFF; color:#0891B2;">购车流程</view>
            <view class="cp-status-tag" style="background:{{item.status === 'completed' || item.status === 'approved' ? '#D1FAE5' : (item.status === 'rejected' || item.status === 'terminated' ? '#FEE2E2' : (item.status === 'pending_approval' ? '#FEF3C7' : '#CFFAFE'))}}; color:{{item.statusColor}};">
              {{item.statusText}}
            </view>
          </view>

          <!-- 进度条（仅购车流程显示） -->
          <view class="cp-progress-bar-wrap" wx:if="{{item.type === 'purchase_process'}}">
            <view class="cp-progress-track">
              <view class="cp-progress-fill" style="width: {{item.progress}}%;"></view>
            </view>
            <view class="cp-progress-text">{{item.progress}}%</view>
          </view>

          <!-- 购车申请摘要 -->
          <view class="cp-app-summary" wx:if="{{item.type === 'purchase_application'}}">
            <text class="cp-app-meta-item" wx:if="{{item.position}}">职别：{{item.position}}</text>
            <text class="cp-app-meta-item" wx:if="{{item.isApplyLoan}}">申请借款</text>
          </view>

          <!-- 购车借款申请摘要 -->
          <view class="cp-app-summary" wx:if="{{item.type === 'purchase_loan'}}">
            <text class="cp-app-meta-item" wx:if="{{item.position}}">职别：{{item.position}}</text>
            <text class="cp-app-meta-item" wx:if="{{item.isFirstResident}}">首次常驻</text>
            <text class="cp-app-meta-item" wx:if="{{item.borrowableAmount}}">可借：{{item.borrowableAmount}} USD</text>
            <text class="cp-app-meta-item" wx:if="{{item.requestedAmount}}">拟借：{{item.requestedAmount}} USD</text>
          </view>

          <!-- 卡片信息 -->
          <view class="cp-card-meta">
            <text wx:if="{{currentTab === 'manage'}}" class="cp-applicant-name">{{item.applicantName || '-'}}</text>
            <text wx:if="{{currentTab === 'manage'}}" class="cp-dept-sep"> · </text>
            <text class="cp-update-time">{{item.updatedAtText}}</text>
          </view>
        </view>
      </view>

      <!-- 空状态 -->
      <view wx:if="{{!loading && recordList.length === 0}}" class="cp-empty">
        <view class="cp-empty-icon">🚗</view>
        <view class="cp-empty-text">暂无购车记录</view>
        <view class="cp-empty-hint" wx:if="{{currentTab === 'mine'}}">点击上方按钮添加购车申请</view>
        <view class="cp-empty-hint" wx:else>暂无购车记录</view>
      </view>

      <!-- 加载中 -->
      <view wx:if="{{loading && recordList.length === 0}}" class="cp-loading">
        <view class="cp-loading-spinner"></view>
        <view class="cp-loading-text">加载中...</view>
      </view>
    </scroll-view>
  </view>


  <!-- ========== 类型选择弹窗 ========== -->
  <view class="cp-popup-mask {{showTypeSelector ? 'is-visible' : ''}}" catchtouchmove="stopPropagation" bindtap="hideTypeSelector">
    <view class="cp-popup-container cp-type-popup" catchtap="stopPropagation">
      <view class="cp-popup-header">
        <view class="cp-popup-title">选择申请类型</view>
        <view class="cp-popup-close" bindtap="hideTypeSelector">×</view>
      </view>
      <view class="cp-type-list">
        <view class="cp-type-item" bindtap="handleTypeSelect" data-type="purchase_application">
          <view class="cp-type-icon-wrap" style="background:#ECFEFF;">
            <text class="cp-type-emoji">🚗</text>
          </view>
          <view class="cp-type-info">
            <view class="cp-type-name">馆内购车申请</view>
            <view class="cp-type-desc">提交购车申请，走审批流程</view>
          </view>
          <text class="cp-type-arrow">›</text>
        </view>
        <view class="cp-type-item" bindtap="handleTypeSelect" data-type="purchase_loan">
          <view class="cp-type-icon-wrap" style="background:#FEF3C7;">
            <text class="cp-type-emoji">💰</text>
          </view>
          <view class="cp-type-info">
            <view class="cp-type-name">馆内购车借款申请</view>
            <view class="cp-type-desc">购车借款申请，走审批流程</view>
          </view>
          <text class="cp-type-arrow">›</text>
        </view>
        <view class="cp-type-item" bindtap="handleTypeSelect" data-type="purchase_process">
          <view class="cp-type-icon-wrap" style="background:#E0F2FE;">
            <text class="cp-type-emoji">📋</text>
          </view>
          <view class="cp-type-info">
            <view class="cp-type-name">开始购车流程</view>
            <view class="cp-type-desc">6阶段购车流程跟踪</view>
          </view>
          <text class="cp-type-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ========== 底部弹出：馆内购车申请表单 ========== -->
  <view class="cp-popup-mask {{showPurchaseAppForm ? 'is-visible' : ''}}" catchtouchmove="stopPropagation" bindtap="hidePurchaseAppForm">
    <view class="cp-popup-container cp-purchase-app-popup" catchtap="stopPropagation">
      <view class="cp-popup-header">
        <view class="cp-popup-title">馆内购车申请</view>
        <view class="cp-popup-close" bindtap="hidePurchaseAppForm">×</view>
      </view>

      <scroll-view scroll-y class="cp-popup-form">
        <view class="cp-form-main">
          <!-- 基本信息 -->
          <view class="cp-form-section-title">基本信息</view>

          <!-- 到馆日期 -->
          <view class="cp-field">
            <view class="cp-field-label">到馆日期 <text class="cp-required">*</text></view>
            <datetime-picker value="{{purchaseAppForm.arrivalDate}}" fields="{{['year', 'month', 'day']}}" placeholder="请选择到馆日期" type="border" bindchange="handleArrivalDateChange" />
          </view>

          <!-- 本次任期月数 -->
          <view class="cp-field">
            <view class="cp-field-label">本次任期月数</view>
            <view class="cp-stepper">
              <view class="cp-stepper-btn" bindtap="handleTermMonthsMinus">−</view>
              <view class="cp-stepper-value">{{purchaseAppForm.termMonths}}</view>
              <view class="cp-stepper-btn" bindtap="handleTermMonthsPlus">+</view>
            </view>
          </view>

          <!-- 职别 -->
          <view class="cp-field">
            <view class="cp-field-label">职别 <text class="cp-required">*</text></view>
            <picker range="{{positionOptions}}" value="{{purchaseAppForm.positionIndex}}" bindchange="handlePositionChange">
              <view class="cp-input-wrapper cp-picker-trigger">
                <text class="{{purchaseAppForm.position ? 'cp-input' : 'cp-placeholder'}}">{{purchaseAppForm.position || '请选择职别'}}</text>
                <text class="cp-picker-arrow">▼</text>
              </view>
            </picker>
          </view>

          <!-- 对应购车标准（美元）— 自动填入 -->
          <view class="cp-field" wx:if="{{purchaseAppForm.carStandard > 0}}">
            <view class="cp-field-label">对应购车标准（美元）</view>
            <view class="cp-input-wrapper cp-input-readonly">
              <text class="cp-input cp-input-disabled">{{purchaseAppForm.carStandard}}</text>
            </view>
          </view>

          <!-- 对应购车最低限额标准（美元）— 自动填入 -->
          <view class="cp-field" wx:if="{{purchaseAppForm.carMinStandard > 0}}">
            <view class="cp-field-label">对应购车最低限额标准（美元）</view>
            <view class="cp-input-wrapper cp-input-readonly">
              <text class="cp-input cp-input-disabled">{{purchaseAppForm.carMinStandard}}</text>
            </view>
          </view>

          <!-- 拟购车辆简况 -->
          <view class="cp-form-section-title">拟购车辆简况</view>

          <!-- 拟购车日期 -->
          <view class="cp-field">
            <view class="cp-field-label">拟购车日期 <text class="cp-required">*</text></view>
            <datetime-picker value="{{purchaseAppForm.plannedPurchaseDate}}" fields="{{['year', 'month', 'day']}}" placeholder="请选择拟购车日期" type="border" bindchange="handlePlannedPurchaseDateChange" />
          </view>

          <!-- 售车公司 -->
          <view class="cp-field">
            <view class="cp-field-label">售车公司</view>
            <view class="cp-input-wrapper">
              <input class="cp-input" value="{{purchaseAppForm.saleCompany}}" placeholder="请输入售车公司" placeholder-class="cp-placeholder" bindinput="handleSaleCompanyInput" />
            </view>
          </view>

          <!-- 品牌 -->
          <view class="cp-field">
            <view class="cp-field-label">品牌 <text class="cp-required">*</text></view>
            <view class="cp-input-wrapper">
              <input class="cp-input" value="{{purchaseAppForm.brand}}" placeholder="请输入品牌" placeholder-class="cp-placeholder" bindinput="handleBrandInput" />
            </view>
          </view>

          <!-- 规格型号 -->
          <view class="cp-field">
            <view class="cp-field-label">规格型号</view>
            <view class="cp-input-wrapper">
              <input class="cp-input" value="{{purchaseAppForm.specModel}}" placeholder="请输入规格型号" placeholder-class="cp-placeholder" bindinput="handleSpecModelInput" />
            </view>
          </view>

          <!-- 排气量 -->
          <view class="cp-field">
            <view class="cp-field-label">排气量</view>
            <view class="cp-input-wrapper">
              <input class="cp-input" value="{{purchaseAppForm.displacement}}" placeholder="请输入排气量" placeholder-class="cp-placeholder" bindinput="handleDisplacementInput" />
            </view>
          </view>

          <!-- 是否新车 -->
          <view class="cp-field">
            <view class="cp-field-label">是否新车</view>
            <view class="cp-switch-row">
              <switch checked="{{purchaseAppForm.isNewCar}}" bindchange="handleIsNewCarChange" color="#0891B2" />
              <text class="cp-switch-label">{{purchaseAppForm.isNewCar ? '新车' : '二手车'}}</text>
            </view>
          </view>

          <!-- 已行驶时间（二手车显示） -->
          <view class="cp-field" wx:if="{{!purchaseAppForm.isNewCar}}">
            <view class="cp-field-label">已行驶时间 <text class="cp-required">*</text></view>
            <view class="cp-input-wrapper">
              <input class="cp-input" value="{{purchaseAppForm.usedTime}}" placeholder="请输入已行驶时间" placeholder-class="cp-placeholder" bindinput="handleUsedTimeInput" />
            </view>
          </view>

          <!-- 已行驶里程（二手车显示） -->
          <view class="cp-field" wx:if="{{!purchaseAppForm.isNewCar}}">
            <view class="cp-field-label">已行驶里程 <text class="cp-required">*</text></view>
            <view class="cp-input-wrapper">
              <input class="cp-input" value="{{purchaseAppForm.usedMileage}}" placeholder="请输入已行驶里程" placeholder-class="cp-placeholder" bindinput="handleUsedMileageInput" />
            </view>
          </view>

          <!-- 售价（含运费） -->
          <view class="cp-field">
            <view class="cp-field-label">售价（含运费）</view>
            <view class="cp-input-wrapper">
              <input class="cp-input" value="{{purchaseAppForm.priceWithShipping}}" placeholder="雷亚尔" placeholder-class="cp-placeholder" bindinput="handlePriceWithShippingInput" type="digit" />
            </view>
          </view>

          <!-- 折美元 -->
          <view class="cp-field">
            <view class="cp-field-label">折美元</view>
            <view class="cp-input-wrapper">
              <input class="cp-input" value="{{purchaseAppForm.priceInUSD}}" placeholder="请输入折合美元金额" placeholder-class="cp-placeholder" bindinput="handlePriceInUSDInput" type="digit" />
            </view>
          </view>

          <!-- 是否申请购车借款 -->
          <view class="cp-field">
            <view class="cp-field-label">是否申请购车借款</view>
            <view class="cp-switch-row">
              <switch checked="{{purchaseAppForm.isApplyLoan}}" bindchange="handleIsApplyLoanChange" color="#0891B2" />
              <text class="cp-switch-label">{{purchaseAppForm.isApplyLoan ? '是' : '否'}}</text>
            </view>
          </view>

            <!-- 审批流程说明 -->
        <view class="car-purchase-note">
          <view class="car-purchase-note-title">📋 审批流程</view>
          <view class="car-purchase-note-steps">
          <view class="car-purchase-note-step">
              <view class="car-purchase-step-dot"></view>
              <view class="car-purchase-step-text">部门负责人审批</view>
            </view>
            <view class="car-purchase-note-arrow">→</view>
            <view class="car-purchase-note-step">
              <view class="car-purchase-step-dot"></view>
              <view class="car-purchase-step-text">办公室审批</view>
            </view>
            <view class="car-purchase-note-arrow">→</view>
            <view class="car-purchase-note-step">
              <view class="car-purchase-step-dot"></view>
              <view class="car-purchase-step-text">馆领导审批</view>
            </view>
          </view>
        </view>
        </view>
      </scroll-view>

      <view class="cp-popup-actions">
        <button class="cp-submit-btn" loading="{{submitting}}" disabled="{{submitting}}" bindtap="submitPurchaseApplication">
          提交申请
        </button>
      </view>
    </view>
  </view>

  <!-- ========== 底部弹出：馆内购车借款申请表单 ========== -->
  <view class="cp-popup-mask {{showPurchaseLoanForm ? 'is-visible' : ''}}" catchtouchmove="stopPropagation" bindtap="hidePurchaseLoanForm">
    <view class="cp-popup-container cp-purchase-app-popup" catchtap="stopPropagation">
      <view class="cp-popup-header">
        <view class="cp-popup-title">馆内购车借款申请</view>
        <view class="cp-popup-close" bindtap="hidePurchaseLoanForm">×</view>
      </view>

      <scroll-view scroll-y class="cp-popup-form">
        <view class="cp-form-main">
          <!-- 基本信息 -->
          <view class="cp-form-section-title">基本信息</view>

          <!-- 赴任日期 -->
          <view class="cp-field">
            <view class="cp-field-label">赴任日期 <text class="cp-required">*</text></view>
            <datetime-picker value="{{purchaseLoanForm.arrivalDate}}" fields="{{['year', 'month', 'day']}}" placeholder="请选择赴任日期" type="border" bindchange="handleLoanArrivalDateChange" />
          </view>

          <!-- 职别 -->
          <view class="cp-field">
            <view class="cp-field-label">职别 <text class="cp-required">*</text></view>
            <picker range="{{positionOptions}}" value="{{purchaseLoanForm.positionIndex}}" bindchange="handleLoanPositionChange">
              <view class="cp-input-wrapper cp-picker-trigger">
                <text class="{{purchaseLoanForm.position ? 'cp-input' : 'cp-placeholder'}}">{{purchaseLoanForm.position || '请选择职别'}}</text>
                <text class="cp-picker-arrow">▼</text>
              </view>
            </picker>
          </view>

          <!-- 月购车补贴标准（人民币）— 自动填入 -->
          <view class="cp-field" wx:if="{{purchaseLoanForm.carSubsidy > 0}}">
            <view class="cp-field-label">月购车补贴标准（人民币）</view>
            <view class="cp-input-wrapper cp-input-readonly">
              <text class="cp-input cp-input-disabled">{{purchaseLoanForm.carSubsidy}}</text>
            </view>
          </view>

          <!-- 剩余任期月数 -->
          <view class="cp-field">
            <view class="cp-field-label">剩余任期月数</view>
            <view class="cp-stepper">
              <view class="cp-stepper-btn" bindtap="handleLoanTermMonthsMinus">−</view>
              <view class="cp-stepper-value">{{purchaseLoanForm.termMonths}}</view>
              <view class="cp-stepper-btn" bindtap="handleLoanTermMonthsPlus">+</view>
            </view>
          </view>

          <!-- 剩余任期内可享购车补贴金额 — 自动计算 -->
          <view class="cp-field" wx:if="{{purchaseLoanForm.totalSubsidy > 0}}">
            <view class="cp-field-label">剩余任期内可享购车补贴金额（人民币）</view>
            <view class="cp-input-wrapper cp-input-readonly">
              <text class="cp-input cp-input-disabled">{{purchaseLoanForm.totalSubsidy}}</text>
            </view>
          </view>

          <!-- 购车信息 -->
          <view class="cp-form-section-title">购车信息</view>

          <!-- 拟购车型号 -->
          <view class="cp-field">
            <view class="cp-field-label">拟购车型号 <text class="cp-required">*</text></view>
            <view class="cp-input-wrapper">
              <input class="cp-input" value="{{purchaseLoanForm.carModel}}" placeholder="请输入拟购车型号" placeholder-class="cp-placeholder" bindinput="handleLoanCarModelInput" />
            </view>
          </view>

          <!-- 拟购车价格（美元） -->
          <view class="cp-field">
            <view class="cp-field-label">拟购车价格（美元） <text class="cp-required">*</text></view>
            <view class="cp-input-wrapper">
              <input class="cp-input" value="{{purchaseLoanForm.priceInUSD}}" placeholder="请输入拟购车价格" placeholder-class="cp-placeholder" bindinput="handleLoanPriceInUSDInput" type="digit" />
            </view>
          </view>

          <!-- 当月美元人民币比价 -->
          <view class="cp-field">
            <view class="cp-field-label">当月美元人民币比价 <text class="cp-required">*</text></view>
            <view class="cp-input-wrapper">
              <input class="cp-input" value="{{purchaseLoanForm.exchangeRate}}" placeholder="请输入美元人民币比价" placeholder-class="cp-placeholder" bindinput="handleLoanExchangeRateInput" type="digit" />
            </view>
          </view>

          <!-- 是否车改后首次常驻 -->
          <view class="cp-field">
            <view class="cp-field-label">是否车改后首次常驻</view>
            <view class="cp-switch-row">
              <switch checked="{{purchaseLoanForm.isFirstResident}}" bindchange="handleLoanIsFirstResidentChange" color="#0891B2" />
              <text class="cp-switch-label">{{purchaseLoanForm.isFirstResident ? '是' : '否'}}</text>
            </view>
          </view>

          <!-- 可借金额（美元）— 自动计算 -->
          <view class="cp-field" wx:if="{{purchaseLoanForm.borrowableAmount > 0}}">
            <view class="cp-field-label">可借金额（美元）</view>
            <view class="cp-input-wrapper cp-input-readonly" style="background:#ECFEFF;">
              <text class="cp-input cp-input-disabled" style="color:#0891B2;font-weight:700;">{{purchaseLoanForm.borrowableAmount}}</text>
            </view>
          </view>

          <!-- 拟借金额（美元）— 用户填写 -->
          <view class="cp-field" wx:if="{{purchaseLoanForm.borrowableAmount > 0}}">
            <view class="cp-field-label">拟借金额（美元） <text class="cp-required">*</text></view>
            <view class="cp-input-wrapper">
              <input class="cp-input" value="{{purchaseLoanForm.requestedAmount}}" placeholder="不超过可借金额" placeholder-class="cp-placeholder" bindinput="handleLoanRequestedAmountInput" type="digit" />
            </view>
          </view>

          <!-- 审批流程说明 -->
        <view class="car-purchase-note">
          <view class="car-purchase-note-title">📋 审批流程</view>
          <view class="car-purchase-note-steps">
            <view class="car-purchase-note-step">
              <view class="car-purchase-step-dot"></view>
              <view class="car-purchase-step-text">财务主管审批</view>
            </view>
            <view class="car-purchase-note-arrow">→</view>
            <view class="car-purchase-note-step">
              <view class="car-purchase-step-dot"></view>
              <view class="car-purchase-step-text">馆领导审批</view>
            </view>
          </view>
        </view>
        </view>
      </scroll-view>

      <view class="cp-popup-actions">
        <button class="cp-submit-btn" loading="{{submitting}}" disabled="{{submitting}}" bindtap="submitPurchaseLoan">
          提交申请
        </button>
      </view>
    </view>
  </view>

  <!-- ========== 底部弹出：申请表单（购车流程） ========== -->
  <view class="cp-popup-mask {{showFormPopup ? 'is-visible' : ''}}" catchtouchmove="stopPropagation" bindtap="hideFormPopup">
    <view class="cp-popup-container cp-form-popup" catchtap="stopPropagation">
      <view class="cp-popup-header">
        <view class="cp-popup-title">开始购车流程</view>
        <view class="cp-popup-close" bindtap="hideFormPopup">×</view>
      </view>

      <scroll-view scroll-y class="cp-popup-form">
        <view class="cp-form-main">
          <!-- 车型输入 -->
          <view class="cp-field">
            <view class="cp-field-label">车型 <text class="cp-required">*</text></view>
            <view class="cp-input-wrapper">
              <input class="cp-input" value="{{form.carModel}}" placeholder="请输入您选择的车型" placeholder-class="cp-placeholder" bindinput="handleCarModelInput" />
            </view>
          </view>

          <!-- 流程预览 -->
          <view class="cp-flow-preview">
            <view class="cp-flow-title">📋 购车流程预览（共6个阶段）</view>
            <view class="cp-flow-steps">
              <view class="cp-flow-step" wx:for="{{[1,2,3,4,5,6]}}" wx:key="*this">
                <view class="cp-flow-dot cp-dot-staff" wx:if="{{item % 2 !== 0}}"></view>
                <view class="cp-flow-dot cp-dot-office" wx:else></view>
                <text class="cp-flow-label">G{{item}}</text>
              </view>
            </view>
            <view class="cp-flow-legend">
              <view class="cp-legend-item">
                <view class="cp-legend-dot cp-dot-staff"></view><text>用户操作</text>
              </view>
              <view class="cp-legend-item">
                <view class="cp-legend-dot cp-dot-office"></view><text>办公室操作</text>
              </view>
            </view>
          </view>
        </view>
      </scroll-view>

      <view class="cp-popup-actions">
        <button class="cp-submit-btn" loading="{{submitting}}" disabled="{{submitting}}" bindtap="submitApplication">
          提交申请
        </button>
      </view>
    </view>
  </view>

  <!-- ========== 底部弹出：详情 ========== -->
  <view class="cp-popup-mask {{showDetailPopup ? 'is-visible' : ''}}" catchtouchmove="stopPropagation" bindtap="hideDetailPopup">
    <view class="cp-popup-container cp-detail-popup" catchtap="stopPropagation">
      <view class="cp-popup-header">
        <view class="cp-popup-header-left">
          <view class="cp-popup-title">{{detailData && (detailData.type === 'purchase_application' || detailData.type === 'purchase_loan') ? (detailData.type === 'purchase_loan' ? '购车借款申请详情' : '购车申请详情') : '购车流程详情'}}</view>
          <view class="cp-detail-badge" wx:if="{{detailData && (detailData.status === 'completed' || detailData.status === 'approved')}}">已完成</view>
          <view class="cp-detail-badge cp-badge-active" wx:elif="{{detailData && detailData.type === 'purchase_process'}}">G{{detailData.currentGroup}}进行中</view>
          <view class="cp-detail-badge" wx:elif="{{detailData && detailData.status === 'pending_approval'}}" style="background:#FEF3C7;color:#92400E;">待审批</view>
          <view class="cp-detail-badge" wx:elif="{{detailData && detailData.status === 'rejected'}}" style="background:#FEE2E2;color:#991B1B;">已驳回</view>
          <view class="cp-detail-badge" wx:elif="{{detailData && detailData.status === 'terminated'}}" style="background:#FEE2E2;color:#991B1B;">已中止</view>
        </view>
        <view class="cp-popup-close" bindtap="hideDetailPopup">×</view>
      </view>

      <scroll-view scroll-y class="cp-detail-content" wx:if="{{detailData}}">
        <!-- 馆内购车借款申请详情 -->
        <block wx:if="{{detailData.type === 'purchase_loan'}}">
          <view class="cp-info-section">
            <view class="cp-info-row">
              <text class="cp-info-label">姓名：</text>
              <text class="cp-info-value">{{detailData.applicantName || '-'}}</text>
            </view>
            <view class="cp-info-row">
              <text class="cp-info-label">部门：</text>
              <text class="cp-info-value">{{detailData.applicantDepartment || '-'}}</text>
            </view>
            <view class="cp-info-row">
              <text class="cp-info-label">赴任日期：</text>
              <text class="cp-info-value">{{detailData.arrivalDate || '-'}}</text>
            </view>
            <view class="cp-info-row">
              <text class="cp-info-label">职别：</text>
              <text class="cp-info-value cp-value-bold">{{detailData.position || '-'}}</text>
            </view>
            <view class="cp-info-row">
              <text class="cp-info-label">月购车补贴：</text>
              <text class="cp-info-value">{{detailData.carSubsidy ? detailData.carSubsidy + ' 人民币' : '-'}}</text>
            </view>
            <view class="cp-info-row">
              <text class="cp-info-label">剩余任期月数：</text>
              <text class="cp-info-value">{{detailData.termMonths || '-'}}</text>
            </view>
            <view class="cp-info-row">
              <text class="cp-info-label">可享补贴金额：</text>
              <text class="cp-info-value">{{detailData.totalSubsidy ? detailData.totalSubsidy + ' 人民币' : '-'}}</text>
            </view>
          </view>
          <view class="cp-info-section">
            <view class="cp-section-subtitle">购车借款信息</view>
            <view class="cp-info-row">
              <text class="cp-info-label">拟购车型号：</text>
              <text class="cp-info-value cp-value-bold">{{detailData.carModel || '-'}}</text>
            </view>
            <view class="cp-info-row">
              <text class="cp-info-label">拟购车价格：</text>
              <text class="cp-info-value">{{detailData.priceInUSD ? detailData.priceInUSD + ' 美元' : '-'}}</text>
            </view>
            <view class="cp-info-row">
              <text class="cp-info-label">美元人民币比价：</text>
              <text class="cp-info-value">{{detailData.exchangeRate || '-'}}</text>
            </view>
            <view class="cp-info-row">
              <text class="cp-info-label">车改后首次常驻：</text>
              <text class="cp-info-value">{{detailData.isFirstResident ? '是' : '否'}}</text>
            </view>
            <view class="cp-info-row">
              <text class="cp-info-label">可借金额：</text>
              <text class="cp-info-value cp-value-bold" style="color:#0891B2;">{{detailData.borrowableAmount ? detailData.borrowableAmount + ' 美元' : '-'}}</text>
            </view>
            <view class="cp-info-row">
              <text class="cp-info-label">拟借金额：</text>
              <text class="cp-info-value cp-value-bold" style="color:#D97706;">{{detailData.requestedAmount ? detailData.requestedAmount + ' 美元' : '-'}}</text>
            </view>
          </view>
        </block>

        <!-- 馆内购车申请详情 -->
        <block wx:elif="{{detailData.type === 'purchase_application'}}">
          <view class="cp-info-section">
            <view class="cp-info-row">
              <text class="cp-info-label">姓名：</text>
              <text class="cp-info-value">{{detailData.applicantName || '-'}}</text>
            </view>
            <view class="cp-info-row">
              <text class="cp-info-label">部门：</text>
              <text class="cp-info-value">{{detailData.applicantDepartment || '-'}}</text>
            </view>
            <view class="cp-info-row">
              <text class="cp-info-label">到馆日期：</text>
              <text class="cp-info-value">{{detailData.arrivalDate || '-'}}</text>
            </view>
            <view class="cp-info-row">
              <text class="cp-info-label">任期月数：</text>
              <text class="cp-info-value">{{detailData.termMonths || '-'}}</text>
            </view>
            <view class="cp-info-row">
              <text class="cp-info-label">职别：</text>
              <text class="cp-info-value cp-value-bold">{{detailData.position || '-'}}</text>
            </view>
            <view class="cp-info-row">
              <text class="cp-info-label">购车标准：</text>
              <text class="cp-info-value">{{detailData.carStandard ? detailData.carStandard + ' 美元' : '-'}}</text>
            </view>
            <view class="cp-info-row">
              <text class="cp-info-label">最低限额：</text>
              <text class="cp-info-value">{{detailData.carMinStandard ? detailData.carMinStandard + ' 美元' : '-'}}</text>
            </view>
          </view>
          <view class="cp-info-section">
            <view class="cp-section-subtitle">拟购车辆简况</view>
            <view class="cp-info-row">
              <text class="cp-info-label">拟购车日期：</text>
              <text class="cp-info-value">{{detailData.plannedPurchaseDate || '-'}}</text>
            </view>
            <view class="cp-info-row">
              <text class="cp-info-label">售车公司：</text>
              <text class="cp-info-value">{{detailData.saleCompany || '-'}}</text>
            </view>
            <view class="cp-info-row">
              <text class="cp-info-label">品牌：</text>
              <text class="cp-info-value cp-value-bold">{{detailData.brand || '-'}}</text>
            </view>
            <view class="cp-info-row">
              <text class="cp-info-label">规格型号：</text>
              <text class="cp-info-value">{{detailData.specModel || '-'}}</text>
            </view>
            <view class="cp-info-row">
              <text class="cp-info-label">排气量：</text>
              <text class="cp-info-value">{{detailData.displacement || '-'}}</text>
            </view>
            <view class="cp-info-row">
              <text class="cp-info-label">是否新车：</text>
              <text class="cp-info-value">{{detailData.isNewCar ? '是' : '否'}}</text>
            </view>
            <view class="cp-info-row" wx:if="{{!detailData.isNewCar}}">
              <text class="cp-info-label">已行驶时间：</text>
              <text class="cp-info-value">{{detailData.usedTime || '-'}}</text>
            </view>
            <view class="cp-info-row" wx:if="{{!detailData.isNewCar}}">
              <text class="cp-info-label">已行驶里程：</text>
              <text class="cp-info-value">{{detailData.usedMileage || '-'}}</text>
            </view>
            <view class="cp-info-row">
              <text class="cp-info-label">售价（含运费）：</text>
              <text class="cp-info-value">{{detailData.priceWithShipping ? detailData.priceWithShipping + ' 雷亚尔' : '-'}}</text>
            </view>
            <view class="cp-info-row">
              <text class="cp-info-label">折美元：</text>
              <text class="cp-info-value">{{detailData.priceInUSD ? detailData.priceInUSD + ' USD' : '-'}}</text>
            </view>
            <view class="cp-info-row">
              <text class="cp-info-label">申请借款：</text>
              <text class="cp-info-value">{{detailData.isApplyLoan ? '是' : '否'}}</text>
            </view>
          </view>
        </block>

        <!-- 购车流程详情（原有逻辑） -->
        <block wx:else>
          <!-- 基础信息 -->
          <view class="cp-info-section">
            <view class="cp-info-row">
              <text class="cp-info-label">申请人：</text>
              <text class="cp-info-value">{{detailData.applicantName || '-'}}</text>
            </view>
            <view class="cp-info-row">
              <text class="cp-info-label">部门：</text>
              <text class="cp-info-value">{{detailData.applicantDepartment || '-'}}</text>
            </view>
            <view class="cp-info-row">
              <text class="cp-info-label">车型：</text>
              <text class="cp-info-value cp-value-bold">{{detailData.carModel || '-'}}</text>
            </view>
            <view class="cp-info-row">
              <text class="cp-info-label">整体进度：</text>
              <view class="cp-mini-progress">
                <view class="cp-mini-track">
                  <view class="cp-mini-fill" style="width:{{detailData.progress}}%"></view>
                </view>
                <text class="cp-mini-text">{{detailData.progress}}%</text>
              </view>
            </view>
            <view class="cp-info-row">
              <text class="cp-info-label">创建时间：</text>
              <text class="cp-info-value">{{detailData.createdAtText || '-'}}</text>
            </view>
          </view>

          <!-- Checklist 纵向时间线 -->
          <view class="cp-timeline-section">
            <view class="cp-timeline-title">📝 流程进度</view>

            <view class="cp-timeline" wx:for="{{detailData.groups}}" wx:key="groupId">
              <!-- 分组标题栏 -->
              <view class="cp-group-header {{detailData.currentGroup > item.groupId ? 'group-done' : (detailData.currentGroup === item.groupId ? 'group-active' : '')}}">
                <view class="cp-group-icon">
                  <text wx:if="{{item.groupOwner === 'staff'}}">👤</text>
                  <text wx:else>🏢</text>
                </view>
                <view class="cp-group-info">
                  <view class="cp-group-name">G{{item.groupId}} · {{item.groupName}}</view>
                  <view class="cp-group-owner">{{item.groupOwner === 'staff' ? '用户操作' : '办公室操作'}}</view>
                </view>
                <view class="cp-group-count" wx:if="{{detailData.groupSummaries[index]}}">
                  {{detailData.groupSummaries[index].doneSteps}}/{{detailData.groupSummaries[index].totalSteps}}
                </view>
              </view>

              <!-- 步骤列表 -->
              <view class="cp-timeline-body">
                <view class="cp-step-item" wx:for="{{item.steps}}" wx:for-item="step" wx:for-index="si" wx:key="stepKey">
                  <!-- 左侧节点和连线 -->
                  <view class="cp-step-left">
                    <view class="cp-node-line" wx:if="{{si > -1}}"></view>
                    <view class="cp-step-node {{step.status === 'done' ? 'node-done' : (detailData.currentGroup > groupId ? 'node-done' : (detailData.currentGroup === groupId ? 'node-active' : 'node-pending'))}}">
                      <text wx:if="{{step.status === 'done'}}">✓</text>
                      <text wx:elif="{{detailData.currentGroup > groupId}}">✓</text>
                      <text wx:else>{{detailData.currentGroup === groupId ? '…' : ''}}</text>
                    </view>
                  </view>

                  <!-- 右侧步骤内容卡片 -->
                  <view class="cp-step-card {{step.status === 'done' ? 'card-done' : ''}}" bindtap="handleStepAction" data-groupindex="{{index}}" data-stepindex="{{si}}">
                    <view class="cp-step-top">
                      <view class="cp-step-title">{{step.title}}</view>
                      <view class="cp-step-status" wx:if="{{step.status === 'done'}}">已完成</view>
                      <view class="cp-step-action-hint" wx:elif="{{step.inputType === 'checkbox'}}">点击打钩</view>
                      <view class="cp-step-action-hint" wx:else>点击填写</view>
                    </view>

                    <!-- 已填内容的预览 -->
                    <!-- 文本值预览 -->
                    <view class="cp-step-preview" wx:if="{{step.value}}">
                      <text class="cp-preview-text">{{step.value}}</text>
                    </view>

                    <!-- 备注预览 -->
                    <view class="cp-step-preview" wx:if="{{step.remark}}">
                      <text class="cp-preview-remark">{{step.remark}}</text>
                    </view>

                    <!-- 附件数badge -->
                    <view class="cp-step-preview" wx:if="{{step.attachments.length > 0}}">
                      <view class="cp-attachment-badge">
                        <text>📎 {{step.attachments.length}} 个文件</text>
                      </view>
                    </view>

                    <!-- 操作人+时间 -->
                    <view class="cp-step-footer" wx:if="{{step.completedAt}}">
                      <text class="cp-operator">{{step.operatorName || ''}}</text>
                      <text class="cp-completed-time">{{step.completedAtText}}</text>
                    </view>
                  </view>
                </view>
              </view>

              <!-- 组间分隔箭头 -->
              <view class="cp-group-arrow" wx:if="{{index < detailData.groups.length - 1}}">
                <text class="cp-arrow-line">↓</text>
                <text class="cp-arrow-text">等待 {{detailData.groups[index + 1].groupName}}</text>
              </view>
            </view>
          </view>
        </block>
      </scroll-view>

      <view class="cp-popup-actions">
        <view class="cp-detail-btn-row">
          <!--已完成的申请或已审批通过的不再显示删除按钮-->
          <button wx:if="{{(detailData.status === 'rejected' || detailData.status === 'terminated') && currentTab === 'mine'}}" class="cp-delete-btn" catchtap="deleteRecord" data-record-id="{{selectedRecord._id}}">删除</button>
          <button wx:if="{{detailData.status === 'pending_approval' && currentTab === 'mine'}}" class="cp-delete-btn" catchtap="terminateRecord" data-record-id="{{selectedRecord._id}}">中止</button>
          <button wx:if="{{detailData.status === 'approved' && (detailData.type === 'purchase_application' || detailData.type === 'purchase_loan')}}" class="cp-export-btn" loading="{{exporting}}" disabled="{{exporting}}" bindtap="handleExportPdf">{{exporting ? '导出中...' : '导出PDF'}}</button>
          <button class="cp-close-btn" bindtap="hideDetailPopup">关闭</button>
        </view>
      </view>
    </view>
  </view>

  <!-- ========== 步骤编辑弹层 ========== -->
  <view class="cp-popup-mask {{showStepEditPopup ? 'is-visible' : ''}}" catchtouchmove="stopPropagation" bindtap="hideStepEditPopup">
    <view class="cp-popup-container cp-step-edit-popup" catchtap="stopPropagation">
      <view class="cp-popup-header">
        <view class="cp-popup-title">{{editingStep ? editingStep.title : '编辑步骤'}}</view>
        <view class="cp-popup-close" bindtap="hideStepEditPopup">×</view>
      </view>

      <scroll-view scroll-y class="cp-step-edit-content" wx:if="{{editingStep}}">
        <!-- 提示文字 -->
        <view class="cp-step-hint" wx:if="{{editingStep.hint}}">
          <text>{{editingStep.hint}}</text>
        </view>

        <!-- 文本输入 -->
        <block wx:if="{{editingStep.inputType === 'text' || editingStep.inputType === 'date'}}">
          <view class="cp-field">
            <view class="cp-field-label">
              {{editingStep.inputType === 'text' ? '请输入' : '请选择'}}
              <text class="cp-required">*</text>
            </view>
            <view wx:if="{{editingStep.inputType === 'text'}}" class="cp-input-wrapper">
              <input class="cp-input" value="{{stepFormValue}}" placeholder="请输入内容" placeholder-class="cp-placeholder" bindinput="handleStepValueInput" />
            </view>
            <datetime-picker wx:elif="{{editingStep.inputType === 'date'}}" value="{{stepFormValue}}" fields="{{['year', 'month', 'day']}}" placeholder="请选择日期" type="border" bindchange="handleDateChange" />
          </view>
        </block>

        <!-- 备注输入（多行） -->
        <block wx:if="{{editingStep.inputType === 'remark'}}">
          <view class="cp-field">
            <view class="cp-field-label">备注</view>
            <view class="cp-textarea-wrapper">
              <textarea class="cp-textarea" value="{{stepFormRemark}}" placeholder="请填写备注信息" placeholder-class="cp-placeholder" bindinput="handleStepRemarkInput" maxlength="500" auto-height />
            </view>
          </view>
        </block>

        <!-- 文件上传 -->
        <block wx:if="{{editingStep.inputType === 'upload' || editingStep.inputType === 'template'}}">
          <view class="cp-field">
            <view class="cp-field-label">上传文件（最多{{editingStep.maxFiles || 9}}张）</view>

            <!-- 已上传/已选文件网格 -->
            <view class="cp-upload-grid" wx:if="{{uploadedTempFiles.length > 0}}">
              <view class="cp-upload-item" wx:for="{{uploadedTempFiles}}" wx:key="*this" wx:for-item="file" wx:for-index="fi">
                <image wx:if="{{!file.tempFilePath}}" class="cp-upload-thumb" src="{{file.fileID}}" mode="aspectFill" data-index="{{fi}}" bindtap="previewImage"></image>
                <image wx:else class="cp-upload-thumb" src="{{file.tempFilePath}}" mode="aspectFill"></image>
                <view class="cp-upload-delete" catchtap="removeTempFile" data-index="{{fi}}">×</view>
              </view>

              <!-- 添加按钮（未满时显示） -->
              <view class="cp-upload-add" wx:if="{{uploadedTempFiles.length < (editingStep.maxFiles || 9)}}" bindtap="chooseImage">
                <text class="cp-upload-plus">+</text>
              </view>
            </view>

            <!-- 还没选择文件时显示大按钮 -->
            <view class="cp-upload-trigger" wx:else bindtap="chooseImage">
              <text class="cp-upload-icon">📷</text>
              <text class="cp-upload-tip">点击选择图片或拍照</text>
            </view>
          </view>

          <!-- upload类型同时允许填备注 -->
          <view class="cp-field" wx:if="{{editingStep.inputType === 'upload'}}">
            <view class="cp-field-label">备注（可选）</view>
            <view class="cp-textarea-wrapper">
              <textarea class="cp-textarea" value="{{stepFormRemark}}" placeholder="可补充说明" placeholder-class="cp-placeholder" bindinput="handleStepRemarkInput" maxlength="200" auto-height />
            </view>
          </view>
        </block>

      </scroll-view>

      <view class="cp-popup-actions">
        <button class="cp-submit-btn" loading="{{uploading}}" disabled="{{uploading}}" bindtap="saveStepEdit">
          保存
        </button>
      </view>
    </view>
  </view>
</view>