  align-items: center;
  justify-content: center;
  padding: 16rpx;
  background: #ECFDF5;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.sd-booked-status text {
  font-size: var(--fs-26);
  color: #059669;
  font-weight: 600;
}

/* 预订操作区 */
.sd-book-area {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
}

.sd-book-label {
  font-size: var(--fs-28);
  color: #334155;
  font-weight: 500;
}

/* 取消预订按钮 */
.sd-cancel-wrap {
  padding-top: 16rpx;
  border-top: 1rpx solid #F1F5F9;
}

.btn-cancel-booking {
  flex: 1;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--fs-28);
  font-weight: 600;
  box-sizing: border-box;
  color: #DC2626;
  background: #FEF2F2;
  border: none;
}

.btn-cancel-booking::after { border: none; }

.btn-cancel-booking:active {
  background: #FEE2E2;
}

/* 表单输入框 */
.form-input {
  flex: 1;
  height: 68rpx;
  font-size: var(--fs-28);
  color: #1E293B;
  text-align: right;
  background: transparent;
}

.form-row-textarea {
  flex-direction: column;
  align-items: stretch;
  gap: 12rpx;
  border-bottom: none;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  font-size: var(--fs-28);
  color: #1E293B;
  background: #F8FAFC;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.required-field::after {
  content: ' *';
  color: #DC2626;
}

/* ==================== 管理端预订详情弹窗样式 ==================== */

.booking-detail-sheet {
  max-height: 85vh;
}

.booking-summary-card {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 24rpx;
  background: linear-gradient(135deg, #EEF2FF 0%, #E0E7FF 100%);
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 0 40rpx;
}

.summary-num {
  font-size: var(--fs-44);
  font-weight: 700;
  color: #2563EB;
}

.summary-label {
  font-size: var(--fs-24);
  color: #64748B;
}

.summary-divider {
  width: 1rpx;
  height: 60rpx;
  background: #CBD5E1;
}

/* 预订人员列表 */
.booking-list-header {
  font-size: var(--fs-28);
  font-weight: 600;
  color: #1E293B;
  padding: 16rpx 0 20rpx;
  border-bottom: 1rpx solid #F1F5F9;
}

.booking-list {
  max-height: 400rpx;
  overflow-y: auto;
}

.booking-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F8FAFC;
}

.booking-name {
  font-size: var(--fs-28);
  color: #334155;
  font-weight: 500;
}

.booking-count {
  font-size: var(--fs-28);
  color: #2563EB;
  font-weight: 600;
}

/* PDF导出按钮 */
.btn-export-pdf {
  flex: 1;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--fs-28);
  font-weight: 600;
  box-sizing: border-box;
  background: linear-gradient(135deg, #7C3AED 0%, #6D28D9 100%);
  color: #fff;
  border: none;
}

.btn-export-pdf::after { border: none; }

.btn-export-pdf[disabled] {
  opacity: 0.45;
  pointer-events: none;
}
