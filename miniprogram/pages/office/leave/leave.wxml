<view class="leave-page" style="{{fontStyle}}">
  <!-- 渐变色头部 -->
  <view class="office-gradient-header leave-header">
    <view class="leave-header-content">
      <view class="leave-title">休假申请</view>
      <view class="leave-subtitle">休假申请及假期余额管理</view>
    </view>
  </view>

  <!-- 内容区域 -->
  <view class="leave-content">
    <!-- 首次配置弹窗（覆盖层） -->
    <view class="leave-setup-mask {{showFirstSetup ? 'is-visible' : ''}}" catchtouchmove="stopPropagation" bindtap="handleSetupCancel">
      <view class="leave-setup-container" catchtap="stopPropagation">
        <view class="leave-popup-header">
          <view class="leave-popup-title">首次配置休假信息</view>
          <view class="leave-popup-close" bindtap="handleSetupCancel">×</view>
        </view>
        <scroll-view scroll-y class="leave-popup-form">
          <view class="leave-form-scroll-main">
            <!-- 提示信息 -->
            <view class="leave-note" style="margin-bottom:28rpx;">
              <view class="leave-note-title">请填写您的休假相关信息</view>
              <view style="font-size:var(--fs-24);color:#065F66;line-height:1.6;">
                选择参加工作日期和到任日期后，系统将自动计算您的年休假和任期假配额。剩余天数用于初始化您已使用的历史天数。
              </view>
            </view>

            <!-- 参加工作日期 -->
            <view class="leave-field">
              <view class="leave-field-label">参加工作日期 <text class="leave-required">*</text></view>
              <datetime-picker value="{{setupForm.workStartDate}}" fields="{{['year', 'month', 'day']}}" placeholder="请选择参加工作日期" type="border" startDate="1985-01-01" endDate="{{today}}" bindchange="handleSetupWorkStartDateChange" />
              <!-- 工作年限提示 -->
              <view class="leave-setup-hint" wx:if="{{setupWorkYearHint}}">
                {{setupWorkYearHint}}
              </view>
            </view>

            <!-- 到任日期 -->
            <view class="leave-field">
              <view class="leave-field-label">到任日期（如系转馆，请填前馆到任日期） <text class="leave-required">*</text></view>
              <datetime-picker value="{{setupForm.arrivalDate}}" fields="{{['year', 'month', 'day']}}" placeholder="请选择到任日期" type="border" startDate="2018-01-01" endDate="{{today}}" bindchange="handleSetupArrivalDateChange" />
              <!-- 任期假提示 -->
              <view class="leave-setup-hint" wx:if="{{setupTermHint}}">
                {{setupTermHint}}
              </view>
            </view>

            <!-- 年休假剩余天数（到任今年无需填写） -->
            <block wx:if="{{setupNeedAnnual}}">
              <!-- x-1年年休假剩余（Q1且到任年份<=x-2时显示） -->
              <view class="leave-field" wx:if="{{setupNeedPrevAnnual}}">
                <view class="leave-field-label">{{setupPrevYear}}年年休假剩余天数 <text class="leave-required">*</text></view>
                <view class="leave-input-wrapper">
                  <input class="leave-input" type="digit" value="{{setupForm.annualRemainingPrev}}" placeholder="{{setupPrevAnnualPlaceholder}}" placeholder-class="leave-input-placeholder" bindinput="handleSetupAnnualPrevInput" />
                  <text style="font-size:var(--fs-26);color:#94A3B8;padding-right:8rpx;">天</text>
                </view>
              </view>

              <!-- x年年休假剩余 -->
              <view class="leave-field">
                <view class="leave-field-label">{{setupCurrentYear}}年年休假剩余天数 <text class="leave-required">*</text></view>
                <view class="leave-input-wrapper">
                  <input class="leave-input" type="digit" value="{{setupForm.annualRemainingCurrent}}" placeholder="{{setupCurrentAnnualPlaceholder}}" placeholder-class="leave-input-placeholder" bindinput="handleSetupAnnualCurrentInput" />
                  <text style="font-size:var(--fs-26);color:#94A3B8;padding-right:8rpx;">天</text>
                </view>
              </view>
            </block>

            <!-- 任期假剩余天数（可休次数>0时显示） -->
            <block wx:if="{{setupMaxTermRound > 0}}">
              <!-- 第y-1次任期假剩余天数 -->
              <view class="leave-field" wx:if="{{setupNeedPrevTerm}}">
                <view class="leave-field-label">第{{setupPrevTermRound}}次任期假剩余天数 <text class="leave-required">*</text></view>
                <view class="leave-input-wrapper">
                  <input class="leave-input" type="digit" value="{{setupForm.termRemainingPrev}}" placeholder="请输入第{{setupPrevTermRound}}次任期假剩余天数（0-20）" placeholder-class="leave-input-placeholder" bindinput="handleSetupTermPrevInput" />
                  <text style="font-size:var(--fs-26);color:#94A3B8;padding-right:8rpx;">天</text>
                </view>
              </view>
              <!-- 第y-1次任期假是否回国 -->
              <view class="leave-field" wx:if="{{setupNeedPrevTerm}}">
                <view class="leave-field-label">第{{setupPrevTermRound}}次任期假是否回国 <text class="leave-required">*</text></view>
                <view class="leave-select-group">
                  <view class="leave-select-item {{setupForm.prevTermReturnToHome ? 'is-active' : ''}}" data-value="true" bindtap="handleSetupPrevTermReturnSelect">是</view>
                  <view class="leave-select-item {{!setupForm.prevTermReturnToHome ? 'is-active' : ''}}" data-value="false" bindtap="handleSetupPrevTermReturnSelect">否</view>
                </view>
                <text style="font-size:var(--fs-22);color:#94A3B8;display:block;margin-top:4rpx;">
                  回国则该次任期假使用了+2天机会
                </text>
              </view>
              <!-- 第y-1次任期假是否使用公费 -->
              <view class="leave-field" wx:if="{{setupNeedPrevTerm}}">
                <view class="leave-field-label">第{{setupPrevTermRound}}次任期假是否使用公费 <text class="leave-required">*</text></view>
                <view class="leave-select-group">
                  <view class="leave-select-item {{setupForm.prevTermPublicExpense ? 'is-active' : ''}}" data-value="true" bindtap="handleSetupPrevTermPublicExpenseSelect">是</view>
                  <view class="leave-select-item {{!setupForm.prevTermPublicExpense ? 'is-active' : ''}}" data-value="false" bindtap="handleSetupPrevTermPublicExpenseSelect">否</view>
                </view>
                <text style="font-size:var(--fs-22);color:#94A3B8;display:block;margin-top:4rpx;">
                  使用公费则该次任期假的公费机会已使用
                </text>
              </view>

              <!-- 第y次任期假剩余天数 -->
              <view class="leave-field">
                <view class="leave-field-label">第{{setupMaxTermRound}}次任期假剩余天数 <text class="leave-required">*</text></view>
                <view class="leave-input-wrapper">
                  <input class="leave-input" type="digit" value="{{setupForm.termRemainingCurrent}}" placeholder="请输入第{{setupMaxTermRound}}次任期假剩余天数（0-20）" placeholder-class="leave-input-placeholder" bindinput="handleSetupTermCurrentInput" />
                  <text style="font-size:var(--fs-26);color:#94A3B8;padding-right:8rpx;">天</text>
                </view>
              </view>
              <!-- 第y次任期假是否回国 -->
              <view class="leave-field">
                <view class="leave-field-label">第{{setupMaxTermRound}}次任期假是否回国 <text class="leave-required">*</text></view>
                <view class="leave-select-group">
                  <view class="leave-select-item {{setupForm.currentTermReturnToHome ? 'is-active' : ''}}" data-value="true" bindtap="handleSetupCurrentTermReturnSelect">是</view>
                  <view class="leave-select-item {{!setupForm.currentTermReturnToHome ? 'is-active' : ''}}" data-value="false" bindtap="handleSetupCurrentTermReturnSelect">否</view>
                </view>
                <text style="font-size:var(--fs-22);color:#94A3B8;display:block;margin-top:4rpx;">
                  回国则该次任期假使用了+2天机会
                </text>
              </view>
              <!-- 第y次任期假是否使用公费 -->
              <view class="leave-field">
                <view class="leave-field-label">第{{setupMaxTermRound}}次任期假是否使用公费 <text class="leave-required">*</text></view>
                <view class="leave-select-group">
                  <view class="leave-select-item {{setupForm.currentTermPublicExpense ? 'is-active' : ''}}" data-value="true" bindtap="handleSetupCurrentTermPublicExpenseSelect">是</view>
                  <view class="leave-select-item {{!setupForm.currentTermPublicExpense ? 'is-active' : ''}}" data-value="false" bindtap="handleSetupCurrentTermPublicExpenseSelect">否</view>
                </view>
                <text style="font-size:var(--fs-22);color:#94A3B8;display:block;margin-top:4rpx;">
                  使用公费则该次任期假的公费机会已使用
                </text>
              </view>
            </block>

            <!-- 到任今年无年休假提示 -->
            <view class="leave-setup-hint" wx:if="{{setupForm.arrivalDate && !setupNeedAnnual}}">
              到任当年无年休假，无需填写年休假剩余天数
            </view>
          </view>
        </scroll-view>

        <view class="leave-popup-actions">
          <button class="leave-cancel-btn" bindtap="handleSetupCancel">取消返回</button>
          <button class="leave-confirm-btn" loading="{{setupSubmitting}}" disabled="{{setupSubmitting}}" bindtap="handleSetupConfirm">确定保存</button>
        </view>
      </view>
    </view>

    <!-- Tab栏 -->
    <view class="leave-tabs" wx:if="{{!showFirstSetup}}">
      <view class="leave-tab {{activeTab === 'apply' ? 'is-active' : ''}}" data-tab="apply" bindtap="handleTabSwitch">申请</view>
      <view class="leave-tab {{activeTab === 'records' ? 'is-active' : ''}}" data-tab="records" bindtap="handleTabSwitch">我的休假记录</view>
    </view>

    <!-- ========== 申请 Tab ========== -->
    <block wx:if="{{activeTab === 'apply' && !showFirstSetup}}">
      <view class="leave-section">

        <!-- ===== 余额卡片（替换原 leave-type-scroll） ===== -->
        <view class="quota-summary-card" wx:if="{{quotaSummary}}">
          <view class="quota-card-header">
            <view class="quota-card-title">{{quotaSummary.year}}年可用假期情况</view>
            <view class="quota-card-badge" wx:if="{{quotaSummary.usageCountThisYear > 0}}">
              已休{{quotaSummary.usageCountThisYear}}次
            </view>
          </view>

          <!-- 年休假 -->
          <view class="quota-card-row">
            <view class="quota-card-icon annual-icon">
              <text class="quota-icon-text">年</text>
            </view>
            <view class="quota-card-info">
              <view class="quota-card-name">年休假</view>
              <view class="quota-card-detail">
                <text wx:for="{{quotaSummary.annual.details}}" wx:key="year" wx:for-item="item">
                  {{item.year}}年 {{item.availableDays}}天
                  <text wx:if="{{item.extendedTo}}" style="color:#D97706;"> (有效期至{{item.extendedTo}})</text>
                </text>
              </view>
            </view>
            <view class="quota-card-value">
              <text class="quota-value-num">{{quotaSummary.annual.totalAvailable}}</text>
              <text class="quota-value-unit">天</text>
            </view>
          </view>

          <!-- 任期假 -->
          <view class="quota-card-row">
            <view class="quota-card-icon term-icon">
              <text class="quota-icon-text">任</text>
            </view>
            <view class="quota-card-info">
              <view class="quota-card-name">任期假</view>
              <view class="quota-card-detail">
                <text wx:for="{{quotaSummary.term.details}}" wx:key="round" wx:for-item="item">
                  第{{item.round}}次 {{item.availableDays}}天<text wx:if="{{item.expiryDate}}" style="color:#D97706;"> (有效期至{{item.expiryDate}})</text>
                </text>
              </view>
            </view>
            <view class="quota-card-value">
              <text class="quota-value-num">{{quotaSummary.term.totalAvailable}}</text>
              <text class="quota-value-unit">天</text>
            </view>
          </view>

          <!-- 第2次休假提示 -->
          <view class="quota-card-warn" wx:if="{{quotaSummary.isSecondMustUseAll && quotaSummary.canApplyThisYear}}">
            本年第2次休假须将剩余年休假和任期假全部休完
          </view>
        </view>

        <!-- ===== "其他"类型入口 ===== -->
        <view class="leave-field">
          <view class="leave-switch-row">
            <text class="leave-switch-label">申请其他类型假期（事假、病假等）</text>
            <switch checked="{{showOtherTypeForm}}" color="#065F46" bindchange="handleOtherTypeSwitch" />
          </view>
        </view>

        <!-- ===== 日期选择区 ===== -->
        <view class="leave-field">
          <view class="leave-field-label">休假日期 <text class="leave-required">*</text></view>
          <view class="leave-date-range">
            <view class="leave-date-item">
              <datetime-picker value="{{form.startDate}}" fields="{{['year', 'month', 'day', 'weekday']}}" placeholder="开始日期" type="border" startDate="{{today}}" bindchange="handleStartDateChange" />
            </view>
            <view class="leave-date-arrow">→</view>
            <view class="leave-date-item">
              <datetime-picker value="{{form.endDate}}" fields="{{['year', 'month', 'day', 'weekday']}}" placeholder="结束日期" type="border" startDate="{{form.startDate || today}}" bindchange="handleEndDateChange" />
            </view>
          </view>
        </view>

        <!-- ===== 任期假选项（回国+公费） ===== -->
        <view class="leave-field" wx:if="{{showTermOptions}}">
          <view class="leave-switch-row">
            <text class="leave-switch-label">是否回国？</text>
            <switch checked="{{form.isReturnToHome}}" color="#065F46" bindchange="handleSwitchReturnToHome" />
          </view>
          <text wx:if="{{isReturnToHome}}" style="font-size:var(--fs-24);color:#94A3B8;display:block;margin-top:4rpx;">
            每次任期假，回国时只有一次+2天机会，串联下一次任期假休假时可用下一轮机会
          </text>
        </view>

        <!-- ===== 方案选择区（日期选完后显示） ===== -->
        <view class="plan-section" wx:if="{{calculatedPlans.length > 0}}">
          <view class="plan-section-title">请选择休假方案</view>

          <view wx:for="{{calculatedPlans}}" wx:key="planKey" class="plan-card {{selectedPlan === item.planKey ? 'is-selected' : ''}}" data-plan="{{item.planKey}}" bindtap="handlePlanSelect">
            <view class="plan-card-header">
              <view class="plan-card-label">方案{{item.planKey}}</view>
              <view class="plan-card-desc">{{item.label}}</view>
              <view class="plan-card-check" wx:if="{{selectedPlan === item.planKey}}">✓</view>
            </view>

            <!-- 消耗明细 -->
            <view class="plan-consumed-list">
              <view wx:for="{{item.consumed}}" wx:for-item="c" wx:key="index" class="plan-consumed-item">
                <view class="plan-consumed-type">
                  <text wx:if="{{c.type === 'annual'}}" class="plan-tag annual-tag">年休假({{c.year}}年)</text>
                  <text wx:if="{{c.type === 'term'}}" class="plan-tag term-tag">任期假(第{{c.round}}次)</text>
                </view>
                <view class="plan-consumed-detail">
                  <text wx:if="{{c.type === 'annual'}}">{{c.consumeDays}}个工作日</text>
                  <text wx:if="{{c.type === 'term'}}">
                    {{c.consumeDays}}个自然日
                    <text wx:if="{{c.usedReturnBonus}}" class="plan-bonus-tag">含+2天</text>
                  </text>
                  <text class="plan-consumed-dates">{{c.startDate}} ~ {{c.endDate}}</text>
                </view>
              </view>
            </view>

            <!-- 覆盖总览 -->
            <view class="plan-coverage">
              <text wx:if="{{item.consumed.length > 0}}">共覆盖 {{item.totalCoveredDays}} 天（{{form.startDate}} ~ {{form.endDate}}）</text>
              <text wx:else>覆盖 {{item.totalCoveredDays}} 天（{{form.startDate}} ~ {{form.endDate}}）</text>
              <text wx:if="{{item.holidayCoveredDays > 0}}" style="color:#68778c;font-size:var(--fs-24);display:block;margin-top:4rpx;">其中法定节假日 {{item.holidayCoveredDays}} 天</text>
              <text wx:if="{{item.weekendCoveredDays > 0}}" style="color:#68778c;font-size:var(--fs-24);display:block;">其中公休日 {{item.weekendCoveredDays}} 天</text>
            </view>

            <!-- 第2次休假警告 -->
            <view class="plan-warning" wx:if="{{item.secondLeaveWarning}}">
              ⚠️ {{item.secondLeaveWarning}}
            </view>
          </view>
        </view>

        <!-- 无方案提示 -->
        <view class="plan-no-result" wx:if="{{form.startDate && form.endDate && calculatedPlans.length === 0 && !plansLoading}}">
          <text>配额不足以覆盖所选日期，请调整日期或检查余额</text>
        </view>

        <!-- 方案计算中 -->
        <view class="plan-loading" wx:if="{{plansLoading}}">
          <text>正在计算方案...</text>
        </view>

        <!-- ===== "其他"类型独立表单（展开时显示） ===== -->
        <block wx:if="{{showOtherTypeForm}}">
          <view class="leave-field">
            <view class="leave-field-label">自定义类型名 <text class="leave-required">*</text></view>
            <view class="leave-input-wrapper">
              <input class="leave-input" value="{{form.otherTypeName}}" placeholder="如：事假、病假等" placeholder-class="leave-input-placeholder" bindinput="handleOtherTypeNameInput" />
            </view>
          </view>
        </block>

        <!-- ===== 费用性质（仅涉及任期假方案或"其他"类型时显示） ===== -->
        <view class="leave-field" wx:if="{{showExpenseTypeSelect}}">
          <view class="leave-field-label">费用性质 <text class="leave-required">*</text></view>
          <view class="leave-select-group">
            <view class="leave-select-item {{form.expenseType === 'public' ? 'is-active' : ''}}" data-value="public" bindtap="handleExpenseTypeSelect">公费</view>
            <view class="leave-select-item {{form.expenseType === 'self' ? 'is-active' : ''}}" data-value="self" bindtap="handleExpenseTypeSelect">自费</view>
          </view>
          <text style="font-size:var(--fs-22);color:#94A3B8;display:block;margin-top:4rpx;" wx:if="{{selectedPlanHasTerm}}">
            每次任期假只有一次公费机会，串联休假时可用下一轮机会
          </text>
        </view>

        <!-- 休假地点 -->
        <view class="leave-field">
          <view class="leave-field-label">休假地点</view>
          <view class="leave-input-wrapper">
            <input class="leave-input" value="{{form.leaveLocation}}" placeholder="请填写休假地点" placeholder-class="leave-input-placeholder" bindinput="handleLeaveLocationInput" />
          </view>
        </view>

        <!-- 休假路线 -->
        <view class="leave-field">
          <view class="leave-field-label">休假路线</view>
          <view class="leave-input-wrapper">
            <input class="leave-input" value="{{form.leaveRoute}}" placeholder="请填写休假路线" placeholder-class="leave-input-placeholder" bindinput="handleLeaveRouteInput" />
          </view>
        </view>

        <!-- 拟定航班 -->
        <view class="leave-field">
          <view class="leave-field-label">拟定航班</view>
          <view class="leave-textarea-wrapper">
            <textarea class="leave-textarea" value="{{form.proposedFlights}}" placeholder="请填写航班号、时间等" placeholder-class="leave-input-placeholder" bindinput="handleProposedFlightsInput" maxlength="500" auto-height />
          </view>
        </view>

        <!-- 是否申请公费待遇转让（公费时显示） -->
        <view class="leave-field" wx:if="{{form.expenseType === 'public'}}">
          <view class="leave-switch-row">
            <text class="leave-switch-label">是否申请公费待遇转让？</text>
            <switch checked="{{form.isTransferringBenefit}}" color="#065F46" bindchange="handleSwitchTransferringBenefit" />
          </view>
        </view>

        <!-- 已转让公费待遇次数（转让选是时显示） -->
        <view class="leave-field" wx:if="{{form.isTransferringBenefit && form.expenseType === 'public'}}">
          <view class="leave-stepper-row">
            <text class="leave-stepper-label">已转让公费待遇次数</text>
            <stepper value="{{form.transferredCount}}" min="0" max="99" step="1" bindchange="handleTransferredCountChange" />
          </view>
        </view>

        <!-- 是否需协助办理签证 -->
        <view class="leave-field">
          <view class="leave-switch-row">
            <text class="leave-switch-label">是否需协助办理签证？</text>
            <switch checked="{{form.needsVisaAssistance}}" color="#065F46" bindchange="handleSwitchVisaAssistance" />
          </view>
        </view>

        <!-- 其他说明 -->
        <view class="leave-field">
          <view class="leave-field-label">其他说明（如同行人情况）</view>
          <view class="leave-textarea-wrapper">
            <textarea class="leave-textarea" value="{{form.otherNotes}}" placeholder="其他需要说明的内容" placeholder-class="leave-input-placeholder" bindinput="handleOtherNotesInput" maxlength="500" auto-height />
          </view>
        </view>

        <!-- 休假原因 -->
        <view class="leave-field">
          <view class="leave-field-label">休假原因 <text class="leave-required">*</text></view>
          <view class="leave-textarea-wrapper">
            <textarea class="leave-textarea" value="{{form.reason}}" placeholder="请填写休假原因" placeholder-class="leave-input-placeholder" bindinput="handleReasonInput" maxlength="500" auto-height />
          </view>
        </view>

        <!-- 审批流程说明 -->
        <view class="leave-note">
          <view class="leave-note-title">📋 审批流程</view>
          <view class="leave-note-steps">
            <view class="leave-note-step">
              <view class="leave-step-dot"></view>
              <view class="leave-step-text">部门负责人</view>
            </view>
            <view class="leave-note-arrow">→</view>
            <view class="leave-note-step">
              <view class="leave-step-dot"></view>
              <view class="leave-step-text">会计</view>
            </view>
            <view class="leave-note-arrow">→</view>
            <view class="leave-note-step">
              <view class="leave-step-dot"></view>
              <view class="leave-step-text">会计主管</view>
            </view>
            <view class="leave-note-arrow">→</view>
            <view class="leave-note-step">
              <view class="leave-step-dot"></view>
              <view class="leave-step-text">人事主管</view>
            </view>
            <view class="leave-note-arrow">→</view>
            <view class="leave-note-step">
              <view class="leave-step-dot"></view>
              <view class="leave-step-text">馆领导</view>
            </view>
          </view>
        </view>

        <!-- 提交按钮 -->
        <button class="leave-submit-btn" loading="{{submitting}}" disabled="{{submitting || !canSubmit}}" bindtap="handleSubmitApplication">
          {{submitting ? '提交中...' : (!canSubmit ? '请选择休假方案' : '提交休假申请')}}
        </button>
      </view>
    </block>

    <!-- ========== 记录 Tab ========== -->
    <block wx:if="{{activeTab === 'records' && !showFirstSetup}}">
      <view class="leave-section">
        <view class="leave-section-header">
          <view class="leave-section-title">我的休假记录</view>
          <view class="leave-add-btn" bindtap="showSupplementPopup">
            <text class="leave-add-text">补填记录</text>
          </view>
        </view>

        <!-- 按月分组列表 -->
        <block wx:for="{{groupedRecords}}" wx:key="monthKey">
          <view class="leave-month-group">
            <view class="leave-month-title">{{item.monthText}}</view>
            <view class="leave-list">
              <view class="leave-item" wx:for="{{item.records}}" wx:for-item="record" wx:key="_id" bindtap="showRecordDetail" data-record="{{record}}">
                <!--  <view class="leave-supplement-badge" wx:if="{{record.recordSource === 'supplemented'}}">补填</view> -->
                <view class="leave-item-header">
                  <view class="leave-item-type">{{record.leaveTypeName}}</view>
                  <view class="leave-item-status status-{{record.status}}">{{record.statusText}}</view>
                </view>
                <view class="leave-item-body">
                  <view class="leave-item-dates">{{record.startDate}} ~ {{record.endDate}}</view>
                  <view class="leave-item-meta">
                    <text class="leave-item-days">{{record.totalDays}}天</text>
                    <text class="leave-item-expense" wx:if="{{record.expenseType}}">{{record.expenseType === 'public' ? '公费' : '自费'}}</text>
                    <text class="leave-item-expense" wx:if="{{record.leaveLocation}}">{{record.leaveLocation}}</text>
                  </view>
                </view>
              </view>
            </view>
          </view>
        </block>

        <!-- 空状态 -->
        <view wx:if="{{!loading && list.length === 0}}" class="leave-empty">
          <view class="leave-empty-icon">🏖️</view>
          <view class="leave-empty-text">暂无休假记录</view>
          <view class="leave-empty-hint">点击上方"补填记录"或切换到申请tab提交申请</view>
        </view>

        <!-- 加载中 -->
        <view wx:if="{{loading && list.length === 0}}" class="leave-loading">
          <view class="leave-loading-text">加载中...</view>
        </view>
      </view>
    </block>
  </view>

  <!-- 底部弹出：详情弹窗 -->
  <view class="leave-setup-mask {{showDetailPopup ? 'is-visible' : ''}}" catchtouchmove="stopPropagation" bindtap="hideDetailPopup">
    <view class="leave-setup-container" catchtap="stopPropagation">
      <view class="leave-popup-header">
        <view class="leave-popup-title">休假记录详情</view>
        <view class="leave-popup-close" bindtap="hideDetailPopup">×</view>
      </view>
      <scroll-view scroll-y scroll-top="{{detailScrollTop}}" class="leave-detail-content" wx:if="{{selectedRecord}}">
        <!-- 基本信息 -->
        <view class="leave-detail-row">
          <text class="leave-detail-label">休假类型：</text>
          <text class="leave-detail-value">{{selectedRecord.leaveTypeName}}</text>
        </view>
        <view class="leave-detail-row">
          <text class="leave-detail-label">休假日期：</text>
          <text class="leave-detail-value">{{selectedRecord.startDate}} ~ {{selectedRecord.endDate}}</text>
        </view>
        <view class="leave-detail-row">
          <text class="leave-detail-label">总天数：</text>
          <text class="leave-detail-value">{{selectedRecord.totalDays}}天</text>
        </view>
        <view class="leave-detail-row">
          <text class="leave-detail-label">工作日天数：</text>
          <text class="leave-detail-value">{{selectedRecord.workDays}}天</text>
        </view>
        <view class="leave-detail-row" wx:if="{{selectedRecord.isReturnToHome !== undefined}}">
          <text class="leave-detail-label">是否回国：</text>
          <text class="leave-detail-value">{{selectedRecord.isReturnToHome ? '是' : '否'}}</text>
        </view>
        <view class="leave-detail-row" wx:if="{{selectedRecord.termLeaveRound}}">
          <text class="leave-detail-label">任期假次数：</text>
          <text class="leave-detail-value">第{{selectedRecord.termLeaveRound}}次</text>
        </view>
        <view class="leave-detail-row" wx:if="{{selectedRecord.selectedPlan}}">
          <text class="leave-detail-label">休假方案：</text>
          <text class="leave-detail-value">方案{{selectedRecord.selectedPlan}}</text>
        </view>
        <!-- 配额消耗明细 -->
        <block wx:if="{{selectedRecord.planConsumedQuota && selectedRecord.planConsumedQuota.length > 0}}">
          <view class="leave-detail-row">
            <text class="leave-detail-label" style="color:#065F46;font-weight:600;">配额消耗：</text>
          </view>
          <view class="leave-detail-row" wx:for="{{selectedRecord.planConsumedQuota}}" wx:key="index" wx:for-item="c">
            <text class="leave-detail-label">
              <text wx:if="{{c.type === 'annual'}}">年休假({{c.year}}年)</text>
              <text wx:if="{{c.type === 'term'}}">任期假(第{{c.round}}次)</text>
            </text>
            <text class="leave-detail-value">
              <text wx:if="{{c.type === 'annual'}}">{{c.consumeDays}}个工作日</text>
              <text wx:if="{{c.type === 'term'}}">{{c.consumeDays}}个自然日<text wx:if="{{c.usedReturnBonus}}" style="color:#1D4ED8;">(含+2天)</text></text>
              <text style="color:#94A3B8;font-size:var(--fs-26);margin-left:8rpx;">\n{{c.startDate}}~{{c.endDate}}</text>
            </text>
          </view>
        </block>
        <view class="leave-detail-row" wx:if="{{selectedRecord.reason}}">
          <text class="leave-detail-label">休假原因：</text>
          <text class="leave-detail-value">{{selectedRecord.reason}}</text>
        </view>

        <view style="height:16rpx;background:#F8FAFC;margin:20rpx -32rpx;"></view>

        <!-- 费用与行程信息 -->
        <view class="leave-detail-row">
          <text class="leave-detail-label">费用性质：</text>
          <text class="leave-detail-value">{{selectedRecord.expenseType === 'public' ? '公费' : '自费'}}</text>
        </view>
        <view class="leave-detail-row" wx:if="{{selectedRecord.leaveLocation}}">
          <text class="leave-detail-label">休假地点：</text>
          <text class="leave-detail-value">{{selectedRecord.leaveLocation}}</text>
        </view>
        <view class="leave-detail-row" wx:if="{{selectedRecord.leaveRoute}}">
          <text class="leave-detail-label">休假路线：</text>
          <text class="leave-detail-value">{{selectedRecord.leaveRoute}}</text>
        </view>
        <view class="leave-detail-row" wx:if="{{selectedRecord.proposedFlights}}">
          <text class="leave-detail-label">拟定航班：</text>
          <text class="leave-detail-value">{{selectedRecord.proposedFlights}}</text>
        </view>
        <view class="leave-detail-row" wx:if="{{selectedRecord.isTransferringBenefit}}">
          <text class="leave-detail-label">公费待遇转让：</text>
          <text class="leave-detail-value">{{selectedRecord.isTransferringBenefit ? '是' : '否'}}</text>
        </view>
        <view class="leave-detail-row" wx:if="{{selectedRecord.transferredCount > 0}}">
          <text class="leave-detail-label">已转让次数：</text>
          <text class="leave-detail-value">{{selectedRecord.transferredCount}}次</text>
        </view>
        <view class="leave-detail-row">
          <text class="leave-detail-label">协助办签证：</text>
          <text class="leave-detail-value">{{selectedRecord.needsVisaAssistance ? '是' : '否'}}</text>
        </view>
        <view class="leave-detail-row" wx:if="{{selectedRecord.otherNotes}}">
          <text class="leave-detail-label">其他说明：</text>
          <text class="leave-detail-value">{{selectedRecord.otherNotes}}</text>
        </view>

        <!-- 组合假子记录 -->
        <block wx:if="{{selectedRecord.subRecord}}">
          <view style="height:16rpx;background:#F8FAFC;margin:20rpx -32rpx;"></view>
          <view class="leave-detail-row"><text class="leave-detail-label" style="color:#065F46;font-weight:600;">第二段（任期假）</text></view>
          <view class="leave-detail-row">
            <text class="leave-detail-label">日期范围：</text>
            <text class="leave-detail-value">{{selectedRecord.subRecord.startDate}} ~ {{selectedRecord.subRecord.endDate}}</text>
          </view>
          <view class="leave-detail-row">
            <text class="leave-detail-label">天数：</text>
            <text class="leave-detail-value">{{selectedRecord.subRecord.totalDays}}天</text>
          </view>
        </block>

        <view style="height:16rpx;background:#F8FAFC;margin:20rpx -32rpx;"></view>

        <view class="leave-detail-row">
          <text class="leave-detail-label">申请人：</text>
          <text class="leave-detail-value">{{selectedRecord.applicantName}}</text>
        </view>
        <view class="leave-detail-row">
          <text class="leave-detail-label">部门：</text>
          <text class="leave-detail-value">{{selectedRecord.applicantDepartment || '-'}}</text>
        </view>
        <view class="leave-detail-row">
          <text class="leave-detail-label">状态：</text>
          <text class="leave-detail-value status-{{selectedRecord.status}}">{{selectedRecord.statusText}}</text>
        </view>
        <view class="leave-detail-row">
          <text class="leave-detail-label">创建时间：</text>
          <text class="leave-detail-value">{{selectedRecord.createdAtText}}</text>
        </view>
        <view class="leave-detail-row">
          <text class="leave-detail-label">通过时间：</text>
          <text class="leave-detail-value">{{selectedRecord.updatedAtText}}</text>
        </view>
        <view class="leave-detail-row" wx:if="{{selectedRecord.recordSource === 'supplemented'}}">
          <text class="leave-detail-label">来源：</text>
          <text class="leave-detail-value" style="color:#7C3AED;">补填记录</text>
        </view>

        <!-- 审批日志（仅申请记录显示） -->
        <view wx:if="{{detailLogs.length > 0 && selectedRecord.recordSource !== 'supplemented'}}" class="leave-detail-logs">
          <view class="leave-logs-title">审批记录</view>
          <view class="leave-log-item" wx:for="{{detailLogs}}" wx:key="index">
            <view class="leave-log-dot"></view>
            <view class="leave-log-content">
              <view class="leave-log-action">{{item.actionText}}</view>
              <view class="leave-log-info" wx:if="{{item.stepName}}">{{item.stepName}}</view>
              <view class="leave-log-info" wx:if="{{item.operatorName}}">
                <text wx:if="{{item.remark}}">{{item.operatorName}}：{{item.remark}}</text>
                <text wx:else>{{item.operatorName}}</text>
              </view>
              <view class="leave-log-info" wx:elif="{{item.remark}}">{{item.remark}}</view>
              <view class="leave-log-time">{{item.timeText}}</view>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 底部弹出：补填记录弹窗 -->
  <view class="leave-setup-mask {{showSupplementPopup ? 'is-visible' : ''}}" catchtouchmove="stopPropagation" bindtap="hideSupplementPopup">
    <view class="leave-setup-container" catchtap="stopPropagation">
      <view class="leave-popup-header">
        <view class="leave-popup-title">补填过往休假记录</view>
        <view class="leave-popup-close" bindtap="hideSupplementPopup">×</view>
      </view>
      <scroll-view scroll-y class="leave-popup-form">
        <view class="leave-form-scroll-main">
          <!-- 补填日期 -->
          <view class="leave-field">
            <view class="leave-field-label">休假日期 <text class="leave-required">*</text></view>
            <view class="leave-date-range">
              <view class="leave-date-item">
                <datetime-picker value="{{supplementForm.startDate}}" fields="{{['year', 'month', 'day']}}" placeholder="开始日期" type="border" endDate="{{today}}" bindchange="handleSupplementStartChange" />
              </view>
              <view class="leave-date-arrow">→</view>
              <view class="leave-date-item">
                <datetime-picker value="{{supplementForm.endDate}}" fields="{{['year', 'month', 'day']}}" placeholder="结束日期" type="border" endDate="{{today}}" bindchange="handleSupplementEndChange" />
              </view>
            </view>
          </view>

          <!-- 假期构成 -->
          <view class="leave-field">
            <view class="leave-field-label">假期构成 <text class="leave-required">*</text></view>
            <view class="leave-textarea-wrapper">
              <textarea class="leave-textarea" value="{{supplementForm.leaveComposition}}" placeholder="请填写假期构成，如：年休假5天+任期假20天" placeholder-class="leave-input-placeholder" bindinput="handleSupplementCompositionInput" maxlength="500" auto-height />
            </view>
          </view>

          <!-- 费用性质 -->
          <view class="leave-field">
            <view class="leave-field-label">费用性质 <text class="leave-required">*</text></view>
            <view class="leave-select-group">
              <view class="leave-select-item {{supplementForm.expenseType === 'public' ? 'is-active' : ''}}" data-value="public" bindtap="handleSupplementExpenseSelect">公费</view>
              <view class="leave-select-item {{supplementForm.expenseType === 'self' ? 'is-active' : ''}}" data-value="self" bindtap="handleSupplementExpenseSelect">自费</view>
            </view>
          </view>

          <!-- 休假地点 -->
          <view class="leave-field">
            <view class="leave-field-label">休假地点</view>
            <view class="leave-input-wrapper">
              <input class="leave-input" value="{{supplementForm.leaveLocation}}" placeholder="请填写休假地点" placeholder-class="leave-input-placeholder" bindinput="handleSupplementLocationInput" />
            </view>
          </view>

          <!-- 备注 -->
          <view class="leave-field">
            <view class="leave-field-label">备注</view>
            <view class="leave-textarea-wrapper">
              <textarea class="leave-textarea" value="{{supplementForm.remark}}" placeholder="补充说明（可选）" placeholder-class="leave-input-placeholder" bindinput="handleSupplementRemarkInput" maxlength="200" auto-height />
            </view>
          </view>
        </view>
      </scroll-view>

      <view class="leave-popup-actions">
        <button class="leave-cancel-btn" bindtap="hideSupplementPopup">取消</button>
        <button class="leave-confirm-btn" loading="{{supplementSubmitting}}" disabled="{{supplementSubmitting}}" bindtap="handleSubmitSupplement">确认补填</button>
      </view>
    </view>
  </view>

  <!-- 底部弹出：余额弹窗 -->
  <view class="leave-setup-mask {{showQuotaPopup ? 'is-visible' : ''}}" catchtouchmove="stopPropagation" bindtap="hideQuotaPopup">
    <view class="leave-setup-container" catchtap="stopPropagation">
      <view class="leave-popup-header">
        <view class="leave-popup-title">假期余额</view>
        <view class="leave-popup-close" bindtap="hideQuotaPopup">×</view>
      </view>
      <scroll-view scroll-y class="leave-detail-content" wx:if="{{quotaDetail}}">
        <!-- 年休假 -->
        <view wx:for="{{quotaDetail.annualLeaves}}" wx:key="year">
          <view class="leave-quota-card" style="margin-bottom:16rpx;">
            <view class="leave-quota-title" style="display:flex;justify-content:space-between;">
              <text>{{item.year}}年年休假</text>
              <text style="font-size:var(--fs-22);color:{{item.status === 'active' ? '#065F46' : '#94A3B8'}};">{{item.status === 'active' ? '有效' : '过期'}}</text>
            </view>
            <view style="margin-top:12rpx;">
              <view style="display:flex;justify-content:space-between;margin-bottom:6rpx;">
                <text style="font-size:var(--fs-24);color:#64748B;">可用</text>
                <text style="font-size:var(--fs-28);color:#065F46;font-weight:600;">{{item.availableDays}} 天</text>
              </view>
              <view style="display:flex;justify-content:space-between;margin-bottom:6rpx;">
                <text style="font-size:var(--fs-24);color:#64748B;">已休</text>
                <text style="font-size:var(--fs-24);color:#DC2626;">{{item.usedDays}} 天</text>
              </view>
              <view style="display:flex;justify-content:space-between;" wx:if="{{item.expiredDays > 0}}">
                <text style="font-size:var(--fs-24);color:#64748B;">作废</text>
                <text style="font-size:var(--fs-24);color:#94A3B8;">{{item.expiredDays}} 天</text>
              </view>
              <view style="background:#E5E7EB;height:8rpx;border-radius:4rpx;margin-top:12rpx;overflow:hidden;">
                <view style="background:linear-gradient(90deg,#065F46,#10B981);height:100%;border-radius:4rpx;width:{{(item.usedDays + item.expiredDays) * 100 / (item.totalDays || 1)}}%;"></view>
              </view>
              <view style="display:flex;justify-content:space-between;margin-top:4rpx;">
                <text style="font-size:var(--fs-20);color:#94A3B8;">总计 {{item.totalDays}} 天</text>
                <text style="font-size:var(--fs-20);color:#94A3B8;" wx:if="{{item.extendedTo}}">有效期至 {{item.extendedTo}}</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 任期假 -->
        <view style="height:16rpx;background:#F8FAFC;margin:20rpx -32rpx;"></view>
        <view style="font-size:var(--fs-30);font-weight:600;color:#1E293B;margin-bottom:16rpx;">任期假</view>
        <view wx:for="{{quotaDetail.termLeaves}}" wx:key="round">
          <view class="leave-term-option" style="width:auto;margin-bottom:8rpx;{{item.used ? 'opacity:0.5;' : ''}}">
            第{{item.round}}次
            <text wx:if="{{item.eligibleDate}}">（{{item.eligibleDate}}起可用）</text>
            <text wx:if="{{item.used}}" style="margin-left:8rpx;color:#DC2626;">已用完</text>
            <text wx:elif="" style="margin-left:8rpx;color:#16A34A;">剩余{{item.availableDays !== undefined ? item.availableDays : 20}}天</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>
</view>