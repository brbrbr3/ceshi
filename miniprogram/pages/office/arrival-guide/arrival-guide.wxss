/* 全屏背景 */
.arrival-guide-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
}

.bg-image {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

/* 自定义导航栏 */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 10;
  background: rgba(0, 0, 0, 0.2);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.custom-nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  position: relative;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  color: #ffffff;
  font-weight: 300;
  line-height: 1;
  position: relative;
  z-index: 1;
}

.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: var(--fs-34);
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 2rpx;
}

/* 删除 .nav-placeholder */

/* 页面内容 */
.guide-content {
  position: relative;
  z-index: 1;
  padding: 40rpx 40rpx 60rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

/* 欢迎文字 */
.welcome-text {
  text-align: center;
  margin-bottom: 10rpx;
  padding-top: 10rpx;
}

.welcome-title {
  font-size: var(--fs-48);
  font-weight: 700;
  color: #ffffff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.welcome-desc {
  font-size: var(--fs-28);
  color: rgba(255, 255, 255, 0.85);
  text-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.3);
}

/* 按钮列表 */
.button-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 毛玻璃按钮 */
.guide-button {
  display: flex;
  align-items: center;
  padding: 15rpx 36rpx;
  background: rgba(0, 0, 0, 0.1);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-radius: 24rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: 4rpx 8rpx 32rpx rgba(0, 0, 0, 0.1);
  transition: all 0.2s ease;
}

.guide-button:active {
  background: rgba(255, 255, 255, 0.3);
  transform: scale(0.98);
}

.guide-button-icon {
  font-size: var(--fs-42);
  margin-right: 24rpx;
  flex-shrink: 0;
}

.guide-button-label {
  flex: 1;
  font-size: var(--fs-35);
  font-weight: 500;
  color: #ffffff;
  text-shadow: 1rpx 1rpx 4rpx rgba(0, 0, 0, 0.2);
}

.guide-button-arrow {
  font-size: var(--fs-46);
  color: rgba(255, 255, 255);
  font-weight: 300;
  margin-left: 12rpx;
}

/* ========== 弹窗 ========== */
.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.popup-mask.is-visible {
  opacity: 1;
  visibility: visible;
}

.popup-container {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 101;
  max-height: 70vh;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  display: flex;
  flex-direction: column;
}

.popup-container.is-visible {
  transform: translateY(0);
}

.popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 40rpx 24rpx;
  border-bottom: 1rpx solid #f1f5f9;
  flex-shrink: 0;
}

.popup-title {
  font-size: var(--fs-34);
  font-weight: 700;
  color: #1e293b;
}

.popup-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--fs-32);
  color: #94a3b8;
  border-radius: 50%;
  background: #f1f5f9;
}

.popup-body {
  flex: 1;
  padding: 24rpx 40rpx 90rpx;
  overflow-y: auto;
  box-sizing: border-box;
}

/* ========== Checklist 样式 ========== */
.checklist-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.checklist-progress {
  font-size: var(--fs-26);
  color: #64748b;
}

.checklist-all {
  font-size: var(--fs-26);
  color: #2563eb;
  font-weight: 600;
  padding: 8rpx 20rpx;
  background: #eff6ff;
  border-radius: 20rpx;
}

.checklist-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.checklist-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  background: #f8fafc;
  border-radius: 16rpx;
  border: 2rpx solid #e2e8f0;
  transition: all 0.2s ease;
}

.checklist-item.is-checked {
  background: #eff6ff;
  border-color: #93c5fd;
}

.checklist-box {
  width: 40rpx;
  height: 40rpx;
  border-radius: 10rpx;
  border: 2rpx solid #cbd5e1;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content:center;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.checklist-item.is-checked .checklist-box {
  background: #2563eb;
  border-color: #2563eb;
}

.checklist-check {
  font-size: var(--fs-24);
  color: #ffffff;
  font-weight: 700;
}

/* Checklist 卡片体（三栏：类别/具体事项/备注） */
.checklist-card-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.checklist-category {
  font-size: var(--fs-28);
  font-weight: 600;
  color: #2563eb;
}

.checklist-item.is-checked .checklist-category {
  color: #1d4ed8;
}

.checklist-detail {
  font-size: var(--fs-26);
  color: #334155;
  line-height: 1.5;
}

.checklist-item.is-checked .checklist-detail {
  color: #1e40af;
}

.checklist-note {
  font-size: var(--fs-26);
  color: #94a3b8;
  line-height: 1.5;
}

/* ========== 静态内容样式 ========== */
.content-section {
  margin-bottom: 32rpx;
}

.content-section:last-child {
  margin-bottom: 0;
}

.content-category {
  font-size: var(--fs-28);
  font-weight: 500;
  color: #1e293b;
  margin-bottom: 16rpx;
  padding-left: 4rpx;
}

.content-card {
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 12rpx;
  border: 1rpx solid #e2e8f0;
}

.content-card:last-child {
  margin-bottom: 0;
}

.content-card-name {
  font-size: var(--fs-28);
  font-weight: 400;
  color: #1e293b;
  margin-bottom: 8rpx;
  word-break: break-all;
}

/* 可点击链接样式 */
.content-card-link {
  color: #2563eb;
  text-decoration: underline;
}

.content-card-link:active {
  opacity: 0.7;
}

/* 可点击电话样式 */
.content-card-phone {
  color: #16a34a;
  font-weight: 500;
}

.content-card-phone:active {
  opacity: 0.7;
}

/* 可点击邮箱样式 */
.content-card-email {
  color: #7c3aed;
  font-weight: 500;
}

.content-card-email:active {
  opacity: 0.7;
}

/* 可点击地址样式 */
.content-card-address {
  color: #ea580c;
  font-weight: 500;
}

.content-card-address:active {
  opacity: 0.7;
}

.content-card-desc {
  font-size: var(--fs-26);
  color: #64748b;
  line-height: 1.5;
  word-break: break-all;
}

