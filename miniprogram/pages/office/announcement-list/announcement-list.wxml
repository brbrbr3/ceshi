<view class="container">
  <!-- 筛选栏 -->
  <view class="filter-bar">
    <view 
      class="filter-item {{filterType === 'all' ? 'active' : ''}}" 
      bindtap="handleFilterChange" 
      data-type="all"
    >
      全部
    </view>
    <view 
      class="filter-item {{filterType === 'urgent' ? 'active' : ''}}" 
      bindtap="handleFilterChange" 
      data-type="urgent"
    >
      紧急
    </view>
    <view 
      class="filter-item {{filterType === 'important' ? 'active' : ''}}" 
      bindtap="handleFilterChange" 
      data-type="important"
    >
      重要
    </view>
    <view 
      class="filter-item {{filterType === 'normal' ? 'active' : ''}}" 
      bindtap="handleFilterChange" 
      data-type="normal"
    >
      普通
    </view>
  </view>

  <!-- 通知公告列表 -->
  <view class="list-container">
    <view 
      wx:for="{{list}}" 
      wx:key="_id" 
      class="announcement-item"
      bindtap="handleAnnouncementTap"
      data-id="{{item._id}}"
    >
      <view class="announcement-header">
        <view class="announcement-title">{{item.title}}</view>
        <view class="announcement-tag {{item.typeClass}}">{{item.typeText}}</view>
      </view>
      <view class="announcement-content">
        <text class="content-text">{{item.content}}</text>
      </view>
      <view class="announcement-footer">
        <text class="publisher">{{item.publisherName}}</text>
        <text class="time">{{item.timeText}}</text>
        <view class="read-info">
          <text class="read-count">{{item.readCount}}</text>
          <text class="read-label">人已读</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{!loading && list.length === 0}}" class="empty-state">
      <text class="empty-text">暂无通知公告</text>
    </view>
  </view>

  <!-- 发布按钮 -->
  <view class="create-btn" bindtap="handleCreate">
    <text class="create-icon">+</text>
  </view>
</view>
