/* pages/office/announcement-list/announcement-list.wxss */
.announcements-page {
  min-height: 100%;
}

/* 分页加载样式 */
.pagination-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 0;
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid #e0e0e0;
  border-top-color: #1890ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-right: 16rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.pagination-no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 0;
}

.no-more-text {
  font-size: 24rpx;
  color: #ccc;
}

.announcements-header {
  padding: 60rpx 40rpx 50rpx;
}

.announcements-title {
  font-size: 48rpx;
  font-weight: 600;
}

.announcements-subtitle {
  margin-top: 5rpx;
  font-size: 26rpx;
}

.announcements-add-btn {
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 600;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

/* 透明标签栏样式 */
.announcements-tabs-shell {
  margin-top: 30rpx;
  margin-bottom: -40rpx;
  padding: 6rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.15);
  display: flex;
}

.announcements-tab {
  flex: 1;
  height: 72rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255, 255, 255, 0.78);
  font-size: 24rpx;
}

.announcements-tab.is-active {
  background: rgba(255, 255, 255, 0.95);
  color: #2563EB;
  font-weight: 600;
}

.announcements-content {
  margin-top: -70rpx;
  padding: 0 24rpx 0;
}

/* 列表样式 */
.announcements-list {
  padding: 24rpx;
}

.announcement-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1rpx solid rgba(37, 99, 235, 0.08);
  background-color: #fff;
  transition: all 0.3s;
}

.announcement-item:active {
  background-color: rgba(37, 99, 235, 0.03);
  transform: scale(0.98);
}

.announcement-item:last-child {
  border-bottom: none;
}

.announcement-item-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.announcement-item-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.announcement-item-icon.tag-urgent {
  background-color: #FEE2E2;
  color: #DC2626;
}

.announcement-item-icon.tag-important {
  background-color: #FEF3C7;
  color: #D97706;
}

.announcement-item-icon.tag-normal {
  background-color: #E0F2FE;
  color: #0284C7;
}

.announcement-item-main {
  flex: 1;
  min-width: 0;
}

.announcement-item-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  word-wrap: break-word;
  word-break: break-all;
}

.announcement-item-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 22rpx;
  color: #94A3B8;
}

.announcement-item-time {
  color: #6B7280;
}

.announcement-item-author {
  color: #94A3B8;
}

.announcement-item-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: #EF4444;
}

.announcement-item-right {
  display: flex;
  align-items: center;
}

.announcement-item-arrow {
  font-size: 40rpx;
  color: #94A3B8;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  gap: 16rpx;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
