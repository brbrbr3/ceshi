/* pages/office/announcement-list/announcement-list.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f7fa;
  padding-bottom: 120rpx;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  background-color: #fff;
  padding: 20rpx;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
  transition: all 0.3s;
}

.filter-item.active {
  color: #2563EB;
  font-weight: 500;
}

.filter-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background-color: #2563EB;
  border-radius: 2rpx;
}

/* 列表容器 */
.list-container {
  padding: 20rpx;
}

/* 公告项 */
.announcement-item {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s;
}

.announcement-item:active {
  transform: scale(0.98);
  opacity: 0.8;
}

/* 公告头部 */
.announcement-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.announcement-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.announcement-tag {
  margin-left: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  flex-shrink: 0;
}

.tag-urgent {
  background-color: #FEE2E2;
  color: #DC2626;
}

.tag-important {
  background-color: #FEF3C7;
  color: #D97706;
}

.tag-normal {
  background-color: #E0F2FE;
  color: #0284C7;
}

/* 公告内容 */
.announcement-content {
  margin-bottom: 20rpx;
}

.content-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 公告底部 */
.announcement-footer {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999;
}

.publisher {
  margin-right: 20rpx;
}

.time {
  flex: 1;
}

.read-info {
  display: flex;
  align-items: center;
}

.read-count {
  color: #2563EB;
  font-weight: 500;
  margin-right: 4rpx;
}

.read-label {
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 创建按钮 */
.create-btn {
  position: fixed;
  bottom: 40rpx;
  right: 40rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #2563EB 0%, #1D4ED8 100%);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.4);
  z-index: 100;
  transition: all 0.3s;
}

.create-btn:active {
  transform: scale(0.9);
}

.create-icon {
  font-size: 60rpx;
  color: #fff;
  font-weight: 300;
  line-height: 1;
}
