<view class="office-page menu-detail-page" style="{{fontStyle}}">
  <view class="office-gradient-header menu-detail-header">
    <view>
      <view class="menu-detail-title">{{menu.title}}</view>
      <view class="menu-detail-meta">
        <text>{{menu.authorName}}</text>
        <text> · {{menu.timeText}}提交</text>
      </view>
    </view>
  </view>

  <view class="office-content menu-detail-content">
    <view class="office-card menu-content-card">
      <view class="menu-content-title">菜单内容</view>
      <view class="menu-content-html">
        <rich-text nodes="{{menu.content}}" user-select="{{true}}" />
      </view>

      <view class="menu-detail-actions" wx:if="{{canEdit || canDelete}}">
        <view wx:if="{{canEdit}}" class="office-btn-secondary menu-action-btn" bindtap="goEdit">修改</view>
        <view wx:if="{{canDelete}}" class="office-btn-secondary menu-action-btn is-delete" bindtap="handleDelete">删除</view>
      </view>
    </view>

    <!-- 菜品评分模块 -->
    <view class="office-section">
      <view class="office-section-header">
        <view class="office-section-title">菜品评分</view>
        <view class="office-link" wx:if="{{dishRatings.length > 0}}">{{dishRatings.length}}道菜</view>
      </view>

      <view class="office-card menu-ratings-card">
        <view wx:if="{{dishRatings.length > 0}}" class="menu-rating-list">
          <view class="menu-rating-item" wx:for="{{dishRatings}}" wx:key="dishName">
            <text class="rating-dish-name">{{item.dishName}}</text>
            <view class="rating-score-area">
              <view class="rating-stars">
                <text wx:for="{{[1,2,3,4,5]}}" wx:for-item="star" wx:key="*this" class="rating-star {{star <= item.averageScore ? 'is-filled' : ''}}">★</text>
              </view>
              <text class="rating-average">{{item.averageScore}}</text>
              <text class="rating-count">({{item.totalRaters}}人)</text>
              <text wx:if="{{item.hasRated}}" class="rating-tag is-rated">已评</text>
            </view>
          </view>
        </view>
        <view wx:if="{{dishRatings.length === 0 && !ratingsLoading}}" class="empty-state is-mini">
          <view class="empty-text">暂无打分数据</view>
        </view>
        <view wx:if="{{ratingsLoading}}" class="loading-text">加载中...</view>

        <view class="menu-rating-btn-wrap">
          <view class="office-btn-primary menu-rating-open-btn" bindtap="openRatingPopup">为菜品打分</view>
        </view>
      </view>
    </view>

    <!-- 打分弹窗 -->
    <view class="rating-popup-mask" wx:if="{{showRatingPopup}}" bindtap="closeRatingPopup" catchtouchmove="stopPropagation">
      <view class="rating-popup" catchtap="stopPropagation">
        <view class="rating-popup-header">
          <text class="rating-popup-title">菜品打分</text>
          <text class="rating-popup-close" catchtap="closeRatingPopup">×</text>
        </view>
        <scroll-view scroll-y class="rating-popup-body" catchtap="stopPropagation">
          <view class="rating-dish-item" wx:for="{{extractedDishes}}" wx:key="*this">
            <text class="rating-dish-label">{{item}}</text>
            <view class="rating-dish-stars">
              <text wx:for="{{[1,2,3,4,5]}}" wx:for-item="star" wx:key="*this" class="popup-star {{star <= (myRatedDishes[item] || tempRatings[item] || 0) ? 'is-active' : ''}}" data-dish="{{item}}" data-star="{{star}}" catchtap="handleStarTap">★</text>
            </view>
            <text wx:if="{{!myRatedDishes[item]}}" class="rating-dish-score">{{tempRatings[item] || 0}}分</text>
            <text wx:if="{{myRatedDishes[item]}}" class="rating-already-tag">已评{{myRatedDishes[item]}}星</text>
          </view>
        </scroll-view>
        <view class="rating-popup-footer">
          <view class="rating-popup-cancel" catchtap="closeRatingPopup">取消</view>
          <view class="rating-popup-submit {{hasTempRatings ? '' : 'is-disabled'}}" catchtap="submitRatings">提交打分</view>
        </view>
      </view>
    </view>

    <view class="office-section">
      <view class="office-section-header">
        <view class="office-section-title">评论</view>
        <view class="office-link">{{comments.length}}</view>
      </view>

      <view class="office-card menu-comments-card">
        <view class="menu-comment-input">
          <textarea value="{{commentText}}" bindinput="onCommentInput" placeholder="言语友善，共建和谐" placeholder-class="menu-comment-placeholder" maxlength="500" auto-height></textarea>
          <view class="menu-comment-submit">
            <text class="menu-comment-count">{{commentText.length}}/500</text>
            <view class="office-btn-primary menu-comment-btn" bindtap="submitComment">发布</view>
          </view>
        </view>

        <view wx:if="{{comments.length === 0}}" class="empty-state is-mini">
          <view class="empty-text">暂无评论，快来抢沙发吧~</view>
        </view>

        <view class="menu-comment-list">
          <view class="menu-comment-item" wx:for="{{comments}}" wx:key="_id">
            <view class="menu-comment-avatar" style="background: {{item.avatarBg}};">{{item.avatar}}</view>
            <view class="menu-comment-main">
              <view class="menu-comment-header">
                <text class="menu-comment-author">{{item.authorName}}</text>
                <text class="menu-comment-time">{{item.timeText}}</text>
              </view>
              <view class="menu-comment-text">{{item.content}}</view>
            </view>
            <view wx:if="{{item.canDelete}}" class="menu-comment-delete" bindtap="deleteComment" data-id="{{item._id}}">
              <text>删除</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>