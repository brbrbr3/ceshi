<view class="office-page home-page">
  <view class="office-gradient-header home-header">
    <view class="office-header-top">
      <view class="home-brand">
        <image wx:if="{{avatarUrl}}" class="home-user-avatar" src="{{avatarUrl}}" mode="aspectFill" />
        <view wx:else class="home-user-avatar home-user-avatar-placeholder">{{avatarText || displayName.slice(0, 1)}}</view>
        <view>
          <view class="home-brand-name">{{displayName}}</view>
          <view class="home-brand-sub">{{roleLabel}}</view>
        </view>
      </view>
      <view class="home-actions">
        <view class="office-icon-btn-wrapper" bindtap="goNotifications">
          <view class="office-icon-btn">🔔</view>
          <view wx:if="{{unreadNotificationCount > 0}}" class="office-badge">{{unreadNotificationCount}}</view>
        </view>
        <view class="office-icon-btn">⌕</view>
      </view>
    </view>

    <view class="home-greeting">{{greetingText}}</view>
    <view class="home-date">{{currentDateText}}</view>

    <view class="office-glass-card home-attendance">
      <view class="home-attendance-main">
        <view class="home-attendance-icon">⏰</view>
        <view>
          <view class="home-attendance-title">今日已打卡</view>
          <view class="home-attendance-desc">上班 08:52 · 在岗中</view>
        </view>
      </view>
      <view class="home-attendance-tag">正常</view>
    </view>
  </view>

  <view class="office-content">
    <view class="office-card home-stats-card">
      <view class="home-stats-grid">
        <view class="home-stat-item" wx:for="{{stats}}" wx:key="label">
          <view class="home-stat-badge" style="background: {{item.bg}}; color: {{item.color}};">{{item.value}}</view>
          <view class="home-stat-label">{{item.label}}</view>
        </view>
      </view>
    </view>

    <view class="office-section">
      <view class="office-section-header">
        <view class="office-section-title">常用功能</view>
        <view class="office-link" bindtap="showComingSoon">全部</view>
      </view>
      <view class="office-card home-grid-card">
        <view class="home-grid">
          <view class="home-grid-item" wx:for="{{quickActions}}" wx:key="label" bindtap="handleQuickAction" data-label="{{item.label}}">
            <view class="home-grid-icon" style="background: {{item.bg}}; color: {{item.color}};">{{item.icon}}</view>
            <view class="home-grid-label">{{item.label}}</view>
          </view>
        </view>
      </view>
    </view>

    <view class="office-section">
      <view class="office-section-header">
        <view class="home-title-with-badge">
          <view class="office-section-title">待我审批</view>
          <view class="home-count-badge">{{pendingApprovalCount}}</view>
        </view>
        <view class="office-link" bindtap="goApprovalTab">查看全部</view>
      </view>
      <view class="office-card home-list-card">
        <view class="home-list-item" wx:for="{{approvals}}" wx:key="name">
          <view class="office-avatar" style="background: {{item.avatarBg}};">{{item.avatar}}</view>
          <view class="home-list-main">
            <view class="home-list-title-row">
              <view class="home-list-name">{{item.name}}</view>
              <view class="home-dot">·</view>
              <view class="home-list-sub">{{item.dept}}</view>
            </view>
            <view class="home-list-type">{{item.type}}</view>
          </view>
          <view class="home-list-side">
            <view class="home-list-time">{{item.time}}</view>
            <view class="office-btn-secondary home-mini-btn" bindtap="goApprovalTab">审批</view>
          </view>
        </view>
      </view>
    </view>

    <view class="office-section">
      <view class="office-section-header">
        <view class="office-section-title">公司公告</view>
        <view class="office-link" bindtap="showComingSoon">更多</view>
      </view>
      <view class="office-card home-news-card">
        <view class="home-news-item" wx:for="{{announcements}}" wx:key="title">
          <view class="office-pill home-news-tag" style="background: {{item.tagBg}}; color: {{item.tagColor}};">{{item.tag}}</view>
          <view class="home-news-main">
            <view class="home-news-title {{!item.unread ? 'is-read' : ''}}">{{item.title}}</view>
            <view class="home-news-time">{{item.time}}</view>
          </view>
          <view wx:if="{{item.unread}}" class="home-news-dot"></view>
        </view>
      </view>
    </view>

    <view class="office-section">
      <view class="office-section-header">
        <view class="office-section-title">今日日程</view>
        <view class="office-link" bindtap="showComingSoon">日历</view>
      </view>
      <view class="office-card home-schedule-card">
        <view class="home-schedule-item" wx:for="{{schedules}}" wx:key="title">
          <view class="home-schedule-time">{{item.time}}</view>
          <view class="home-schedule-line" style="background: {{item.color}};"></view>
          <view class="home-schedule-main">
            <view class="home-schedule-title">{{item.title}}</view>
            <view class="office-pill home-schedule-type" style="background: {{item.bg}}; color: {{item.color}};">{{item.type}}</view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
