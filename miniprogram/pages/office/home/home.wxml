<view class="office-page home-page">
  <view class="office-gradient-header home-header">
    <view class="office-header-top">
      <view class="home-brand">
        <image wx:if="{{avatarUrl}}" class="home-user-avatar" src="{{avatarUrl}}" mode="aspectFill" />
        <view wx:else class="home-user-avatar home-user-avatar-placeholder">{{avatarText || displayName.slice(0, 1)}}</view>
        <view>
          <view class="home-brand-name">{{displayName}}</view>
          <view class="home-brand-sub">{{roleLabel}}</view>
        </view>
      </view>
    </view>

    <!--欢迎词 + 通知、搜索图标-->
    <view class="home-greeting-row">
      <view class="home-greeting">{{greetingText}}</view>
      <view class="home-actions">
        <view class="office-icon-btn-wrapper" bindtap="goNotifications">
          <view class="office-icon-btn">🔔</view>
          <view wx:if="{{unreadNotificationCount > 0}}" class="office-badge">{{unreadNotificationCount}}</view>
        </view>
        <view class="office-icon-btn" bindtap="showComingSoon">🔎</view>
      </view>
    </view>
    <!-- <view class="home-date">{{currentDateText}}</view> -->

    <!--全馆日程模块-->
    <view class="office-glass-card home-calendar" bindtap="goCalendar">
      <view class="home-calendar-main">
        <view class="home-calendar-icon">📅</view>
        <view>
          <view class="home-calendar-title">{{currentDateText}}</view>
          <view class="home-calendar-desc">{{todayTypeText}}</view>
        </view>
      </view>
      <view class="home-calendar-tag">全馆日程</view>
    </view>
  </view>

  <!--数据板-->
  <view class="office-content">
    <view class="office-card home-stats-card">
      <view class="home-stats-grid">
        <view class="home-stat-item" wx:for="{{stats}}" wx:key="label">
          <view class="home-stat-badge" style="background: {{item.bg}}; color: {{item.color}};">{{item.value}}</view>
          <view class="home-stat-label">{{item.label}}</view>
        </view>
      </view>
    </view>

    <!--常用功能（所有图标对所有人可见）-->
    <view class="office-section">
      <view class="office-section-header">
        <view class="office-section-title">常用功能</view>
        <view class="office-link" bindtap="showComingSoon">全部</view>
      </view>
      <view class="office-card home-grid-card">
        <view class="home-grid">
          <view wx:for="{{quickActions}}" wx:key="label" class="home-grid-item" bindtap="handleQuickAction" data-label="{{item.label}}" data-feature="{{item.featureKey}}">
            <view class="home-grid-icon {{item.implemented === false ? 'is-implemented' : ''}}" style="background: {{item.bg}}; color: {{item.color}};">{{item.icon}}</view>
            <view class="home-grid-label {{item.implemented === false ? 'is-implemented' : ''}}">{{item.label}}</view>
          </view>
        </view>
      </view>
    </view>

    <!--通知公告-->
    <view class="office-section">
      <view class="office-section-header">
        <view class="office-section-title">通知公告</view>
        <view class="office-link" bindtap="goAnnouncements">更多</view>
      </view>
      <view class="office-card home-news-card">
        <view class="home-news-item" wx:for="{{announcements}}" wx:key="_id" bindtap="handleAnnouncementTap" data-id="{{item._id}}">
          <view class="office-pill home-news-tag" style="background: {{item.tagBg}}; color: {{item.tagColor}};">{{item.tag}}</view>
          <view class="home-news-main">
            <view class="home-news-title {{!item.unread ? 'is-read' : ''}}">{{item.title}}</view>
            <view class="home-news-time">{{item.time}}</view>
          </view>
          <view wx:if="{{item.unread}}" class="home-news-dot"></view>
        </view>
        <view wx:if="{{!loading && announcements.length === 0}}" class="empty-announcement">
          <text class="empty-text">暂无通知公告</text>
        </view>
      </view>
    </view>

    <!--今日日程-->
    <view class="office-section">
      <view class="office-section-header">
        <view class="office-section-title">今日日程</view>
        <view class="office-link" bindtap="goCalendar">日历</view>
      </view>
      <view class="office-card home-schedule-card">
        <view class="home-schedule-item" wx:for="{{todaySchedules}}" wx:key="_id" bindtap="handleScheduleTap" data-schedule="{{item}}">
          <view class="home-schedule-time">{{item.startTime || '全天'}}</view>
          <view class="home-schedule-line" style="background: {{item.color}};"></view>
          <view class="home-schedule-main">
            <view class="home-schedule-title">{{item.title}}</view>
            <view class="office-pill home-schedule-type" style="background: {{item.typeBg}}; color: {{item.color}};">{{item.typeName}}</view>
          </view>
        </view>
        <view wx:if="{{!loadingSchedules && todaySchedules.length === 0}}" class="empty-schedule">
          <text class="empty-text">暂无订阅的日程</text>
        </view>
        <view wx:if="{{loadingSchedules}}" class="loading-schedule">
          <text class="empty-text">加载中...</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 日程详情弹窗 -->
  <view class="detail-popup-mask {{showScheduleDetail ? 'is-visible' : ''}}" catchtouchmove="stopPropagation" bindtap="hideScheduleDetail">
    <view class="detail-popup-container" catchtap="stopPropagation">
      <!-- 弹窗头部 -->
      <view class="detail-popup-header">
        <view class="detail-popup-close" bindtap="hideScheduleDetail">×</view>
        <view class="detail-popup-title">日程详情</view>
        <view class="detail-popup-unsubscribe" bindtap="handleUnsubscribe">取消订阅</view>
      </view>

      <!-- 详情内容 -->
      <scroll-view class="detail-popup-scroll" scroll-y="true" enhanced="true" show-scrollbar="false">
        <view class="detail-popup-content" wx:if="{{detailSchedule}}">
          <!-- 标题区域 -->
          <view class="detail-header">
            <view class="detail-type-dot" style="background: {{detailSchedule.color}};"></view>
            <text class="detail-title">{{detailSchedule.title}}</text>
            <text class="detail-type-name">{{detailSchedule.typeName}}</text>
          </view>

          <!-- 时间信息 -->
          <view class="detail-section">
            <view class="detail-section-title">时间</view>
            <view class="detail-time-info">
              <view class="detail-time-row" wx:if="{{detailSchedule.isAllDay}}">
                <text class="detail-time-label">全天</text>
                <text class="detail-time-value">{{detailSchedule.startDate}}</text>
              </view>
              <view class="detail-time-row" wx:else>
                <text class="detail-time-label">开始</text>
                <text class="detail-time-value">{{detailSchedule.startDate}} {{detailSchedule.startTime}}</text>
              </view>
              <view class="detail-time-row" wx:if="{{!detailSchedule.isAllDay}}">
                <text class="detail-time-label">结束</text>
                <text class="detail-time-value">{{detailSchedule.endDate}} {{detailSchedule.endTime}}</text>
              </view>
            </view>
          </view>

          <!-- 地点 -->
          <view class="detail-section" wx:if="{{detailSchedule.location}}">
            <view class="detail-section-title">地点</view>
            <text class="detail-section-value">{{detailSchedule.location}}</text>
          </view>

          <!-- 备注 -->
          <view class="detail-section" wx:if="{{detailSchedule.description}}">
            <view class="detail-section-title">备注</view>
            <text class="detail-section-value">{{detailSchedule.description}}</text>
          </view>

          <!-- 创建者 -->
          <view class="detail-section" wx:if="{{detailSchedule.creatorName}}">
            <view class="detail-section-title">创建者</view>
            <text class="detail-section-value">{{detailSchedule.creatorName}}</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>
</view>