page {
  background: #EEF2FF;
}

/* 从 app.wxss 迁移的样式 - 仅本页面使用 */
.office-glass-card {
  background: rgba(255, 255, 255, 0.1);
  border: 3rpx solid rgba(255, 255, 255, 0.48);
  box-shadow: 3rpx 3rpx 2rpx rgba(255, 255, 255, 0.42);
  backdrop-filter: blur(15px);
}

.office-icon-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.16);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: var(--fs-28);
}

.home-header {
  height: 30%;
  padding-bottom: 40rpx;
  position: relative;
  overflow: hidden;
}

/* 背景装饰图片 */
.home-bg-image-wrapper {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  width: 100%;
  z-index: 0;
  pointer-events: none;
}

.home-bg-image {
  width: 100%;
  display: block;
  border-radius: 0;
  -webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,0) 0%, rgba(0,0,0,1) 20%);
  /* mask-image: linear-gradient(to bottom, rgba(0,0,0,0) 0%, rgba(0,0,0,1) 100%); */
}

