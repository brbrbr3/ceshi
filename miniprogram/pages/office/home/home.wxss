.home-brand {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.home-brand-mark {
  width: 64rpx;
  height: 64rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  font-size: var(--fs-28);
  font-weight: 700;
}

.home-brand-name {
  font-size: var(--fs-22);
  opacity: 0.84;
}

.home-brand-sub {
  margin-top: 6rpx;
  font-size: var(--fs-20);
  opacity: 0.72;
}

.home-actions {
  display: flex;
  gap: 16rpx;
  flex-shrink: 0;
}

.home-greeting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
  position: relative;
  z-index: 1;
}

.office-icon-btn-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}

.home-icon-btn-ntf{
  border: 1rpx solid rgba(0, 0, 0, 0.238);
  border-radius: 100rpx;
}

.office-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 10rpx;
  border-radius: 16rpx;
  background: #F44336;
  color: #FFFFFF;
  font-size: var(--fs-18);
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  box-shadow: 0 2rpx 8rpx rgba(244, 67, 54, 0.3);
}

.home-greeting {
  font-size: var(--fs-40);
  font-weight: 600;
}

.home-calendar {
  border: 3rpx solid rgba(0, 0, 0, 0.238);
  margin: -15rpx 0 0;
  border-radius: 28rpx;
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  z-index: 1;
}

.home-calendar-main {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.home-calendar-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--fs-70);
}

.home-calendar-title {
  font-size: var(--fs-28);
  font-weight: 600;
}

.home-calendar-desc {
  margin-top: 6rpx;
  font-size: var(--fs-22);
}

.home-calendar-tag {
  min-width: 96rpx;
  padding: 14rpx 26rpx;
  border-radius: 999rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.1);
  font-size: var(--fs-22);
  font-weight: 600;
  border: 1px solid rgba(0, 0, 0, 0.238);
}

.home-stats-card {
  padding: 145rpx 0 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  z-index: 1;
}

.home-stats-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 26rpx 12rpx;
  height: 100%;
  width: 100%;
}

.home-stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 17%;
  box-sizing: border-box;
  border-radius: 25rpx;
  padding: 0 0 20rpx;
}

.home-stat-item.stat-clickable {
  cursor: pointer;
  transition: opacity 0.2s;
}

.home-stat-item.stat-clickable:active {
  opacity: 0.7;
}

.home-stat-badge {
  min-width: 76rpx;
  height: 76rpx;
  padding: 10rpx 10rpx 0;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--fs-40);
  font-weight: 700;
}

.home-stat-label {
  font-size: var(--fs-26);
  color: #ffffff;
}

.home-grid-card,
.home-list-card,
.home-news-card,
.home-schedule-card {
  padding: 24rpx;
}

.home-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 26rpx 12rpx;
}

.home-grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 23.6%;
  box-sizing: border-box;
}

.home-grid-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--fs-66);
}

.home-grid-icon.is-implemented {
  background: #F1F5F9 !important;
  color: #94A3B8 !important;
}

.home-grid-label {
  margin-top: 14rpx;
  font-size: var(--fs-26);
  color: #4B6080;
  text-align: center;
  line-height: 1.4;
}

.home-grid-label.is-implemented {
  color: #94A3B8;
}

.home-title-with-badge {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.home-count-badge {
  min-width: 34rpx;
  height: 34rpx;
  border-radius: 17rpx;
  background: #F44336;
  color: #FFFFFF;
  font-size: var(--fs-20);
  display: flex;
  align-items: center;
  justify-content: center;
}

.home-list-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 18rpx 0;
}

.home-list-item + .home-list-item {
  border-top: 1rpx solid rgba(37, 99, 235, 0.1);
}

.home-list-main {
  flex: 1;
  min-width: 0;
}

.home-list-title-row {
  display: flex;
  align-items: center;
  margin-bottom: 6rpx;
}

.home-list-name {
  font-size: var(--fs-26);
  font-weight: 600;
  color: #1E293B;
}

.home-dot,
.home-list-sub {
  font-size: var(--fs-22);
  color: #94A3B8;
  margin-left: 8rpx;
}

.home-list-type {
  font-size: var(--fs-24);
  color: #4B6080;
}

.home-list-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.home-list-time {
  font-size: var(--fs-20);
  color: #94A3B8;
}

.home-mini-btn {
  padding: 10rpx 20rpx;
  font-size: var(--fs-20);
}

.home-news-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 18rpx 0;
}

.home-news-item + .home-news-item {
  border-top: 1rpx solid rgba(37, 99, 235, 0.1);
}

.home-news-tag {
  margin-top: 2rpx;
}

.home-news-main {
  flex: 1;
  min-width: 0;
}

.home-news-title {
  font-size: var(--fs-26);
  color: #1E293B;
  line-height: 1.45;
}

.home-news-title.is-read {
  color: #94A3B8;
}

.home-news-time {
  margin-top: 10rpx;
  font-size: var(--fs-20);
  color: #94A3B8;
}

.home-news-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #F44336;
  margin-top: 12rpx;
}

.home-schedule-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.home-schedule-item + .home-schedule-item {
  margin-top: 22rpx;
}

.home-schedule-time {
  width: 80rpx;
  text-align: right;
  font-size: var(--fs-22);
  color: #94A3B8;
}

.home-schedule-line {
  width: 8rpx;
  height: 54rpx;
  border-radius: 999rpx;
}

.home-schedule-main {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.home-schedule-title {
  font-size: var(--fs-24);
  color: #1E293B;
}

.home-schedule-type {
  flex-shrink: 0;
}

.empty-announcement {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx 0;
}

.empty-text {
  font-size: var(--fs-26);
  color: #94A3B8;
}

/* 学习园地首页模块 */
.home-learning-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--fs-28);
  background: linear-gradient(135deg, #FEE2E2, #FECACA);
  flex-shrink: 0;
  margin-top: 2rpx;
}

.home-learning-pinned {
  display: inline-block;
  font-size: var(--fs-18);
  color: #FFFFFF;
  background: linear-gradient(135deg, #DC2626, #B91C1C);
  padding: 0 8rpx;
  border-radius: 4rpx;
  margin-right: 6rpx;
  vertical-align: middle;
  line-height: 1.4;
}

/* 群团活动首页模块 */
.home-activity-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--fs-28);
  background: linear-gradient(135deg, #EDE9FE, #DDD6FE);
  flex-shrink: 0;
  margin-top: 2rpx;
}

.activity-home-tag {
  flex-shrink: 0;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-size: var(--fs-20);
  font-weight: 500;
}

.tag-active {
  color: #10B981;
  background: #D1FAE5;
}

.tag-ended {
  color: #94A3B8;
  background: #F1F5F9;
}

/* 空状态 */
.empty-schedule,
.loading-schedule {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx 0;
}

/* ========================================
   日程详情弹窗样式
   ======================================== */

/* 弹窗遮罩 */
.detail-popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 10000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.detail-popup-mask.is-visible {
  opacity: 1;
  visibility: visible;
}

/* 弹窗容器 */
.detail-popup-container {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #F8FAFC;
  border-radius: 32rpx 32rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}

.detail-popup-mask.is-visible .detail-popup-container {
  transform: translateY(0);
}

/* 弹窗头部 */
.detail-popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #E2E8F0;
  border-radius: 32rpx 32rpx 0 0;
  flex-shrink: 0;
}

.detail-popup-close {
  font-size: var(--fs-48);
  color: #64748B;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-popup-title {
  font-size: var(--fs-32);
  font-weight: 600;
  color: #1E293B;
  padding-left: 40rpx;
}

.detail-popup-unsubscribe {
  font-size: var(--fs-26);
  color: #EF4444;
  font-weight: 500;
}

/* 详情滚动区域 */
.detail-popup-scroll {
  flex: 1;
  height: 0;
  overflow: hidden;
}

.detail-popup-content {
  padding: 24rpx;
}

/* 标题区域 */
.detail-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
  flex-wrap: wrap;
}

.detail-type-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.detail-title {
  font-size: var(--fs-32);
  font-weight: 600;
  color: #1E293B;
  line-height: 1.4;
}

.detail-type-name {
  font-size: var(--fs-24);
  color: #64748B;
  background: #F1F5F9;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

/* 详情区块 */
.detail-section {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 16rpx;
}

.detail-section-title {
  font-size: var(--fs-24);
  color: #94A3B8;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.detail-section-value {
  font-size: var(--fs-28);
  color: #1E293B;
  line-height: 1.6;
}

/* 时间信息 */
.detail-time-info {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.detail-time-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.detail-time-label {
  font-size: var(--fs-26);
  color: #64748B;
  width: 80rpx;
  flex-shrink: 0;
}

.detail-time-value {
  font-size: var(--fs-26);
  color: #1E293B;
}
