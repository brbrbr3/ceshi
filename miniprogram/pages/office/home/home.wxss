page {
  background: #EEF2FF;
}

.home-header {
  padding-bottom: 176rpx;
}

.home-brand {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.home-brand-mark {
  width: 64rpx;
  height: 64rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  font-size: 28rpx;
  font-weight: 700;
}

.home-brand-name {
  font-size: 22rpx;
  opacity: 0.84;
}

.home-brand-sub {
  margin-top: 6rpx;
  font-size: 20rpx;
  opacity: 0.72;
}

.home-actions {
  display: flex;
  gap: 16rpx;
}

.office-icon-btn-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}

.office-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 10rpx;
  border-radius: 16rpx;
  background: #F44336;
  color: #FFFFFF;
  font-size: 18rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  box-shadow: 0 2rpx 8rpx rgba(244, 67, 54, 0.3);
}

.home-greeting {
  margin-top: 32rpx;
  font-size: 40rpx;
  font-weight: 600;
}

.home-date {
  margin-top: 10rpx;
  font-size: 24rpx;
  opacity: 0.78;
}

.home-attendance {
  margin-top: 28rpx;
  border-radius: 28rpx;
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.home-attendance-main {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.home-attendance-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.16);
  font-size: 28rpx;
}

.home-attendance-title {
  font-size: 28rpx;
  font-weight: 600;
}

.home-attendance-desc {
  margin-top: 6rpx;
  font-size: 22rpx;
  opacity: 0.74;
}

.home-attendance-tag {
  min-width: 96rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.16);
  font-size: 22rpx;
  font-weight: 600;
}

.home-stats-card {
  padding: 28rpx 20rpx;
}

.home-stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}

.home-stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.home-stat-item.stat-clickable {
  cursor: pointer;
  transition: opacity 0.2s;
}

.home-stat-item.stat-clickable:active {
  opacity: 0.7;
}

.home-stat-badge {
  min-width: 76rpx;
  height: 76rpx;
  padding: 0 10rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
}

.home-stat-label {
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #94A3B8;
}

.home-grid-card,
.home-list-card,
.home-news-card,
.home-schedule-card {
  padding: 24rpx;
}

.home-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 26rpx 12rpx;
}

.home-grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.home-grid-icon {
  width: 92rpx;
  height: 92rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
}

.home-grid-icon.is-implemented {
  background: #F1F5F9 !important;
  color: #94A3B8 !important;
}

.home-grid-label {
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #4B6080;
  text-align: center;
  line-height: 1.4;
}

.home-grid-label.is-implemented {
  color: #94A3B8;
}

.home-title-with-badge {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.home-count-badge {
  min-width: 34rpx;
  height: 34rpx;
  border-radius: 17rpx;
  background: #F44336;
  color: #FFFFFF;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.home-list-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 18rpx 0;
}

.home-list-item + .home-list-item {
  border-top: 1rpx solid rgba(37, 99, 235, 0.1);
}

.home-list-main {
  flex: 1;
  min-width: 0;
}

.home-list-title-row {
  display: flex;
  align-items: center;
  margin-bottom: 6rpx;
}

.home-list-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1E293B;
}

.home-dot,
.home-list-sub {
  font-size: 22rpx;
  color: #94A3B8;
  margin-left: 8rpx;
}

.home-list-type {
  font-size: 24rpx;
  color: #4B6080;
}

.home-list-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.home-list-time {
  font-size: 20rpx;
  color: #94A3B8;
}

.home-mini-btn {
  padding: 10rpx 20rpx;
  font-size: 20rpx;
}

.home-news-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 18rpx 0;
}

.home-news-item + .home-news-item {
  border-top: 1rpx solid rgba(37, 99, 235, 0.1);
}

.home-news-tag {
  margin-top: 2rpx;
}

.home-news-main {
  flex: 1;
  min-width: 0;
}

.home-news-title {
  font-size: 26rpx;
  color: #1E293B;
  line-height: 1.45;
}

.home-news-title.is-read {
  color: #94A3B8;
}

.home-news-time {
  margin-top: 10rpx;
  font-size: 20rpx;
  color: #94A3B8;
}

.home-news-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #F44336;
  margin-top: 12rpx;
}

.home-schedule-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.home-schedule-item + .home-schedule-item {
  margin-top: 22rpx;
}

.home-schedule-time {
  width: 80rpx;
  text-align: right;
  font-size: 22rpx;
  color: #94A3B8;
}

.home-schedule-line {
  width: 8rpx;
  height: 54rpx;
  border-radius: 999rpx;
}

.home-schedule-main {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.home-schedule-title {
  font-size: 24rpx;
  color: #1E293B;
}

.home-schedule-type {
  flex-shrink: 0;
}
