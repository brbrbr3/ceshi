/* pages/office/announcement-detail/announcement-detail.wxss */
.announcement-detail-page {
  min-height: 100%;
}

/* 加载状态 */
.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid #e0e0e0;
  border-top-color: #1890ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
  margin-left: 16rpx;
}

/* 头部样式 */
.detail-header {
  padding-bottom: 100rpx;
}

.detail-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.detail-subtitle {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.detail-content {
  margin-top: -60rpx;
  padding: 0 24rpx;
}

/* 详情卡片 */
.detail-card {
  padding: 32rpx;
}

/* 详情标签 */
.detail-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.detail-tag {
  padding: 6rpx 20rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.detail-tag.tag-urgent {
  background-color: #FEE2E2;
  color: #DC2626;
}

.detail-tag.tag-important {
  background-color: #FEF3C7;
  color: #D97706;
}

.detail-tag.tag-normal {
  background-color: #E0F2FE;
  color: #0284C7;
}

.status-tag {
  padding: 6rpx 20rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
  background-color: #F3F4F6;
  color: #6B7280;
}

/* 详情元数据 */
.detail-meta {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  font-size: 26rpx;
}

.meta-label {
  color: #94A3B8;
  margin-right: 12rpx;
}

.meta-value {
  color: #1E293B;
  font-weight: 500;
}

/* 分隔线 */
.detail-divider {
  height: 1rpx;
  background-color: rgba(37, 99, 235, 0.08);
  margin: 24rpx 0;
}

/* 详情内容 */
.detail-body {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.body-text {
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
}

/* 操作区域 */
.detail-actions {
  padding: 24rpx;
}

.btn-revoke {
  width: 100%;
  background-color: #DC2626;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  font-size: 32rpx;
  padding: 24rpx 0;
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.3);
}

.btn-revoke:active {
  background-color: #B91C1C;
}
