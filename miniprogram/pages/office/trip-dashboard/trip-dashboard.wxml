<view class="dashboard-page" style="{{fontStyle}}">
  <!-- 渐变色头部（带圆角，类似home页） -->
  <view class="office-gradient-header dashboard-header">
    <view class="dashboard-header-content">
      <view class="dashboard-title">出行数据板</view>
      <view class="dashboard-subtitle">查看团队出行情况</view>
    </view>
  </view>

  <view class="dashboard-content">
    <!-- 筛选区域 -->
    <view class="dashboard-filter">
      <picker wx:if="{{departmentOptions.length > 1}}" mode="selector" range="{{departmentOptions}}" value="{{selectedDepartment === 'all' ? 0 : departmentOptions.indexOf(selectedDepartment)}}" bindchange="handleDepartmentChange">
        <view class="dashboard-filter-picker">
          <text>{{selectedDepartment === 'all' ? '全部部门' : selectedDepartment}}</text>
          <text class="dashboard-filter-arrow">▼</text>
        </view>
      </picker>
      <view wx:else class="dashboard-filter-picker">
        <text>{{departmentOptions[0]}}</text>
      </view>
      <picker mode="selector" range="{{timeRangeOptions}}" value="{{selectedTimeRangeIndex}}" bindchange="handleTimeRangeChange">
        <view class="dashboard-filter-picker dashboard-filter-time">
          <text>{{timeRangeOptions[selectedTimeRangeIndex]}}</text>
          <text class="dashboard-filter-arrow">▼</text>
        </view>
      </picker>
    </view>

    <!-- Tab 切换 -->
    <view class="dashboard-tabs">
      <view class="dashboard-tab {{activeTab === 'overview' ? 'is-active' : ''}}" data-tab="overview" bindtap="handleTabChange">今日概览</view>
      <view class="dashboard-tab {{activeTab === 'records' ? 'is-active' : ''}}" data-tab="records" bindtap="handleTabChange">出行记录</view>
      <view class="dashboard-tab {{activeTab === 'stats' ? 'is-active' : ''}}" data-tab="stats" bindtap="handleTabChange">统计</view>
    </view>

    <!-- 今日概览 -->
    <view wx:if="{{activeTab === 'overview'}}" class="dashboard-overview">
      <!-- 统计卡片 -->
      <view class="dashboard-stats-grid">
        <view class="dashboard-stat-card">
          <view class="dashboard-stat-value">{{todayOverview.totalOut}}</view>
          <view class="dashboard-stat-label">当前{{(selectedDepartment === 'all' ? '全体' : selectedDepartment)}}外出人数</view>
        </view>
        <view class="dashboard-stat-card">
          <view class="dashboard-stat-value">{{statistics.total}}</view>
          <view class="dashboard-stat-label">{{statTimeRangeLabel || '本月'}}{{(selectedDepartment === 'all' ? '全体' : selectedDepartment)}}出行次数</view>
        </view>
      </view>

      <!-- 当前外出人员 -->
      <view class="dashboard-section">
        <view class="dashboard-section-title">当前外出人员</view>
        <view class="dashboard-active-list">
          <view wx:if="{{todayOverview.activeTrips.length === 0}}" class="dashboard-empty">
            <text class="dashboard-empty-text">暂无外出人员</text>
          </view>
          <view wx:for="{{todayOverview.activeTrips}}" wx:key="_id" class="dashboard-active-item">
            <view class="office-avatar dashboard-active-avatar" style="background: {{item.avatarColor}};">{{item.avatarText}}</view>
            <view class="dashboard-active-info">
              <view class="dashboard-active-name">{{item.userName}}</view>
              <view class="dashboard-active-dest">{{item.destination}}</view>
            </view>
            <view class="dashboard-active-meta">
              <view class="dashboard-active-mode">🚗 {{item.travelMode}}</view>
              <view class="dashboard-active-time">预计 {{item.plannedReturnText || '--'}}</view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 出行记录 -->
    <view wx:if="{{activeTab === 'records'}}" class="dashboard-records">
      <view class="dashboard-list">
        <view wx:for="{{tripList}}" wx:key="_id" class="dashboard-item">
          <view class="dashboard-item-header">
            <view class="dashboard-item-user">
              <view class="office-avatar dashboard-item-avatar" style="background: {{item.avatarColor}};">{{item.avatarText}}</view>
              <view>
                <view class="dashboard-item-name">{{item.userName}}</view>
                <view class="dashboard-item-dept">{{item.department || '未知部门'}}</view>
              </view>
            </view>
            <view class="dashboard-item-status" style="background: {{item.statusBg}}; color: {{item.statusColor}};">
              {{item.statusIcon}} {{item.statusText}}
            </view>
          </view>
          <view class="dashboard-item-body">
            <view class="dashboard-item-row">
              <text class="dashboard-item-label">目的地</text>
              <text class="dashboard-item-value">{{item.destination}}</text>
            </view>
            <view class="dashboard-item-row">
              <text class="dashboard-item-label">时间</text>
              <text class="dashboard-item-value">{{item.dateText}} {{item.timeRange}}</text>
            </view>
            <view class="dashboard-item-row">
              <text class="dashboard-item-label">方式</text>
              <text class="dashboard-item-value">{{item.travelMode}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 空状态 -->
      <view wx:if="{{!loading && tripList.length === 0}}" class="dashboard-empty-state">
        <view class="dashboard-empty-icon">📋</view>
        <view class="dashboard-empty-text">暂无出行记录</view>
      </view>

      <!-- 加载更多 -->
      <view wx:if="{{loading}}" class="dashboard-loading">
        <text>加载中...</text>
      </view>
    </view>

    <!-- 统计 -->
    <view wx:if="{{activeTab === 'stats'}}" class="dashboard-stats">
      <!-- 状态统计 -->
      <view class="dashboard-section">
        <view class="dashboard-section-title">状态统计</view>
        <view class="dashboard-status-grid">
          <view class="dashboard-status-item">
            <view class="dashboard-status-value" style="color: #2563EB;">{{statistics.byStatus.out || 0}}</view>
            <view class="dashboard-status-label">外出中</view>
          </view>
          <view class="dashboard-status-item">
            <view class="dashboard-status-value" style="color: #16A34A;">{{statistics.byStatus.returned || 0}}</view>
            <view class="dashboard-status-label">已返回</view>
          </view>
          <view class="dashboard-status-item">
            <view class="dashboard-status-value" style="color: #DC2626;">{{statistics.byStatus.overtime || 0}}</view>
            <view class="dashboard-status-label">超时</view>
          </view>
        </view>
      </view>

      <!-- 出行方式统计 -->
      <view class="dashboard-section">
        <view class="dashboard-section-title">出行方式分布</view>
        <view class="dashboard-chart-bars">
          <view wx:for="{{chartData.modeLabels}}" wx:for-index="idx" wx:for-item="label" wx:key="label" class="dashboard-chart-bar-item">
            <view class="dashboard-chart-bar-label">{{label}}</view>
            <view class="dashboard-chart-bar-wrapper">
              <view class="dashboard-chart-bar" style="width: {{chartData.modePercentages[idx]}}%;"></view>
              <text class="dashboard-chart-bar-value">{{chartData.modeValues[idx]}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 部门统计 -->
      <view class="dashboard-section">
        <view class="dashboard-section-title">部门出行统计</view>
        <view class="dashboard-chart-bars">
          <view wx:for="{{chartData.deptLabels}}" wx:for-index="idx" wx:for-item="label" wx:key="label" class="dashboard-chart-bar-item">
            <view class="dashboard-chart-bar-label">{{label}}</view>
            <view class="dashboard-chart-bar-wrapper">
              <view class="dashboard-chart-bar dashboard-chart-bar--dept" style="width: {{chartData.deptPercentages[idx]}}%;"></view>
              <text class="dashboard-chart-bar-value">{{chartData.deptValues[idx]}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 个人出行排行（uCharts 柱形图） -->
      <view wx:if="{{chartData.personCategories.length > 0}}" class="dashboard-section">
        <view class="dashboard-section-title">个人出行排行</view>
        <view class="dashboard-person-charts">
          <canvas canvas-id="personChart" id="personChart" class="dashboard-person-charts" bindtouchend="tapPersonChart"/>
        </view>
      </view>
    </view>
  </view>
</view>
