<view class="office-page learning-page">
  <!-- 红色渐变头部 -->
  <view class="learning-header office-gradient-header">
    <view class="office-header-top">
      <view>
        <view class="learning-title">学习园地</view>
        <view class="learning-subtitle">分享知识，共同进步</view>
      </view>
      <view class="learning-add-btn" bindtap="handleCreate">
        <text>+ 发布文章</text>
      </view>
    </view>
  </view>

  <!-- 列表内容 -->
  <view class="learning-content">

    <view class="office-card learning-list" wx:if="{{list.length > 0}}">
      <view class="swipe-wrapper" wx:for="{{list}}" wx:key="_id">
        <!-- 操作按钮层 -->
        <view class="swipe-actions">
          <view class="swipe-action swipe-action-pin" bindtap="handlePin" data-id="{{item._id}}">
            <text>{{item.isPinned ? '取消↑' : '置顶↑'}}</text>
          </view>
          <view class="swipe-action swipe-action-delete" bindtap="handleDelete" data-id="{{item._id}}">
            <text>删除×</text>
          </view>
        </view>
        <!-- 内容层 -->
        <view
          class="swipe-content"
          style="transform: translateX({{swipeX[item._id] || 0}}px); transition: transform 0.3s;"
          bindtouchstart="handleTouchStart"
          bindtouchmove="handleTouchMove"
          bindtouchend="handleTouchEnd"
          data-id="{{item._id}}"
        >
          <view class="article-item" bindtap="handleItemTap" data-id="{{item._id}}">
            <view class="article-item-left">
              <view class="article-item-icon">
                <text wx:if="{{item.isPinned}}">📌</text>
                <text wx:else>📖</text>
              </view>
              <view class="article-item-main">
                <view class="article-item-title">
                  <text wx:if="{{item.isPinned}}" class="pinned-badge">置顶</text>
                  {{item.title}}
                </view>
                <view class="article-item-desc" wx:if="{{item.plainText}}">{{item.plainText}}</view>
                <view class="article-item-meta">
                  <text class="article-item-author">{{item.authorName}}</text>
                  <text class="article-item-time">{{item.timeText}}</text>
                  <text class="article-item-views">{{item.readCount || 0}} 阅读</text>
                </view>
              </view>
            </view>
            <view class="article-item-right">
              <view class="article-item-arrow">›</view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 分页加载状态 -->
    <view class="pagination-loading" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <view class="pagination-no-more" wx:elif="{{!hasMore && list.length > 0}}">
      <text class="no-more-text">没有更多数据了</text>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:elif="{{list.length === 0 && !loading}}">
      <view class="empty-icon">📚</view>
      <view class="empty-text">暂无学习文章</view>
      <view class="empty-hint">点击右上角发布第一篇</view>
    </view>
  </view>
</view>
