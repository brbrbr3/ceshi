<view class="office-page announcement-create-page">
  <view class="office-gradient-header announcement-create-header">
    <view class="announcement-create-title">发布新通知</view>
  </view>

  <view class="office-content announcement-create-content">
    <view class="office-card announcement-create-form">
      <view class="auth-form">
        <!-- 通知类型 -->
        <view class="auth-field">
          <view class="auth-field-label">
            通知类型
            <text class="auth-field-required">*</text>
          </view>
          <picker
            mode="selector"
            range="{{typeOptions}}"
            range-key="label"
            value="{{typeIndex}}"
            bindchange="handleTypeChange"
          >
            <view class="auth-picker-shell {{typeIndex === -1 ? 'is-placeholder' : ''}}">
              <view class="auth-picker-value">
                {{typeIndex === -1 ? '请选择通知类型' : typeOptions[typeIndex].label}}
              </view>
              <view class="auth-picker-arrow">›</view>
            </view>
          </picker>
        </view>

        <!-- 标题 -->
        <view class="auth-field">
          <view class="auth-field-label">
            标题
            <text class="auth-field-required">*</text>
          </view>
          <view class="auth-input-shell">
            <input
              value="{{title}}"
              bindinput="handleTitleInput"
              placeholder="请输入通知标题"
              placeholder-class="auth-input-placeholder"
              maxlength="100"
            />
          </view>
          <view class="auth-field-count">{{title.length}}/100</view>
        </view>

        <!-- 内容 -->
        <view class="auth-field">
          <view class="auth-field-label">
            内容
            <text class="auth-field-required">*</text>
          </view>
          <view class="auth-textarea-wrapper">
            <textarea
              value="{{content}}"
              bindinput="handleContentInput"
              placeholder="请输入通知内容"
              placeholder-class="auth-input-placeholder"
              maxlength="1000"
              auto-height
            />
          </view>
          <view class="auth-field-count">{{content.length}}/1000</view>
        </view>

        <!-- 按钮组 -->
        <view class="announcement-create-buttons">
          <button
            class="auth-submit-btn announcement-submit-btn"
            loading="{{submitting}}"
            bindtap="handleSubmit"
          >
            立即发布
          </button>
        </view>
      </view>
    </view>
  </view>
</view>
