/* pages/office/announcement-create/announcement-create.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f7fa;
  padding-bottom: 40rpx;
}

.form-container {
  padding: 20rpx;
}

.form-item {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.form-label {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
}

.required {
  color: #DC2626;
  margin-left: 4rpx;
}

.form-input {
  width: 100%;
  font-size: 30rpx;
  color: #333;
  padding: 20rpx 0;
  border: none;
  border-bottom: 1rpx solid #E5E7EB;
}

.form-textarea {
  width: 100%;
  min-height: 300rpx;
  font-size: 30rpx;
  color: #333;
  padding: 20rpx 0;
  border: none;
  border-bottom: 1rpx solid #E5E7EB;
  line-height: 1.6;
}

.picker-value {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 30rpx;
  color: #333;
  padding: 20rpx 0;
}

.picker-arrow {
  font-size: 48rpx;
  color: #9CA3AF;
  font-weight: 300;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 10rpx;
}

.button-group {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 40rpx;
}

.btn-submit {
  background: linear-gradient(135deg, #2563EB 0%, #1D4ED8 100%);
  color: #fff;
  border: none;
  border-radius: 12rpx;
  font-size: 32rpx;
  padding: 28rpx 0;
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.3);
}

.btn-cancel {
  background-color: #fff;
  color: #666;
  border: 1rpx solid #E5E7EB;
  border-radius: 12rpx;
  font-size: 32rpx;
  padding: 28rpx 0;
}
