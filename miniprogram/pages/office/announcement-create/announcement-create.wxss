/* pages/office/announcement-create/announcement-create.wxss */
.announcement-create-page {
  min-height: 100%;
}

.create-header {
  padding-bottom: 100rpx;
}

.create-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.create-subtitle {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.create-content {
  margin-top: -60rpx;
  padding: 0 24rpx;
}

.form-card {
  padding: 30rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.required {
  color: #DC2626;
  margin-left: 4rpx;
}

.form-input {
  width: 100%;
  font-size: 30rpx;
  color: #333;
  padding: 20rpx 0;
  border: none;
  border-bottom: 1rpx solid rgba(37, 99, 235, 0.1);
  transition: all 0.3s;
}

.form-input:focus {
  border-bottom-color: #2563EB;
}

.form-textarea {
  width: 100%;
  min-height: 300rpx;
  font-size: 30rpx;
  color: #333;
  padding: 20rpx 0;
  border: none;
  border-bottom: 1rpx solid rgba(37, 99, 235, 0.1);
  transition: all 0.3s;
  line-height: 1.6;
}

.form-textarea:focus {
  border-bottom-color: #2563EB;
}

.picker-value {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 30rpx;
  color: #333;
  padding: 20rpx 0;
}

.picker-arrow {
  font-size: 48rpx;
  color: #9CA3AF;
  font-weight: 300;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 10rpx;
}

.button-group {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.btn-submit {
  flex: 1;
  background: linear-gradient(135deg, #2563EB 0%, #1D4ED8 100%);
  color: #fff;
  border: none;
  border-radius: 12rpx;
  font-size: 32rpx;
  padding: 28rpx 0;
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.3);
}

.btn-cancel {
  flex: 1;
  background-color: #fff;
  color: #666;
  border: 1rpx solid rgba(37, 99, 235, 0.2);
  border-radius: 12rpx;
  font-size: 32rpx;
  padding: 28rpx 0;
}
