/* pages/office/announcement-create/announcement-create.wxss */

.announcement-create-page {
  min-height: 100%;
}

.announcement-create-page .auth-field-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
}

.announcement-create-page .auth-picker-content {
  display: flex;
  align-items: center;
  width: 100%;
}

.announcement-create-page .auth-picker-value {
  flex: 1;
}

.announcement-create-header {
  padding-bottom: 100rpx;
}

.announcement-create-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  text-align: left;
}

.announcement-create-content {
  margin-top: -60rpx;
}

.announcement-create-form {
  padding: 28rpx;
}

.auth-field-required {
  color: #DC2626;
  margin-left: 4rpx;
}

.auth-textarea-wrapper {
  border-radius: 24rpx;
  overflow: hidden;
  background: #F8FAFC;
  border: 2rpx solid transparent;
}

.auth-textarea-wrapper textarea {
  min-height: 300rpx;
  padding: 20rpx;
  box-sizing: border-box;
  width: 100%;
  font-size: 26rpx;
  color: #0F172A;
  line-height: 1.6;
}

.auth-field-count {
  text-align: right;
  font-size: 22rpx;
  color: #94A3B8;
  margin-top: 10rpx;
}

.announcement-create-buttons {
  display: flex;
  justify-content: center;
  margin-top: 32rpx;
}

.announcement-submit-btn {
  width: 100%;
  height: 96rpx !important;
  margin-top: 0 !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  border-radius: 24rpx !important;
}
