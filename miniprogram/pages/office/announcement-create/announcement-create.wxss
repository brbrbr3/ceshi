/* pages/office/announcement-create/announcement-create.wxss */

.announcement-create-page {
  min-height: 100%;
}

.announcement-create-page .auth-field-label {
  font-size: var(--fs-28);
  font-weight: 600;
  color: #1E293B;
}

.announcement-create-header {
  padding-bottom: 70rpx;
  padding-top: 40rpx;
}

.announcement-create-title {
  font-size: var(--fs-48);
  font-weight: 700;
  color: #FFFFFF;
  text-align: left;
}

.announcement-create-content {
  margin-top: -60rpx;
}

.announcement-create-form {
  padding: 28rpx;
}

.auth-field-required {
  color: #DC2626;
  margin-left: 4rpx;
}

/* ===== 富文本编辑器 ===== */
.editor-container {
  border-radius: 24rpx;
  overflow: hidden;
  background: #F8FAFC;
  border: 2rpx solid #E2E8F0;
}

/* 工具栏 */
.editor-toolbar {
  background: #FFFFFF;
  border-bottom: 1rpx solid #E2E8F0;
  padding: 8rpx 12rpx;
}

.toolbar-row {
  display: flex;
  align-items: center;
  min-height: 64rpx;
}

.toolbar-row-extra {
  border-top: 1rpx solid #F1F5F9;
  margin-top: 4rpx;
  padding-top: 8rpx;
}

.toolbar-btn {
  width: 64rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  font-size: var(--fs-26);
  color: #475569;
  transition: background-color 0.15s;
}

.toolbar-btn:active {
  background-color: #E2E8F0;
}

.toolbar-btn-expand {
  width: 56rpx;
  color: #94A3B8;
}

.expand-icon {
  font-size: var(--fs-24);
  transition: transform 0.2s;
  display: inline-block;
}

.expand-icon-up {
  transform: rotate(90deg);
}

.toolbar-divider {
  width: 1rpx;
  height: 32rpx;
  background-color: #E2E8F0;
  margin: 0 6rpx;
}

.toolbar-spacer {
  flex: 1;
}

/* 工具栏图标样式 */
.toolbar-icon-bold {
  font-weight: 800;
  font-size: var(--fs-28);
  font-family: Georgia, serif;
}

.toolbar-icon-italic {
  font-style: italic;
  font-size: var(--fs-28);
  font-family: Georgia, serif;
}

.toolbar-icon-underline {
  text-decoration: underline;
  font-size: var(--fs-28);
  font-family: Georgia, serif;
}

.toolbar-icon-strike {
  text-decoration: line-through;
  font-size: var(--fs-26);
  font-family: Georgia, serif;
}

.toolbar-icon-list {
  font-size: var(--fs-24);
  font-weight: 600;
}

.toolbar-icon-header {
  font-size: var(--fs-22);
  font-weight: 700;
  color: #2563EB;
}

.toolbar-icon-align {
  font-size: var(--fs-28);
  letter-spacing: -2rpx;
}

.toolbar-icon-divider {
  font-size: var(--fs-28);
  color: #94A3B8;
}

/* 编辑器主体 */
.editor-body {
  min-height: 300rpx;
  padding: 20rpx;
  box-sizing: border-box;
  width: 100%;
  font-size: var(--fs-26);
  color: #0F172A;
  line-height: 1.6;
}

.auth-field-count {
  text-align: right;
  font-size: var(--fs-22);
  color: #94A3B8;
  margin-top: 10rpx;
}

.announcement-create-buttons {
  display: flex;
  justify-content: center;
  margin-top: 32rpx;
}

.announcement-submit-btn {
  width: 100%;
  height: 96rpx !important;
  margin-top: 0 !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  border-radius: 24rpx !important;
}
