<view class="office-page contacts-page" style="{{fontStyle}}">
  <view class="office-gradient-header contacts-header">
    <view class="office-header-top">
      <view>
        <view class="contacts-title">通讯录</view>
        <view class="contacts-subtitle">共 {{totalCount}} 人 · {{onlineCount}} 人在线</view>
      </view>
    </view>

    <view class="office-search contacts-search">
      <view class="contacts-search-icon">⌕</view>
      <input value="{{search}}" bindinput="onSearchInput" placeholder="搜索姓名、角色、部门、岗位..." placeholder-class="office-search-placeholder" />
    </view>
  </view>

  <view class="office-content contact-content">

    <scroll-view scroll-x="true" class="office-chip-scroll contacts-chip-scroll" enable-flex="true">
      <view class="chip-scroll-container">
        <view wx:for="{{departments}}" wx:key="*this" class="contacts-chip {{selectedDept == item ? 'is-active' : ''}}" data-dept="{{item}}" bindtap="switchDept">
          {{item}}
        </view>
      </view>
    </scroll-view>

    <view wx:if="{{groupedContacts.length}}">
      <view class="contacts-group" wx:for="{{groupedContacts}}" wx:key="groupKey">
        <view class="contacts-group-title">
          <text>{{item.groupTitle}}</text>
          <text class="contacts-group-count">{{item.members.length}} 人</text>
        </view>

        <view class="office-card contacts-list-card">
          <view class="contacts-item" wx:for="{{item.members}}" wx:key="_id" wx:for-item="member" data-id="{{member._id}}" bindtap="toggleContact">
            <view class="contacts-item-row">
              <view class="contacts-avatar-wrap">
                <view class="office-avatar" style="background: {{member.roleColor}};">{{member.avatarText}}</view>
              </view>

              <view class="contacts-item-main">
                <view class="contacts-item-title-row">
                  <view class="contacts-item-name">{{member.name}}</view>
                  <view class="contacts-item-role-tag" style="background: {{member.roleColor}}15; color: {{member.roleColor}};">{{member.roleIcon}} {{member.role}}</view>
                  <view class="contacts-item-role-tag" style="background: {{member.statusBg}}; color: {{member.statusColor}};">{{member.statusLabel}}</view>
                </view>
                <view class="contacts-item-sub">
                  <text wx:if="{{member.department}}">{{member.department}}</text>
                  <text wx:if="{{member.department && member.position && member.position !== '无'}}"> · </text>
                  <text wx:if="{{member.position && member.position !== '无'}}">{{member.position}}</text>
                </view>
              </view>
            </view>

            <view wx:if="{{expandedId == member._id}}" class="contacts-expand-box">
              <view class="contacts-expand-grid">
                <!-- <view class="contacts-expand-cell">
                  <view class="contacts-expand-label">角色</view>
                  <view class="contacts-expand-value">{{member.role}}</view>
                </view> -->
                <view class="contacts-expand-cell">
                  <view class="contacts-expand-label">部门</view>
                  <view class="contacts-expand-value">{{member.department || '—'}}</view>
                </view>
                <view class="contacts-expand-cell">
                  <view class="contacts-expand-label">岗位</view>
                  <view class="contacts-expand-value">{{member.position || '—'}}</view>
                </view>
                <view class="contacts-expand-cell">
                  <view class="contacts-expand-label">手机</view>
                  <view class="contacts-expand-value">{{member.mobile || '—'}}</view>
                </view>
                <view class="contacts-expand-cell">
                  <view class="contacts-expand-label">座机</view>
                  <view class="contacts-expand-value">{{member.landline || '—'}}</view>
                </view>
                <!-- <view class="contacts-expand-cell">
                  <view class="contacts-expand-label">状态</view>
                  <view class="contacts-expand-value" style="color: {{member.statusColor}};">{{member.statusLabel}}</view>
                </view> -->
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view wx:else class="office-card office-empty">
      <view class="contacts-empty-icon">⌕</view>
      <view>未找到相关联系人</view>
    </view>
  </view>
</view>