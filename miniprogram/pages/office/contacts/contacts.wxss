page {
  background: #EEF2FF;
}

/* 从 app.wxss 迁移的样式 - 仅本页面使用 */
.office-search {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 0 28rpx;
  height: 88rpx;
  border-radius: 24rpx;
  background: #FFFFFF;
  box-shadow: 0 12rpx 28rpx rgba(37, 99, 235, 0.06);
}

.office-search input {
  flex: 1;
  font-size: var(--fs-26);
  color: #1E293B;
}

.office-search-placeholder {
  color: #94A3B8;
}

.contacts-header {
  padding-top: 120rpx;
  padding-bottom: 50rpx;
}

.contacts-title {
  font-size: var(--fs-40);
  font-weight: 600;
}

.contacts-subtitle {
  font-size: var(--fs-22);
}

.contacts-search {
  margin-top: 28rpx;
  background: rgba(255, 255, 255, 0.18);
  box-shadow: none;
}

.contacts-search input {
  color: #FFFFFF;
}

.contacts-search-icon {
  color: rgba(255, 255, 255, 0.74);
  font-size: var(--fs-40);
}

.contacts-list-card {
  padding: 24rpx;
}

.contact-content{
  margin-top: -30rpx;
}

.contacts-chip-scroll {
}

.chip-scroll-container{
  padding-bottom: 25rpx;
}

.contacts-chip-scroll {
  white-space: nowrap;
}

.contacts-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 28rpx;
  margin-right: 16rpx;
  border-radius: 999rpx;
  font-size: var(--fs-25);
  font-weight: 500;
  box-shadow: 8rpx 8rpx 18rpx rgba(37, 99, 235, 0.5);
  background: rgba(0, 0, 0, 0.07);
  border: 4rpx solid rgba(225, 225, 225, 0.3);
  backdrop-filter: blur(15px);
  color: rgba(255, 255, 255, 0.733);
}

.contacts-chip.is-active {
  background: rgba(255, 255, 255, 0.07);
  color: rgb(0, 0, 0);
  border: 4rpx solid rgb(247, 247, 247);
  box-shadow: 8rpx 8rpx 18rpx rgba(37, 99, 235, 0.5);
}

.contacts-group {
  margin-top: 20rpx;
}

.contacts-group-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 6rpx 12rpx;
  font-size: var(--fs-24);
  font-weight: 600;
  color: #4B6080;
}

.contacts-group-count {
  font-size: var(--fs-22);
  color: #94A3B8;
}

.contacts-item + .contacts-item {
  border-top: 1rpx solid rgba(37, 99, 235, 0.1);
  margin-top: 18rpx;
  padding-top: 18rpx;
}

.contacts-item-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.contacts-avatar-wrap {
  position: relative;
}

.contacts-item-main {
  flex: 1;
  min-width: 0;
}

.contacts-item-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.contacts-item-name,
.contacts-expand-value {
  font-size: var(--fs-28);
  font-weight: 600;
  color: #1E293B;
}

.contacts-item-role-tag {
  font-size: var(--fs-20);
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
  font-weight: 500;
}

.contacts-item-sub {
  margin-top: 8rpx;
  font-size: var(--fs-22);
  color: #94A3B8;
}

.contacts-expand-box {
  max-height: 0;
  overflow: hidden;
  opacity: 0;
  padding: 0 20rpx;
  margin-top: 0;
  border-radius: 24rpx;
  background: #F8FAFC;
  transition: max-height 0.15s ease-in-out, opacity 0.15s ease-in-out, padding 0.15s ease-in-out, margin-top 0.15s ease-in-out;
}

.contacts-expand-box.is-expanded {
  max-height: 500rpx;
  opacity: 1;
  padding: 20rpx;
  margin-top: 20rpx;
}

.contacts-expand-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.contacts-expand-label {
  font-size: var(--fs-22);
  color: #94A3B8;
}

.contacts-expand-value {
  margin-top: 8rpx;
  font-size: var(--fs-24);
}

.contacts-expand-cell {
  min-width: 0;
}

.contacts-empty-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  margin: 0 auto 20rpx;
  background: #EFF6FF;
  color: #2563EB;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--fs-60);
}
