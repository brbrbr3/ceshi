<view class="auth-page edit-profile-page" style="{{fontStyle}}">
  <view class="auth-hero">
    <view class="auth-brand">编辑</view>
    <view class="auth-title">修改个人信息</view>
    <view class="auth-subtitle">请填写需要修改的个人信息。提交后，管理员将收到修改申请并进行审核。</view>
  </view>

  <view class="auth-card">
    <view class="auth-card-title">填写个人资料</view>
    <view class="auth-card-desc">审批通过后将更新您的个人信息。姓名和性别不可更改。</view>

    <view wx:if="{{reviewRemark}}" class="auth-review-banner">
      <view class="auth-review-title">退回说明</view>
      <view class="auth-review-text">{{reviewRemark}}</view>
    </view>

    <view class="auth-form">
      <view class="auth-field">
        <view class="auth-field-label">姓名</view>
        <view class="auth-input-shell is-disabled">
          <input value="{{form.name}}" disabled placeholder="请输入真实姓名" />
        </view>
        <view class="auth-field-hint">姓名不可修改</view>
      </view>

      <view class="auth-field">
        <view class="auth-field-label">性别</view>
        <view class="auth-segment is-disabled">
          <view class="auth-segment-item {{form.gender === '男' ? 'is-active' : ''}}">男</view>
          <view class="auth-segment-item {{form.gender === '女' ? 'is-active' : ''}}">女</view>
        </view>
        <view class="auth-field-hint">性别不可修改</view>
      </view>

      <view class="auth-field">
        <view class="auth-field-label">出生日期</view>
        <picker wx:if="{{today}}" mode="date" value="{{form.birthday}}" start="1900-01-01" end="{{today}}" bindchange="handleBirthdayChange">
          <view class="auth-picker-shell {{form.birthday ? '' : 'is-placeholder'}}">
            <view class="auth-picker-value">{{form.birthday || '请选择出生日期'}}</view>
            <view class="auth-picker-arrow">›</view>
          </view>
        </picker>
        <view wx:else class="auth-picker-shell is-placeholder">
          <view class="auth-picker-value">加载中...</view>
        </view>
      </view>

      <view class="auth-field">
        <view class="auth-field-label">角色</view>
        <picker mode="selector" range="{{roleOptions}}" value="{{roleIndex}}" bindchange="handleRoleChange">
          <view class="auth-picker-shell {{roleIndex < 0 ? 'is-placeholder' : ''}}">
            <view class="auth-picker-value">{{roleIndex >= 0 ? form.role : '请选择角色'}}</view>
            <view class="auth-picker-arrow">›</view>
          </view>
        </picker>
      </view>

      <view wx:if="{{showDepartmentField}}" class="auth-field">
        <view class="auth-field-label">部门</view>
        <picker mode="selector" range="{{departmentOptions}}" value="{{departmentIndex >= 0 ? departmentIndex : 0}}" bindchange="handleDepartmentChange">
          <view class="auth-picker-shell {{departmentIndex < 0 ? 'is-placeholder' : ''}}">
            <view class="auth-picker-value">{{departmentIndex >= 0 ? form.department : '请选择部门'}}</view>
            <view class="auth-picker-arrow">›</view>
          </view>
        </picker>
      </view>

      <view wx:if="{{showRelativeField}}" class="auth-field">
        <view class="auth-field-label">您是哪位馆员的亲属？</view>
        <view class="auth-input-shell">
          <input value="{{form.relativeName}}" placeholder="请输入馆员姓名" bindinput="handleRelativeNameInput" />
        </view>
      </view>

      <view wx:if="{{showPositionField}}" class="auth-field">
        <view class="auth-field-label">请选择岗位</view>
        <picker mode="selector" range="{{positionOptions}}" value="{{positionIndex >= 0 ? positionIndex : 0}}" bindchange="handlePositionChange">
          <view class="auth-picker-shell {{positionIndex < 0 ? 'is-placeholder' : ''}}">
            <view class="auth-picker-value">{{positionIndex >= 0 ? form.position : '请选择岗位'}}</view>
            <view class="auth-picker-arrow">›</view>
          </view>
        </picker>
      </view>

      <view class="auth-field">
        <view class="auth-field-label">手机 <text class="auth-field-optional">（选填）</text></view>
        <view class="auth-input-shell">
          <input value="{{form.mobile}}" placeholder="+55 61 " placeholder-class="auth-input-placeholder" bindinput="handleMobileInput" type="text" />
        </view>
      </view>

      <view class="auth-field">
        <view class="auth-field-label">座机 <text class="auth-field-optional">（选填）</text></view>
        <view class="auth-input-shell">
          <input value="{{form.landline}}" placeholder="+55 61 " placeholder-class="auth-input-placeholder" bindinput="handleLandlineInput" type="text" />
        </view>
      </view>

      <view class="auth-field">
        <view class="auth-field-label">是否为管理员</view>
        <view class="auth-segment">
          <view class="auth-segment-item {{form.isAdmin ? 'is-active' : ''}}" data-value="true" bindtap="selectAdmin">是</view>
          <view class="auth-segment-item {{!form.isAdmin ? 'is-active' : ''}}" data-value="false" bindtap="selectAdmin">否</view>
        </view>
      </view>
    </view>

    <button class="auth-submit-btn" loading="{{loading}}" bindtap="submitUpdate">提交修改申请</button>
    <view class="auth-note">提交后请等待管理员处理；若未通过，可进入本页修改并重新提交。</view>
  </view>
</view>
