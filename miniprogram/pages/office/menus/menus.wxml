<view class="office-page menus-page">
  <view class="office-gradient-header menus-header">
    <view class="office-header-top">
      <view>
        <view class="menus-title">每周菜单</view>
        <view class="menus-subtitle">查看本周及历史菜单安排</view>
      </view>
      <view wx:if="{{showAddButton}}" class="menus-add-btn" bindtap="goAddMenu">
        <text>＋ 新增</text>
      </view>
    </view>
  </view>

  <view class="office-content menus-content">
    <!-- 列表内容 -->
    <view class="office-card menus-list" wx:if="{{list.length > 0}}">
      <view class="menu-item" wx:for="{{list}}" wx:key="_id" bindtap="goMenuDetail" data-id="{{item._id}}">
        <view class="menu-item-left">
          <view class="menu-item-icon">📋</view>
          <view class="menu-item-main">
            <view class="menu-item-title">{{item.title}}</view>
            <view class="menu-item-meta">
              <text class="menu-item-time">提交于 {{item.timeText}}</text>
              <text class="menu-item-author">· {{item.authorName}}</text>
            </view>
          </view>
        </view>
        <view class="menu-item-right">
          <view class="menu-item-arrow">›</view>
        </view>
      </view>
    </view>

    <!-- 分页加载状态 -->
    <view class="pagination-loading" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 没有更多数据提示 -->
    <view class="pagination-no-more" wx:elif="{{!hasMore && list.length > 0}}">
      <text class="no-more-text">没有更多数据了</text>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:elif="{{list.length === 0 && !loading}}">
      <view class="empty-icon">🍽️</view>
      <view class="empty-text">暂无菜单</view>
    </view>
  </view>
</view>

