.menus-page {
  min-height: 100%;
}

.menus-header {
  padding-bottom: 100rpx;
}

.menus-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.menus-subtitle {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.menus-add-btn {
  align-self: flex-end;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 600;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.menus-content {
  margin-top: -60rpx;
}

.menus-list {
  padding: 24rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1rpx solid rgba(37, 99, 235, 0.08);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.menu-item-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  background: #DCFCE7;
  color: #16A34A;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.menu-item-main {
  flex: 1;
  min-width: 0;
}

.menu-item-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.menu-item-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 22rpx;
  color: #94A3B8;
}

.menu-item-right {
  display: flex;
  align-items: center;
}

.menu-item-arrow {
  font-size: 40rpx;
  color: #94A3B8;
}
