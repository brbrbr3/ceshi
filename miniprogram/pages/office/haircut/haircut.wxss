/* 理发预约页面样式 */

page {
  background: #ffffff;
  height: 100%;
}

.haircut-page {
  min-height: 100%;
}

/* ========== 头部 - 渐变色背景（橙色系） ========== */
.haircut-header {
  background: linear-gradient(135deg, #EA580C 0%, #C2410C 100%);
  padding: 40rpx 28rpx 10rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.haircut-header-content {
  color: #FFFFFF;
}

.haircut-title {
  font-size: var(--fs-48);
  font-weight: 600;
}

.haircut-subtitle {
  font-size: var(--fs-26);
  padding-top: 5rpx;
  opacity: 0.9;
}

/* ========== Tab栏 ========== */
.haircut-tabs {
  background: #FFFFFF;
  display: flex;
  padding: 0 16rpx;
  border-bottom: 1rpx solid #F1F5F9;
  position: sticky;
  top: 0;
  z-index: 50;
}

.haircut-tab {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: var(--fs-28);
  color: #64748B;
  font-weight: 500;
  position: relative;
  transition: all 0.3s ease;
}

.haircut-tab.is-active {
  color: #EA580C;
  font-weight: 600;
}

.haircut-tab.is-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: linear-gradient(135deg, #EA580C 0%, #C2410C 100%);
  border-radius: 3rpx;
}

/* ========== 内容区 ========== */
.haircut-content {
  padding: 24rpx;
  padding-bottom: 100rpx;
}

/* ========== 日期选择器（完全仿会议室样式） ========== */
.date-selector {
  background: #FFFFFF;
  padding: 24rpx 0 5rpx;
  border-top: 1rpx solid #E2E8F0;
}

.date-scroll {
  width: 100%;
  white-space: nowrap;
}

.date-list {
  display: inline-flex;
  padding: 0 32rpx;
  gap: 16rpx;
}

.date-item {
  width: 140rpx;
  padding: 20rpx 0;
  border-radius: 24rpx;
  background: #F8FAFC;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  transition: all 0.3s ease;
  flex-shrink: 0;
}

.date-item.is-active {
  border: 4rpx solid #EA580C;
  background: #ea5a0c1f;
}

.date-item.is-disabled {
  opacity: 0.5;
  background: #F1F5F9;
}

.date-weekday {
  font-size: var(--fs-24);
  color: #94A3B8;
}

.date-day {
  font-size: var(--fs-28);
  font-weight: 600;
  color: #1E293B;
}

.date-item.is-active .date-day {
  color: #EA580C;
}

/* 预约数圆圈徽章（橙色） */
.date-count-badge {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #EA580C;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 4rpx;
}

.date-count-badge text {
  font-size: var(--fs-20);
  color: #FFFFFF;
  font-weight: 500;
}

/* ========== 日期提示 ========== */
.haircut-date-hint {
  padding: 20rpx 24rpx;
  background: #FEF3C7;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.haircut-date-hint-text {
  font-size: var(--fs-26);
  color: #92400E;
}

/* ========== 时段列表 ========== */
.haircut-slots-section {
  margin-top: 20rpx;
}

.haircut-slots-title {
  font-size: var(--fs-30);
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.haircut-slots-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.haircut-slot-item {
  display: flex;
  
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  border: 4rpx solid #E2E8F0;
  transition: all 0.3s ease;
}

.haircut-slot-item.is-selected {
  border-color: #EA580C;
  background: #ea5a0c1f;
}

.haircut-slot-item.is-booked {
  opacity: 0.8;
  background: #F1F5F9;
  border-color: transparent;
}

.haircut-slot-time {
  font-size: var(--fs-32);
  font-weight: 600;
  color: #1E293B;
}

.haircut-slot-item.is-booked .haircut-slot-time {
  color: #94A3B8;
}

.haircut-slot-status {
  font-size: var(--fs-24);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.haircut-slot-status.is-available {
  background: #DCFCE7;
  color: #16A34A;
}

.haircut-slot-status.is-booked {
  background: #FEE2E2;
  color: #DC2626;
}

/* 我已预约 - 黄色 */
.haircut-slot-status.is-myBooked {
  background: #FEF3C7;
  color: #D97706;
}

/* 不可预约 - 灰色 */
.haircut-slot-status.is-unavailable {
  background: #F3F4F6;
  color: #6B7280;
}

/* 时段左侧 */
.haircut-slot-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

/* 时段理发人姓名 */
.haircut-slot-booker {
  font-size: var(--fs-24);
  color: #6B7280;
  font-weight: normal;
  margin-left: 8rpx;
}

/* 时段右侧 */
.haircut-slot-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

/* 操作按钮 */
.haircut-slot-action {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--fs-32);
  font-weight: bold;
}

/* 设为不可预约按钮 - 红色 */
.haircut-slot-action.is-disable {
  background: #FEE2E2;
  color: #DC2626;
}

/* 恢复为可预约按钮 - 绿色 */
.haircut-slot-action.is-restore {
  background: #DCFCE7;
  color: #16A34A;
}

/* 取消按钮 - 红色 */
.haircut-slot-action.is-cancel {
  background: #FEE2E2;
  color: #DC2626;
}

.haircut-slot-item.is-selected .haircut-slot-status.is-available {
  background: #EA580C;
  color: #FFFFFF;
}

/* ========== 预约按钮 ========== */
.haircut-booking-btn {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: calc(28rpx + env(safe-area-inset-bottom));
  height: 96rpx;
  background: linear-gradient(135deg, #EA580C 0%, #C2410C 100%);
  color: #FFFFFF;
  font-size: var(--fs-32);
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.haircut-booking-btn[disabled] {
  background: #94A3B8;
}

/* ========== 排序切换 ========== */
.haircut-sort-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.haircut-sort-btn {
  padding: 12rpx 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  font-size: var(--fs-26);
  color: #64748B;
  transition: all 0.3s ease;
}

.haircut-sort-btn.is-active {
  background: linear-gradient(135deg, #EA580C 0%, #C2410C 100%);
  color: #FFFFFF;
}

/* ========== 列表 ========== */
.haircut-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* ========== 记录卡片 ========== */
.haircut-item {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  border: 4rpx solid #E2E8F0;
}

.haircut-item-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.haircut-item-datetime {
  display: flex;
  flex-direction: column;
}

.haircut-item-date {
  font-size: var(--fs-30);
  font-weight: 600;
  color: #1E293B;
}

.haircut-item-time {
  font-size: var(--fs-24);
  color: #64748B;
  margin-top: 4rpx;
}

.haircut-item-status {
  font-size: var(--fs-22);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.haircut-item-status.is-booked {
  background: #DCFCE7;
  color: #16A34A;
}

.haircut-item-status.is-cancelled {
  background: #FEE2E2;
  color: #DC2626;
}

.haircut-item-status.is-completed {
  background: #EFF6FF;
  color: #2563EB;
}

.haircut-item-body {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.haircut-item-name {
  font-size: var(--fs-28);
  color: #1E293B;
  font-weight: 500;
}

.haircut-item-meta {
  font-size: var(--fs-24);
  color: #64748B;
}

.haircut-item-reason {
  font-size: var(--fs-24);
  color: #DC2626;
  margin-top: 8rpx;
}

.haircut-item-actions {
  display: flex;
  gap: 24rpx;
  padding-top: 16rpx;
  margin-top: 16rpx;
  border-top: 1rpx solid #F1F5F9;
}

.haircut-item-action {
  font-size: var(--fs-26);
  color: #EA580C;
  font-weight: 500;
}

.haircut-item-action.is-danger {
  color: #DC2626;
}

/* ========== 空状态 ========== */
.haircut-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.haircut-empty-icon {
  font-size: var(--fs-80);
  margin-bottom: 20rpx;
}

.haircut-empty-text {
  font-size: var(--fs-28);
  color: #94A3B8;
}

/* ========== 加载状态 ========== */
.haircut-loading {
  display: flex;
  justify-content: center;
  padding: 32rpx 0;
}

.haircut-loading-text {
  font-size: var(--fs-26);
  color: #94A3B8;
}

/* ========== 弹窗遮罩 ========== */
.haircut-popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.haircut-popup-mask.is-visible {
  opacity: 1;
  visibility: visible;
}

/* ========== 弹窗容器 ========== */
.haircut-popup-container {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 90vh;
  overflow-y: auto;
  margin: 0 28rpx 0;
}

.haircut-popup-mask.is-visible .haircut-popup-container {
  transform: translateY(0);
}

/* ========== 弹窗头部 ========== */
.haircut-popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #F1F5F9;
  position: sticky;
  top: 0;
  background: #FFFFFF;
  z-index: 1;
}

.haircut-popup-title {
  font-size: var(--fs-34);
  font-weight: 600;
  color: #1E293B;
}

.haircut-popup-close {
  font-size: var(--fs-48);
  color: #94A3B8;
  line-height: 1;
  padding: 0 8rpx;
}

/* ========== 表单 ========== */
.haircut-popup-form {
  padding: 32rpx 32rpx 0;
}

.haircut-field {
  margin-bottom: 28rpx;
}

.haircut-field-label {
  font-size: var(--fs-28);
  color: #1E293B;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.haircut-required {
  color: #DC2626;
}

.haircut-field-hint {
  font-size: var(--fs-22);
  color: #94A3B8;
  margin-top: 8rpx;
}

.haircut-input-wrapper {
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 0 24rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
}

.haircut-input {
  flex: 1;
  font-size: var(--fs-28);
  color: #1E293B;
}

.haircut-input-placeholder {
  color: #94A3B8;
}

/* ========== 单选组 ========== */
.haircut-radio-group {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.haircut-radio-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #F8FAFC;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.haircut-radio-item.is-active {
  background: #FFF7ED;
  border-color: #EA580C;
}

.haircut-radio-dot {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #D1D5DB;
  margin-right: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.haircut-radio-item.is-active .haircut-radio-dot {
  border-color: #EA580C;
  background: #EA580C;
}

.haircut-radio-dot-inner {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #FFFFFF;
}

.haircut-radio-text {
  font-size: var(--fs-28);
  color: #1E293B;
}

/* ========== 提交按钮 ========== */
.haircut-submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #EA580C 0%, #C2410C 100%);
  color: #FFFFFF;
  font-size: var(--fs-32);
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
  margin-top: 20rpx;
}

.haircut-submit-btn[disabled] {
  background: #94A3B8;
}

/* ========== 弹窗操作按钮 ========== */
.haircut-popup-actions {
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 16rpx;
}

.haircut-action-btn {
  flex: 1;
  height: 88rpx;
  font-size: var(--fs-30);
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
}

.haircut-action-btn.is-primary {
  background: linear-gradient(135deg, #EA580C 0%, #C2410C 100%);
  color: #FFFFFF;
}

.haircut-action-btn.is-secondary {
  background: #F1F5F9;
  color: #64748B;
}

.haircut-action-btn.is-danger {
  background: #DC2626;
  color: #FFFFFF;
}

.haircut-action-btn[disabled] {
  background: #94A3B8;
  color: #FFFFFF;
}

/* ========== 提示信息 ========== */
.haircut-info-card {
  background: #EFF6FF;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
}

.haircut-info-text {
  font-size: var(--fs-26);
  color: #1E40AF;
  line-height: 1.6;
}

/* ========== 统计月分组 ========== */
.haircut-stats-month-group {
  margin-bottom: 32rpx;
}

.haircut-stats-month-title {
  font-size: var(--fs-28);
  font-weight: 600;
  color: #475569;
  padding: 16rpx 8rpx;
  border-left: 6rpx solid #EA580C;
  background: #F8FAFC;
  border-radius: 0 12rpx 12rpx 0;
  margin-bottom: 16rpx;
}

/* ========== 按人员排序 - 人名列表 ========== */
.haircut-stats-name-list {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  border: 4rpx solid #E2E8F0;
}

.haircut-stats-name-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F1F5F9;
}

.haircut-stats-name-item:last-child {
  border-bottom: none;
}

.haircut-stats-name-text {
  font-size: var(--fs-28);
  color: #1E293B;
  font-weight: 500;
}

.haircut-stats-count-text {
  font-size: var(--fs-26);
  color: #64748B;
  background: #F1F5F9;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

/* ========== 统计Tab分页加载 ========== */
.pagination-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 0;
  background-color: #f5f5f5;
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid #e0e0e0;
  border-top-color: #EA580C;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-right: 16rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: var(--fs-28);
  color: #999;
}

/* 点击加载更多 */
.pagination-load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 0;
}

.load-more-text {
  font-size: var(--fs-26);
  color: #EA580C;
  background: #FFF7ED;
  padding: 16rpx 48rpx;
  border-radius: 40rpx;
  border: 2rpx solid #FED7AA;
}

/* 没有更多数据 */
.pagination-no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 0;
}

.no-more-text {
  font-size: var(--fs-24);
  color: #ccc;
}