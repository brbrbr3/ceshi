/* 护照领用页面样式 */

.passport-page {
  min-height: 100vh;
  background: #EEF2FF;
}

/* 头部 - 渐变色背景 */
.passport-header {
  background: linear-gradient(135deg, #7C3AED 0%, #5B21B6 100%);
  padding: 70rpx 28rpx 32rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.passport-header-content {
  color: #FFFFFF;
}

.passport-title {
  font-size: 48rpx;
  font-weight: 600;
}

.passport-subtitle {
  font-size: 26rpx;
  padding-top: 5rpx;
}

.passport-header-action {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 32rpx;
  padding: 16rpx 32rpx;
  backdrop-filter: blur(10px);
}

.passport-action-text {
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 500;
}

/* 状态卡片 */
.passport-status-card {
  margin: 28rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  transition: all 0.3s ease;
}

.passport-status-card.is-borrowed {
  background: #FEF3C7;
  border: 1rpx solid #D97706;
}

.passport-status-card.is-borrowed .passport-status-label {
  color: #92400E;
}

.passport-status-card.is-borrowed .passport-status-detail {
  color: #B45309;
}

.passport-status-card.is-idle {
  background: #DCFCE7;
  border: 1rpx solid #16A34A;
}

.passport-status-card.is-idle .passport-status-label {
  color: #166534;
}

.passport-status-card.is-idle .passport-status-detail {
  color: #15803D;
}

.passport-status-header {
  display: flex;
  align-items: center;
}

.passport-status-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 16rpx;
}

.passport-status-info {
  flex: 1;
}

.passport-status-label {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.passport-status-detail {
  font-size: 24rpx;
  font-weight: 500;
}

/* 在借列表 */
.passport-borrowed-list {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.1);
}

.passport-borrowed-item {
  padding: 16rpx 0;
}

.passport-borrowed-row {
  display: flex;
  margin-bottom: 8rpx;
}

.passport-borrowed-label {
  font-size: 24rpx;
  color: #666;
  width: 140rpx;
}

.passport-borrowed-value {
  font-size: 24rpx;
  color: #333;
  flex: 1;
}

/* 内容区 */
.passport-content {
  padding: 24rpx;
  padding-bottom: 100rpx;
}

/* 章节标题 */
.passport-section {
  margin-top: 16rpx;
}

.passport-section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 20rpx;
  padding-left: 8rpx;
}

/* 月份分组 */
.passport-month-group {
  margin-bottom: 24rpx;
}

.passport-month-title {
  font-size: 26rpx;
  color: #64748B;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

/* 列表 */
.passport-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 记录卡片 */
.passport-item {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.passport-item-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.passport-item-date {
  font-size: 32rpx;
  font-weight: 600;
  color: #1E293B;
  flex: 1;
}

.passport-item-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.passport-item-body {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.passport-item-borrowers {
  font-size: 28rpx;
  color: #1E293B;
  font-weight: 500;
}

.passport-item-meta {
  display: flex;
  gap: 20rpx;
}

.passport-item-reason {
  font-size: 24rpx;
  color: #64748B;
}

/* 空状态 */
.passport-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.passport-empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.passport-empty-text {
  font-size: 28rpx;
  color: #94A3B8;
}

/* 加载状态 */
.passport-loading {
  display: flex;
  justify-content: center;
  padding: 32rpx 0;
}

.passport-loading-text {
  font-size: 26rpx;
  color: #94A3B8;
}

/* 弹窗遮罩 */
.passport-popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.passport-popup-mask.is-visible {
  opacity: 1;
  visibility: visible;
}

/* 弹窗容器 */
.passport-popup-container {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 90vh;
  overflow-y: auto;
  margin: 0 28rpx 0;
}

.passport-popup-mask.is-visible .passport-popup-container {
  transform: translateY(0);
}

/* 弹窗头部 */
.passport-popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #F1F5F9;
  position: sticky;
  top: 0;
  background: #FFFFFF;
  z-index: 1;
}

.passport-popup-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1E293B;
}

.passport-popup-close {
  font-size: 48rpx;
  color: #94A3B8;
  line-height: 1;
  padding: 0 8rpx;
}

/* 表单 */
.passport-popup-form {
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.passport-field {
  margin-bottom: 28rpx;
}

.passport-field-label {
  font-size: 28rpx;
  color: #1E293B;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.passport-required {
  color: #DC2626;
}

.passport-field-hint {
  font-size: 22rpx;
  color: #94A3B8;
  margin-top: 8rpx;
}

.passport-input-wrapper {
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 0 24rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
}

.passport-input {
  flex: 1;
  font-size: 28rpx;
  color: #1E293B;
}

.passport-input-placeholder {
  color: #94A3B8;
}

.passport-textarea-wrapper {
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 24rpx;
}

.passport-textarea {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  color: #1E293B;
}

/* 下拉选择器 */
.passport-picker-wrapper {
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 0 24rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.passport-picker-wrapper.is-placeholder .passport-picker-value {
  color: #94A3B8;
}

.passport-picker-value {
  font-size: 28rpx;
  color: #1E293B;
}

.passport-picker-arrow {
  font-size: 36rpx;
  color: #94A3B8;
  font-weight: 300;
}

/* 提交按钮 */
.passport-submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #7C3AED 0%, #5B21B6 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
  margin-top: 20rpx;
}

.passport-submit-btn[disabled] {
  background: #94A3B8;
}

/* 详情内容 */
.passport-detail-content {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.passport-detail-row {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F1F5F9;
}

.passport-detail-row:last-child {
  border-bottom: none;
}

.passport-detail-label {
  font-size: 28rpx;
  color: #64748B;
  width: 160rpx;
  flex-shrink: 0;
}

.passport-detail-value {
  font-size: 28rpx;
  color: #1E293B;
  flex: 1;
}
