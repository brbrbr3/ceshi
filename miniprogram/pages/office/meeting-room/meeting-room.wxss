/* 会议室预约页面样式 */

page {
  background: #F8FAFC;
  height: 100%;
}

.meeting-room-page {
  display: flex;
  flex-direction: column;
  height: 100%;
}

/* ========================================
   页面头部
   ======================================== */

.meeting-header {
  background: linear-gradient(135deg, #E8E4FF 0%, #F5F3FF 100%);
  padding: 24rpx 32rpx 32rpx;
}

.meeting-header-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.meeting-title {
  font-size: 48rpx;
  font-weight: 600;
  color: #1E293B;
}

.meeting-add-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #7C5CFC 0%, #8B5CF6 100%);
  color: #FFFFFF;
  font-size: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(124, 92, 252, 0.3);
}

/* ========================================
   会议室选择器
   ======================================== */

.room-selector {
  background: #FFFFFF;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #E2E8F0;
}

.room-scroll {
  width: 100%;
  white-space: nowrap;
}

.room-list {
  display: inline-flex;
  padding: 0 32rpx;
  gap: 16rpx;
}

.room-item {
  padding: 16rpx 32rpx;
  border-radius: 24rpx;
  background: #F1F5F9;
  color: #64748B;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.3s ease;
  flex-shrink: 0;
}

.room-item.is-active {
  background: #7C5CFC;
  color: #FFFFFF;
}

/* ========================================
   日期选择器
   ======================================== */

.date-selector {
  background: #FFFFFF;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #E2E8F0;
}

.date-scroll {
  width: 100%;
  white-space: nowrap;
}

.date-list {
  display: inline-flex;
  padding: 0 32rpx;
  gap: 16rpx;
}

.date-item {
  width: 120rpx;
  padding: 20rpx 0;
  border-radius: 24rpx;
  background: #F8FAFC;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  transition: all 0.3s ease;
  flex-shrink: 0;
}

.date-item.is-active {
  background: #E8E4FF;
}

.date-weekday {
  font-size: 24rpx;
  color: #94A3B8;
}

.date-day {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
}

.date-item.is-active .date-day {
  color: #7C5CFC;
}

/* 预约数圆圈徽章 */
.date-count-badge {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #7C5CFC;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 4rpx;
}

.date-count-badge text {
  font-size: 20rpx;
  color: #FFFFFF;
  font-weight: 500;
}

/* ========================================
   时间轴会议列表
   ======================================== */

.timeline-section {
  flex: 1;
  overflow: hidden;
  margin-bottom: 50rpx;
  border-bottom: 4rpx solid #7c5cfc39;
}

.timeline-scroll {
  height: 100%;
}

.timeline-container {
  position: relative;
  min-height: 100%;
}

/* 小时网格 */
.timeline-grid {
  position: relative;
}

.hour-row {
  position: relative;
  display: flex;
  align-items: flex-start;
  height: 200rpx;
  border-bottom: 1rpx solid #E2E8F0;
}

.hour-label {
  width: 88rpx;
  font-size: 22rpx;
  color: #94A3B8;
  text-align: center;
  padding-top: 4rpx;
  flex-shrink: 0;
}

/* 半点虚线 */
.half-hour-line {
  position: absolute;
  top: 100rpx;
  left: 0;
  right: 0;
  height: 0;
  border-top: 1rpx dashed #E2E8F0;
}

/* 预约块容器 */
.reservation-bars {
  position: absolute;
  top: 0rpx;
  left: 88rpx;
  right: 32rpx;
  bottom: 0;
  pointer-events: none;
  box-sizing: border-box;
}

/* 预约块 */
.reservation-bar {
  position: absolute;
  left: 0;
  right: 0;
  margin: 1rpx 0;
  background: #FFFFFF;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  padding: 16rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  box-sizing: border-box;
  border-left: 6rpx solid #7C5CFC;
  border-top: 3rpx solid #7c5cfcaf;
  pointer-events: auto;
  min-height: 80rpx;
  transition: box-shadow 0.2s ease;
}

.reservation-bar.is-dragging {
  box-shadow: 0 8rpx 24rpx rgba(124, 92, 252, 0.25);
  z-index: 100;
}

.reservation-bar-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1E293B;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.reservation-bar-time {
  font-size: 30rpx;
  color: #64748B;
  font-weight: 500;
}

.reservation-bar-desc {
  font-size: 30rpx;
  color: #94A3B8;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 拖拽手柄 */
.drag-handle {
  position: absolute;
  left: 20rpx;
  right: 20rpx;
  height: 8rpx;
  opacity: 0;
  transition: opacity 0.2s ease;
}

.drag-handle-top {
  top: 8rpx;
  background: linear-gradient(90deg, transparent 0%, #E2E8F0 20%, #E2E8F0 80%, transparent 100%);
}

.drag-handle-bottom {
  bottom: 8rpx;
  background: linear-gradient(90deg, transparent 0%, #E2E8F0 20%, #E2E8F0 80%, transparent 100%);
}

.reservation-bar:active .drag-handle {
  opacity: 1;
}

/* 当前时间线 */
.current-time-line {
  position: absolute;
  left: 8rpx;
  right: 30rpx;
  height: 0;
  z-index: 10;
}

.current-time-label {
  position: absolute;
  left: 5rpx;
  top: 0rpx;
  font-size: 22rpx;
  color: #EF4444;
  font-weight: 600;
  background: rgba(255, 255, 255, 0.8);
  border: 1rpx solid #EF4444;
  padding: 4rpx 8rpx;
  border-radius: 255rpx;
  transform: translateY(-50%);
  text-align: center;
}

.current-time-dot {
  position: absolute;
  left: 95rpx;
  top: 0;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #EF4444;
  box-shadow: 0 0 8rpx rgba(239, 68, 68, 0.7);
  transform: translate(-50%, -50%);
}

.current-time-bar {
  position: absolute;
  left: 100rpx;
  right: -30rpx;
  top: 0;
  height: 2rpx;
  background: #EF4444;
  transform: translateY(-50%);
}

/* ========================================
   详情弹窗
   ======================================== */

.detail-popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 10000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.detail-popup-mask.is-visible {
  opacity: 1;
  visibility: visible;
}

.detail-popup-container {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #F8FAFC;
  border-radius: 32rpx 32rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}

.detail-popup-mask.is-visible .detail-popup-container {
  transform: translateY(0);
}

.detail-popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #E2E8F0;
  border-radius: 32rpx 32rpx 0 0;
  flex-shrink: 0;
}

.detail-popup-close {
  font-size: 48rpx;
  color: #64748B;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-popup-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1E293B;
  padding-left: 40rpx;
}

.detail-popup-edit {
  font-size: 28rpx;
  color: #7C5CFC;
  font-weight: 500;
}

.detail-popup-scroll {
  flex: 1;
  height: 0;
  overflow: hidden;
}

.detail-popup-content {
  padding: 24rpx;
}

.detail-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.detail-type-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #7C5CFC;
  flex-shrink: 0;
}

.detail-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1E293B;
  line-height: 1.4;
}

.detail-section {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 16rpx;
}

.detail-section-title {
  font-size: 24rpx;
  color: #94A3B8;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.detail-section-value {
  font-size: 28rpx;
  color: #1E293B;
  line-height: 1.6;
}

.detail-time-info {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.detail-time-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.detail-time-label {
  font-size: 26rpx;
  color: #64748B;
  width: 80rpx;
  flex-shrink: 0;
}

.detail-time-value {
  font-size: 26rpx;
  color: #1E293B;
}

.detail-popup-footer {
  padding: 24rpx 32rpx;
  background: #FFFFFF;
  border-top: 1rpx solid #E2E8F0;
}

.detail-delete-btn {
  width: 100%;
  height: 88rpx;
  background: #FFFFFF;
  border: 2rpx solid #EF4444;
  color: #EF4444;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 500;
}

/* ========================================
   表单弹窗
   ======================================== */

.form-popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 10000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.form-popup-mask.is-visible {
  opacity: 1;
  visibility: visible;
}

.form-popup-container {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #F8FAFC;
  border-radius: 32rpx 32rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.form-popup-mask.is-visible .form-popup-container {
  transform: translateY(0);
}

.form-popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #E2E8F0;
  border-radius: 32rpx 32rpx 0 0;
  flex-shrink: 0;
}

.form-popup-cancel {
  font-size: 28rpx;
  color: #64748B;
}

.form-popup-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1E293B;
}

.form-popup-save {
  font-size: 28rpx;
  color: #7C5CFC;
  font-weight: 600;
}

.form-popup-scroll {
  flex: 1;
  height: 0;
  overflow: hidden;
}

.form-popup-form {
  padding: 24rpx;
}

.form-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 16rpx;
}

.form-field {
  margin-bottom: 24rpx;
}

.form-field:last-child {
  margin-bottom: 0;
}

.form-field-label {
  font-size: 24rpx;
  color: #94A3B8;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1E293B;
  box-sizing: border-box;
}

.form-field-value {
  font-size: 28rpx;
  color: #1E293B;
  padding: 20rpx 0;
}

.form-picker {
  width: 100%;
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #1E293B;
  box-sizing: border-box;
}


