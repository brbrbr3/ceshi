/* pages/office/help/help.wxss */

.feedback-container {
  min-height: 100vh;
}

/* 头部区域 */
.feedback-header {
  padding: 60rpx 40rpx 40rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.feedback-header-content {
  text-align: center;
}

.feedback-title {
  font-size: var(--fs-48);
  font-weight: bold;
  color: #ffffff;
  text-align: left;
}

.feedback-subtitle {
  padding-top: 5rpx;
  font-size: var(--fs-26);
  color: rgba(255, 255, 255);
  text-align: left;
}

/* 内容区域 */
.feedback-content {
  padding: 20rpx 30rpx 40rpx;
}

/* 功能分类区块 */
.help-section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: var(--fs-32);
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  padding-left: 10rpx;
  border-left: 6rpx solid #667eea;
}

/* 功能卡片 */
.help-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-icon {
  font-size: var(--fs-48);
  margin-right: 20rpx;
}

.card-title {
  font-size: var(--fs-32);
  font-weight: bold;
  color: #333;
  flex: 1;
}

.card-content {
  padding-left: 68rpx;
}

.card-desc {
  font-size: var(--fs-28);
  color: #666;
  line-height: 44rpx;
  margin-bottom: 20rpx;
}

.card-features {
  margin-bottom: 20rpx;
}

.feature-item {
  font-size: var(--fs-26);
  color: #666;
  line-height: 40rpx;
  margin-bottom: 8rpx;
}

.card-permission {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 20rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  border-left: 4rpx solid #667eea;
}

.permission-label {
  font-size: var(--fs-26);
  color: #999;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.permission-value {
  font-size: var(--fs-26);
  color: #667eea;
  font-weight: 500;
}

/* 权限说明提示 */
.permission-tips {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.tips-item {
  display: flex;
  margin-bottom: 32rpx;
}

.tips-item:last-child {
  margin-bottom: 0;
}

.tips-icon {
  font-size: var(--fs-40);
  margin-right: 20rpx;
  flex-shrink: 0;
}

.tips-content {
  flex: 1;
}

.tips-title {
  font-size: var(--fs-28);
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.tips-desc {
  font-size: var(--fs-26);
  color: #666;
  line-height: 40rpx;
}

.permission-type {
  font-size: var(--fs-26);
  color: #666;
  line-height: 40rpx;
  margin-bottom: 8rpx;
}

/* 底部提示 */
.help-footer {
  text-align: center;
  padding: 0 0 60rpx;
}

.footer-text {
  font-size: var(--fs-26);
}
