page {
  background: #EEF2FF;
}

.sig-header {
  padding: 30rpx 28rpx 32rpx;
}

.sig-title {
  font-size: var(--fs-48);
  font-weight: 600;
  color: #FFFFFF;
}

.sig-subtitle {
  font-size: var(--fs-26);
  color: rgba(255, 255, 255);
}

.sig-content {
  margin-top: -15rpx;
}

/* ====== 签字卡片 ====== */
.sig-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 0 32rpx;
}

.sig-card {
  padding: 24rpx;
  display: flex;
  gap: 24rpx;
  align-items: flex-start;
}

.sig-card-preview {
  width: 240rpx;
  height: 192rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #F8FAFC;
  border: 2rpx solid #E2E8F0;
  flex-shrink: 0;
}

.sig-card-image-wrap {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sig-card-image {
  width: 100%;
  height: 100%;
}

.sig-card-image-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sig-card-loading,
.sig-card-error {
  font-size: var(--fs-24);
  color: #94A3B8;
}

.sig-card-info {
  flex: 1;
  min-width: 0;
}

.sig-card-label {
  font-size: var(--fs-30);
  font-weight: 600;
  color: #1E293B;
}

.sig-card-time {
  margin-top: 8rpx;
  font-size: var(--fs-24);
  color: #94A3B8;
}

.sig-card-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 20rpx;
}

.sig-action-btn {
  font-size: var(--fs-24);
  color: #2563EB;
  padding: 8rpx 0;
}

.sig-action-delete {
  color: #EF4444;
}

/* ====== 空状态 ====== */
.sig-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0 60rpx;
  gap: 16rpx;
}

.sig-empty-icon {
  font-size: 100rpx;
  opacity: 0.7;
}

.sig-empty-text {
  font-size: var(--fs-30);
  color: #64748B;
  font-weight: 500;
}

.sig-empty-hint {
  font-size: var(--fs-24);
  color: #94A3B8;
  margin-top: 4rpx;
}

/* ====== 添加按钮 ====== */
.sig-add-section {
  padding: 32rpx;
}

.sig-add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 28rpx 0;
  background: linear-gradient(135deg, #2563EB 0%, #4F46E5 100%);
  border-radius: 20rpx;
  color: #FFFFFF;
  font-size: var(--fs-30);
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.28);
  transition: all 0.2s ease;
}

.sig-add-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.sig-add-btn-disabled {
  background: #CBD5E1;
  box-shadow: none;
  opacity: 0.7;
}

.sig-add-icon {
  font-size: var(--fs-36);
  font-weight: 300;
  line-height: 1;
}

.sig-add-hint {
  text-align: center;
  font-size: var(--fs-24);
  color: #94A3B8;
  margin-top: 12rpx;
}
