<view class="trip-page">
  <!-- 渐变色头部（带圆角，类似home页） -->
  <view class="office-gradient-header trip-header">
    <view class="trip-header-content">
      <view class="trip-title">外出报备</view>
      <view class="trip-subtitle">记录您的出行信息</view>
    </view>

    
  </view>
<!-- 状态卡片（半透明玻璃效果，始终显示） -->
<view class="trip-status-card {{activeTrip ? 'is-active' : 'is-idle'}}">
      <view class="trip-status-header">
        <view class="trip-status-icon">
          <text wx:if="{{activeTrip}}">🚗</text>
          <text wx:else>🏠</text>
        </view>
        <view class="trip-status-info">
          <view class="trip-status-label">
            <text wx:if="{{activeTrip}}">当前外出中：{{activeTrip.destination}}</text>
            <text wx:else>当前未外出</text>
          </view>
          <view class="trip-status-companion">
            <text wx:if="{{activeTrip}}">同行人：{{activeTrip.companions}}</text>
            <text wx:else>点击下方按钮开始报备</text>
          </view>
        </view>
      </view>
      <view wx:if="{{activeTrip}}" class="trip-status-detail">
        <view class="trip-status-item">
          <text class="trip-status-item-label">计划返回</text>
          <text class="trip-status-item-value">{{activeTrip.plannedReturnText}}</text>
        </view>
        <view class="trip-status-item">
          <text class="trip-status-item-label">出行方式</text>
          <text class="trip-status-item-value">{{activeTrip.travelMode}}</text>
        </view>
        <view wx:if="{{activeTrip.createdByName}}" class="trip-status-item">
          <text class="trip-status-item-label">代报备人</text>
          <text class="trip-status-item-value">{{activeTrip.createdByName}}</text>
        </view>
      </view>
    </view>
  <view class="trip-content">
  
    <!-- 主操作按钮 -->
    <view class="trip-action-section">
      <button class="trip-action-btn {{activeTrip ? 'trip-action-btn-return' : 'trip-action-btn-depart'}}" bindtap="handleMainButton">
        <text wx:if="{{activeTrip}}">🏠 返回报备</text>
        <text wx:else>🚗 外出报备</text>
      </button>
    </view>

    <!-- 出行记录标题 -->
    <view class="trip-section">
      <view class="trip-section-title">出行记录</view>

      <!-- 按月分组列表 -->
      <block wx:for="{{groupedTrips}}" wx:key="monthKey">
        <view class="trip-month-group">
          <view class="trip-month-title">{{item.monthText}}</view>
          <view class="trip-list">
            <view class="trip-item" wx:for="{{item.trips}}" wx:for-item="trip" wx:key="_id">
              <view class="trip-item-header">
                <view class="trip-item-date">{{trip.dateText}}</view>
                <view class="trip-item-time">{{trip.timeRange}}</view>
                <view class="trip-item-status" style="background: {{trip.statusBg}}; color: {{trip.statusColor}};">
                  {{trip.statusIcon}} {{trip.statusText}}
                </view>
              </view>
              <view class="trip-item-body">
                <view class="trip-item-dest">{{trip.destination}}</view>
                <view class="trip-item-meta">
                  <text class="trip-item-mode">🚗 {{trip.travelMode}}</text>
                  <text wx:if="{{trip.companions}}" class="trip-item-companions">👥 {{trip.companions}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </block>

      <!-- 空状态 -->
      <view wx:if="{{!loading && tripList.length === 0}}" class="trip-empty">
        <view class="trip-empty-icon">📋</view>
        <view class="trip-empty-text">暂无出行记录</view>
      </view>

      <!-- 加载更多 -->
      <view wx:if="{{loading}}" class="trip-loading">
        <view class="trip-loading-text">加载中...</view>
      </view>
    </view>
  </view>

  <!-- 底部弹出表单 -->
  <view class="trip-popup-mask {{showFormPopup ? 'is-visible' : ''}}" catchtouchmove="stopPropagation" bindtap="hideFormPopup">
    <view class="trip-popup-container" catchtap="stopPropagation">
      <view class="trip-popup-header">
        <view class="trip-popup-title">外出报备</view>
        <view class="trip-popup-close" bindtap="hideFormPopup">×</view>
      </view>

      <view class="trip-popup-form">
        <view class="trip-field">
          <view class="trip-field-label">目的地 <text class="trip-required">*</text></view>
          <view class="trip-input-wrapper">
            <input 
              class="trip-input" 
              value="{{form.destination}}" 
              placeholder="请输入目的地" 
              placeholder-class="trip-input-placeholder"
              bindinput="handleDestinationInput"
              bindblur="handleDestinationBlur"
            />
          </view>
          <!-- 历史记录快捷选择 -->
          <view wx:if="{{showDestinationHistory && destinationHistory.length > 0}}" class="trip-history-list">
            <view class="trip-history-title">最近使用</view>
            <view class="trip-history-items">
              <view wx:for="{{destinationHistory}}" wx:key="index" class="trip-history-item" bindtap="selectDestinationHistory" data-value="{{item}}">
                {{item}}
              </view>
            </view>
          </view>
        </view>

        <view class="trip-field">
          <view class="trip-field-label">同行人</view>
          <view class="trip-input-wrapper">
            <input 
              class="trip-input" 
              value="{{form.companions}}" 
              placeholder="请输入同行人（选填）" 
              placeholder-class="trip-input-placeholder"
              bindinput="handleCompanionsInput"
              bindblur="handleCompanionsBlur"
            />
          </view>
          <view class="trip-field-hint">多个同行人用空格分隔，系统将自动为同行人代报备</view>
          <!-- 历史记录快捷选择 -->
          <view wx:if="{{showCompanionsHistory && companionsHistory.length > 0}}" class="trip-history-list">
            <view class="trip-history-title">最近使用</view>
            <view class="trip-history-items">
              <view wx:for="{{companionsHistory}}" wx:key="index" class="trip-history-item" bindtap="selectCompanionsHistory" data-value="{{item}}">
                {{item}}
              </view>
            </view>
          </view>
        </view>

        <view class="trip-field">
          <view class="trip-field-label">计划返回时间 <text class="trip-required">*</text></view>
          <view class="trip-datetime-picker">
            <picker mode="date" value="{{form.plannedReturnDate}}" start="{{minReturnDate}}" end="2030-12-31" bindchange="handleReturnDateChange">
              <view class="trip-picker-value">{{form.plannedReturnDate || '选择日期'}}</view>
            </picker>
            <picker mode="time" value="{{form.plannedReturnTime}}" start="{{minReturnTime}}" bindchange="handleReturnTimeChange">
              <view class="trip-picker-value">{{form.plannedReturnTime || '选择时间'}}</view>
            </picker>
          </view>
          <view class="trip-field-hint">计划返回时间需晚于当前时间</view>
        </view>

        <view class="trip-field">
          <view class="trip-field-label">出行方式 <text class="trip-required">*</text></view>
          <picker mode="selector" range="{{travelModes}}" value="{{travelModeIndex >= 0 ? travelModeIndex : 0}}" bindchange="handleTravelModeChange">
            <view class="trip-picker-wrapper {{form.travelMode ? '' : 'is-placeholder'}}">
              <view class="trip-picker-value">{{form.travelMode || '请选择出行方式'}}</view>
              <view class="trip-picker-arrow">›</view>
            </view>
          </picker>
        </view>

        <button class="trip-submit-btn" loading="{{submitting}}" disabled="{{submitting}}" bindtap="submitDepart">
          确认报备
        </button>
      </view>
    </view>
  </view>
</view>
