/* 外出报备页面样式 */

.trip-page {
  min-height: 100vh;
  background: #EEF2FF;
}

/* 头部 - 使用圆角渐变 */
.trip-header {
  padding-bottom: 32rpx;
}

.trip-header-content {
  color: #FFFFFF;
  padding-bottom: 24rpx;
}

.trip-title {
  font-size: 48rpx;
  font-weight: 700;
}

.trip-subtitle {
  font-size: 26rpx;
  padding-top: 5rpx;
}

/* 状态卡片 - 参照 approval-modal-copy 风格 */
.trip-status-card {
  margin: 28rpx;
  padding: 24rpx;
  border-radius: 90rpx;
  transition: all 0.3s ease;
}

.trip-status-card.is-active {
  /* 外出中 - 黄色 */
  background: #FEF3C7;
  border: 1rpx solid #92400E;
}

.trip-status-card.is-active .trip-status-label {
  color: #92400E;
}

.trip-status-card.is-active .trip-status-companion {
  color: #B45309;
}

.trip-status-card.is-active .trip-status-item-label {
  color: #92400E;
  opacity: 0.8;
}

.trip-status-card.is-active .trip-status-item-value {
  color: #92400E;
}

.trip-status-card.is-active .trip-status-detail {
  border-top-color: #92400E;
}

.trip-status-card.is-idle {
  /* 未外出 - 绿色 */
  background: #DCFCE7;
  border: 1rpx solid #166534;
}

.trip-status-card.is-idle .trip-status-label {
  color: #166534;
}

.trip-status-card.is-idle .trip-status-companion {
  color: #15803D;
}

.trip-status-card.is-idle .trip-status-item-label {
  color: #166534;
  opacity: 0.8;
}

.trip-status-card.is-idle .trip-status-item-value {
  color: #166534;
}

.trip-status-card.is-idle .trip-status-detail {
  border-top-color: rgba(74, 222, 128, 0.6);
}

.trip-status-header {
  display: flex;
  align-items: center;
}

.trip-status-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255,0);
  font-size: 72rpx;
  margin-right: 16rpx;
}

.trip-status-info {
  flex: 1;
}

.trip-status-label {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.trip-status-companion {
  font-size: 24rpx;
  font-weight: 500;
}

.trip-status-detail {
  display: flex;
  gap: 32rpx;
  padding-top: 20rpx;
  margin-top: 20rpx;
  border-top: 1rpx solid;
}

.trip-status-item {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.trip-status-item-label {
  font-size: 22rpx;
}

.trip-status-item-value {
  font-size: 28rpx;
  font-weight: 500;
}

/* 内容区 */
.trip-content {
  padding: 0 24rpx 12rpx;
  padding-bottom: 100rpx;
  margin-top: -8rpx;
}

/* 操作按钮 */
.trip-action-section {
  margin-bottom: 32rpx;
}

.trip-action-btn {
  width: 100%;
  height: 100rpx;
  border-radius: 20rpx;
  font-size: 34rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.trip-action-btn-depart {
  background: linear-gradient(135deg, #2563EB 0%, #4F46E5 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.3);
}

.trip-action-btn-return {
  background: linear-gradient(135deg, #16A34A 0%, #059669 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(22, 163, 74, 0.3);
}

.trip-action-btn:active {
  transform: scale(0.98);
}

/* 章节标题 */
.trip-section {
  margin-top: 16rpx;
}

.trip-section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 20rpx;
  padding-left: 8rpx;
}

/* 月份分组 */
.trip-month-group {
  margin-bottom: 24rpx;
}

.trip-month-title {
  font-size: 26rpx;
  color: #64748B;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

/* 列表 */
.trip-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 记录卡片 */
.trip-item {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.trip-item-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.trip-item-date {
  font-size: 32rpx;
  font-weight: 600;
  color: #1E293B;
  margin-right: 16rpx;
}

.trip-item-time {
  font-size: 26rpx;
  color: #64748B;
  flex: 1;
}

.trip-item-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.trip-item-body {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.trip-item-dest {
  font-size: 28rpx;
  color: #1E293B;
  font-weight: 500;
}

.trip-item-meta {
  display: flex;
  gap: 20rpx;
}

.trip-item-mode,
.trip-item-companions {
  font-size: 24rpx;
  color: #64748B;
}

/* 空状态 */
.trip-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.trip-empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.trip-empty-text {
  font-size: 28rpx;
  color: #94A3B8;
}

/* 加载状态 */
.trip-loading {
  display: flex;
  justify-content: center;
  padding: 32rpx 0;
}

.trip-loading-text {
  font-size: 26rpx;
  color: #94A3B8;
}

/* 弹窗遮罩 */
.trip-popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.trip-popup-mask.is-visible {
  opacity: 1;
  visibility: visible;
}

/* 弹窗容器 */
.trip-popup-container {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 90vh;
  overflow-y: auto;
  margin: 0 28rpx 0;
}

.trip-popup-mask.is-visible .trip-popup-container {
  transform: translateY(0);
}

/* 弹窗头部 */
.trip-popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #F1F5F9;
  position: sticky;
  top: 0;
  background: #FFFFFF;
  z-index: 1;
}

.trip-popup-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1E293B;
}

.trip-popup-close {
  font-size: 48rpx;
  color: #94A3B8;
  line-height: 1;
  padding: 0 8rpx;
}

/* 表单 */
.trip-popup-form {
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.trip-field {
  margin-bottom: 28rpx;
}

.trip-field-label {
  font-size: 28rpx;
  color: #1E293B;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.trip-required {
  color: #DC2626;
}

.trip-field-hint {
  font-size: 22rpx;
  color: #94A3B8;
  margin-top: 8rpx;
}

.trip-input-wrapper {
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 0 24rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
}

.trip-input {
  flex: 1;
  font-size: 28rpx;
  color: #1E293B;
}

.trip-input-placeholder {
  color: #94A3B8;
}

/* 历史记录列表 */
.trip-history-list {
  margin-top: 12rpx;
  background: #F8FAFC;
  border-radius: 12rpx;
  padding: 16rpx;
}

.trip-history-title {
  font-size: 22rpx;
  color: #94A3B8;
  margin-bottom: 12rpx;
}

.trip-history-items {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.trip-history-item {
  background: #FFFFFF;
  border: 1rpx solid #E2E8F0;
  border-radius: 8rpx;
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  color: #475569;
  transition: all 0.2s ease;
}

.trip-history-item:active {
  background: #EEF2FF;
  border-color: #2563EB;
  color: #2563EB;
}

/* 日期时间选择器 */
.trip-datetime-picker {
  display: flex;
  gap: 16rpx;
}

.trip-datetime-picker picker {
  flex: 1;
}

.trip-picker-value {
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 0 24rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #1E293B;
}

/* 下拉选择器 */
.trip-picker-wrapper {
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 0 24rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.trip-picker-wrapper.is-placeholder .trip-picker-value {
  color: #94A3B8;
}

.trip-picker-arrow {
  font-size: 36rpx;
  color: #94A3B8;
  font-weight: 300;
}

/* 提交按钮 */
.trip-submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #2563EB 0%, #4F46E5 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
  margin-top: 20rpx;
}

.trip-submit-btn[disabled] {
  background: #94A3B8;
}
