page {
  background-color: #F8FAFC;
  height: 100%;
}

/* ===== 导航栏 ===== */
.news-navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: linear-gradient(135deg, #1E3A5F 0%, #2563EB 100%);
  padding-left: 24rpx;
  padding-right: 24rpx;
}

.news-navbar-inner {
  height: 44px;
  display: flex;
  align-items: center;
}

.news-navbar-title {
  font-size: 22px;
  font-weight: bold;
  color: #FFFFFF;
}

/* ===== 页面容器 ===== */
.news-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #F8FAFC;
  width: 100%;
  box-sizing: border-box;
}

/* ===== 来源Tab ===== */
.news-sources {
  white-space: nowrap;
  padding: 16rpx 24rpx;
  background-color: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  flex-shrink: 0;
}

.news-sources-inner {
  display: inline-flex;
  gap: 16rpx;
}

.news-source-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  font-size: var(--fs-24);
  color: #64748B;
  background: #F1F5F9;
}

.news-source-item.is-active {
  background: #1E3A5F;
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(30, 58, 95, 0.3);
}

/* ===== 滚动区容器 ===== */
.news-scroll-wrap {
  flex: 1;
  width: 100%;
  overflow: hidden;
}

/* ===== 滚动区 ===== */
.news-scroll {
  width: 100%;
  height: 100%;
  padding: 16rpx 24rpx;
  box-sizing: border-box;
}

/* ===== 新闻列表 ===== */
.news-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* ===== 新闻卡片 ===== */
.news-card {
  display: flex;
  gap: 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: box-shadow 0.2s;
}

.news-card:active {
  box-shadow: 0 2rpx 20rpx rgba(0, 0, 0, 0.1);
}

/* 封面图 */
.news-card-image {
  width: 200rpx;
  height: 150rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
  background: #F1F5F9;
}

.news-card-img {
  width: 100%;
  height: 100%;
}

.news-card-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #EEF2FF 0%, #DBEAFE 100%);
}

.news-placeholder-icon {
  font-size: var(--fs-56);
}

/* 右侧内容 */
.news-card-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.news-card-title {
  font-size: var(--fs-28);
  font-weight: 600;
  color: #0F172A;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.news-card-summary {
  font-size: var(--fs-24);
  color: #64748B;
  line-height: 1.5;
  margin-top: 8rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.news-card-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 12rpx;
}

.news-card-source {
  font-size: var(--fs-20);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.news-card-source.source-globo {
  background: #FEF3C7;
  color: #92400E;
}

.news-card-source.source-folha {
  background: #DBEAFE;
  color: #1E40AF;
}

.news-card-source.source-estadao {
  background: #FCE7F3;
  color: #9D174D;
}

.news-card-time {
  font-size: var(--fs-22);
  color: #94A3B8;
}

/* ===== 加载更多 ===== */
.news-load-more {
  padding: 24rpx 0 40rpx;
  text-align: center;
  font-size: var(--fs-24);
  color: #94A3B8;
}

/* ===== 空状态 ===== */
.news-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.news-empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.news-empty-text {
  font-size: var(--fs-28);
  color: #94A3B8;
}
