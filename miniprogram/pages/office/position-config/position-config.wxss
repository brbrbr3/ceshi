/* 岗位配置页 */
.position-config-page {
  min-height: 100vh;
  background: #F5F5F5;
}

.position-config-header {
  padding: 30rpx 28rpx 32rpx;
}

.position-config-title {
  font-size: var(--fs-48);
  font-weight: 600;
  color: #FFFFFF;
}

.position-config-subtitle {
  font-size: var(--fs-26);
  color: rgba(255, 255, 255);
}

.position-config-loading {
  padding: 80rpx 0;
  text-align: center;
}

.position-config-loading-text {
  color: #9CA3AF;
  font-size: var(--fs-28);
}

/* 岗位分组 */
.position-group {
  margin-bottom: 24rpx;
}

.position-group-card {
  padding: 0 !important;
  overflow: hidden;
}

.position-group-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #F3F4F6;
}

.position-group-name {
  font-size: var(--fs-30);
  font-weight: 600;
  color: #1F2937;
}

.position-group-count {
  font-size: var(--fs-24);
  color: #6B7280;
  background: #F3F4F6;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.position-group-empty {
  padding: 24rpx 32rpx;
  font-size: var(--fs-26);
  color: #9CA3AF;
}

/* 用户列表 */
.position-user-list {
  padding: 0 32rpx;
}

.position-user-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F9FAFB;
}

.position-user-item:last-child {
  border-bottom: none;
}

.position-user-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667EEA, #764BA2);
  color: #FFFFFF;
  font-size: var(--fs-26);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.position-user-info {
  flex: 1;
}

.position-user-name {
  font-size: var(--fs-28);
  color: #1F2937;
  font-weight: 500;
}

.position-user-role {
  font-size: var(--fs-24);
  color: #6B7280;
  margin-top: 4rpx;
}

.position-user-remove {
  font-size: var(--fs-24);
  color: #DC2626;
  padding: 8rpx 20rpx;
  border: 1rpx solid #FCA5A5;
  border-radius: 8rpx;
  flex-shrink: 0;
}

/* 添加按钮 */
.position-group-add {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #F3F4F6;
}

.position-group-add-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #EFF6FF;
  color: #2563EB;
  font-size: var(--fs-30);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
}

.position-group-add-text {
  font-size: var(--fs-28);
  color: #2563EB;
}

/* 弹窗 */
.position-add-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  animation: fadeIn 0.2s ease;
}

.position-add-mask.is-hidden {
  display: none;
}

.position-add-mask.is-closing {
  animation: fadeOut 0.25s ease forwards;
}

.position-add-container {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  border-radius: 24rpx 24rpx 0 0;
  height: 70vh;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
}

.is-closing .position-add-container {
  animation: slideDown 0.25s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
}

.position-add-title {
  font-size: var(--fs-32);
  font-weight: 600;
  color: #1F2937;
  padding: 32rpx 32rpx 16rpx;
  text-align: center;
}

.position-add-search {
  padding: 0 32rpx 16rpx;
}

.position-add-search-input {
  display: block;
  width: 100%;
  box-sizing: border-box;
  background: #F3F4F6;
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  font-size: var(--fs-28);
  height: 60rpx;
  line-height: 60rpx;
}

.position-add-list {
  flex: 1;
  overflow-y: auto;
  padding: 0 32rpx 32rpx;
}

.position-add-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F9FAFB;
}

.position-add-item-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667EEA, #764BA2);
  color: #FFFFFF;
  font-size: var(--fs-22);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.position-add-item-info {
  flex: 1;
}

.position-add-item-name {
  font-size: var(--fs-28);
  color: #1F2937;
}

.position-add-item-detail {
  font-size: var(--fs-24);
  color: #6B7280;
}

.position-add-item-btn {
  font-size: var(--fs-24);
  color: #2563EB;
  background: #EFF6FF;
  padding: 8rpx 24rpx;
  border-radius: 8rpx;
}

.position-add-empty {
  text-align: center;
  padding: 40rpx 0;
  color: #9CA3AF;
  font-size: var(--fs-26);
}

/* 动画 */
@keyframes fadeIn {
  from {
    opacity: 0;
  }

  to {
    opacity: 1;
  }
}

@keyframes fadeOut {
  from {
    opacity: 1;
  }

  to {
    opacity: 0;
  }
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }

  to {
    transform: translateY(0);
  }
}

@keyframes slideDown {
  from {
    transform: translateY(0);
  }

  to {
    transform: translateY(100%);
  }
}