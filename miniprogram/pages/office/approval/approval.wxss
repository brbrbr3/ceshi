page {
  background: #EEF2FF;
}

.approval-header {
  padding-bottom: 164rpx;
}

.approval-title {
  font-size: 40rpx;
  font-weight: 600;
}

.approval-subtitle {
  margin-top: 10rpx;
  font-size: 22rpx;
  opacity: 0.76;
}

.approval-launch-btn {
  padding: 14rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  font-size: 24rpx;
  font-weight: 600;
  text-align: center;
}

.approval-tabs-shell {
  margin-top: 30rpx;
  padding: 6rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.15);
  display: flex;
}

.approval-tab {
  flex: 1;
  height: 72rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 24rpx;
}

.approval-tab.is-active {
  background: rgba(255, 255, 255, 0.95);
  color: #2563EB;
  font-weight: 600;
}

.approval-tab-count {
  font-size: 20rpx;
}

.approval-type-card,
.approval-summary-card,
.approval-list-card,
.approval-note-card {
  padding: 24rpx;
}

.approval-type-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx 12rpx;
}

.approval-type-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.approval-type-icon {
  width: 92rpx;
  height: 92rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.approval-type-label {
  margin-top: 14rpx;
  text-align: center;
  line-height: 1.4;
  font-size: 22rpx;
  color: #4B6080;
}

.approval-note-card {
  margin-top: 24rpx;
  background: linear-gradient(180deg, #FFFFFF 0%, #F8FAFC 100%);
}

.approval-note-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
}

.approval-note-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #64748B;
}

.approval-summary-card {
  margin-top: 24rpx;
  background: linear-gradient(180deg, #F5FAFF 0%, #FFFFFF 100%);
}

.approval-summary-top {
  font-size: 24rpx;
  font-weight: 600;
  color: #1E293B;
}

.approval-summary-grid {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.approval-summary-grid.is-three {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.approval-summary-label,
.approval-person-sub,
.approval-detail,
.approval-time,
.approval-filter,
.approval-meta {
  font-size: 22rpx;
  color: #94A3B8;
}

.approval-summary-value {
  margin-top: 8rpx;
  font-size: 38rpx;
  font-weight: 700;
  color: #1E293B;
}

.approval-summary-value text {
  font-size: 22rpx;
  font-weight: 400;
}

.approval-list-header {
  margin-top: 28rpx;
  margin-bottom: 16rpx;
}

.approval-list-card + .approval-list-card {
  margin-top: 20rpx;
}

.approval-list-top,
.approval-person,
.approval-person-row,
.approval-actions,
.approval-modal-head,
.approval-modal-row,
.approval-modal-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.approval-person {
  gap: 18rpx;
}

.approval-person-main {
  flex: 1;
}

.approval-person-row {
  justify-content: flex-start;
  gap: 10rpx;
}

.approval-person-name,
.approval-type-title,
.approval-modal-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1E293B;
}

.approval-type-title {
  margin-top: 22rpx;
}

.approval-detail {
  margin-top: 12rpx;
  color: #4B6080;
}

.approval-meta {
  margin-top: 8rpx;
}

.approval-time {
  margin-top: 10rpx;
}

.approval-urgent {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #FFEBEE;
  color: #F44336;
  font-size: 18rpx;
}

.approval-actions,
.approval-modal-actions {
  gap: 18rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(37, 99, 235, 0.1);
}

.approval-reject-btn,
.approval-approve-btn {
  flex: 1;
  height: 78rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
}

.approval-reject-btn {
  background: #F8FAFC;
  color: #4B6080;
}

.approval-empty-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  margin: 0 auto 20rpx;
  background: #EFF6FF;
  color: #2563EB;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  font-weight: 700;
}

.approval-modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.42);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 24rpx;
  box-sizing: border-box;
  z-index: 20;
}

.approval-modal-card {
  width: 100%;
  border-radius: 32rpx;
  background: #FFFFFF;
  padding: 28rpx;
  box-sizing: border-box;
}

.approval-modal-sub,
.approval-modal-label {
  font-size: 22rpx;
  color: #94A3B8;
}

.approval-modal-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: #F8FAFC;
  color: #64748B;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.approval-modal-body {
  margin-top: 24rpx;
}

.approval-modal-row + .approval-modal-row {
  margin-top: 18rpx;
}

.approval-modal-value {
  font-size: 24rpx;
  color: #1E293B;
  font-weight: 600;
}

.approval-modal-remark {
  margin-top: 24rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: #F8FAFC;
  color: #475569;
  font-size: 22rpx;
  line-height: 1.7;
}
