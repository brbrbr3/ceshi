page {
  background: #EEF2FF;
}

/* 分页加载样式 */
.pagination-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 0;
  background: #EEF2FF;
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid #e0e0e0;
  border-top-color: #1890ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-right: 16rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.pagination-no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 0;
  background: #EEF2FF;
}

.no-more-text {
  font-size: 24rpx;
  color: #ccc;
}


.approval-header {
  padding-bottom: 164rpx;
}

.approval-title {
  font-size: 40rpx;
  font-weight: 600;
}

.approval-subtitle {
  margin-top: 10rpx;
  font-size: 22rpx;
  opacity: 0.76;
}

.approval-launch-btn {
  padding: 14rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  font-size: 24rpx;
  font-weight: 600;
  text-align: center;
}

.approval-tabs-shell {
  margin-top: 30rpx;
  padding: 6rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.15);
  display: flex;
}

.approval-tab {
  flex: 1;
  height: 72rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 24rpx;
}

.approval-tab.is-active {
  background: rgba(255, 255, 255, 0.95);
  color: #2563EB;
  font-weight: 600;
}

.approval-tab-count {
  font-size: 20rpx;
}

.approval-type-card,
.approval-summary-card,
.approval-list-card,
.approval-note-card {
  padding: 24rpx;
}

.approval-type-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx 12rpx;
}

.approval-type-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.approval-type-icon {
  width: 92rpx;
  height: 92rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.approval-type-label {
  margin-top: 14rpx;
  text-align: center;
  line-height: 1.4;
  font-size: 22rpx;
  color: #4B6080;
}

.approval-note-card {
  margin-top: 24rpx;
  background: linear-gradient(180deg, #FFFFFF 0%, #F8FAFC 100%);
}

.approval-note-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
}

.approval-note-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #64748B;
}

.approval-summary-card {
  margin-top: 24rpx;
  background: linear-gradient(180deg, #F5FAFF 0%, #FFFFFF 100%);
}

.approval-summary-top {
  font-size: 24rpx;
  font-weight: 600;
  color: #1E293B;
}

.approval-summary-grid {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.approval-summary-grid.is-three {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.approval-summary-label,
.approval-person-sub,
.approval-detail,
.approval-time,
.approval-filter,
.approval-meta {
  font-size: 22rpx;
  color: #94A3B8;
}

.approval-summary-value {
  margin-top: 8rpx;
  font-size: 38rpx;
  font-weight: 700;
  color: #1E293B;
}

.approval-summary-value text {
  font-size: 22rpx;
  font-weight: 400;
}

.approval-list-header {
  margin-top: 28rpx;
  margin-bottom: 16rpx;
}

.approval-list-card + .approval-list-card {
  margin-top: 20rpx;
}

.approval-list-top,
.approval-person,
.approval-person-row,
.approval-actions,
.approval-modal-head,
.approval-modal-row,
.approval-modal-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.approval-person {
  gap: 18rpx;
}

.approval-person-main {
  flex: 1;
}

.approval-person-row {
  justify-content: flex-start;
  gap: 10rpx;
}

.approval-person-name,
.approval-type-title,
.approval-modal-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1E293B;
}

.approval-type-title {
  margin-top: 22rpx;
}

.approval-detail {
  margin-top: 12rpx;
  color: #4B6080;
}

.approval-meta {
  margin-top: 8rpx;
}

.approval-time {
  margin-top: 10rpx;
}

.approval-urgent {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #FFEBEE;
  color: #F44336;
  font-size: 18rpx;
}

.approval-actions,
.approval-modal-actions {
  gap: 18rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(37, 99, 235, 0.1);
}

.approval-reject-btn,
.approval-approve-btn {
  flex: 1;
  height: 78rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  transition: all 0.3s ease;
  position: relative;
}

.approval-reject-btn {
  background: #F8FAFC;
  color: #4B6080;
}

.approval-reject-btn.is-disabled,
.approval-approve-btn.is-disabled {
  opacity: 0.6;
  pointer-events: none;
}

/* 加载动画 */
.approval-reject-btn.is-disabled::after,
.approval-approve-btn.is-disabled::after {
  content: '';
  position: absolute;
  right: 20rpx;
  width: 24rpx;
  height: 24rpx;
  border: 3rpx solid currentColor;
  border-top-color: transparent;
  border-right-color: transparent;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  opacity: 0.8;
}

@keyframes spin {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}

.approval-empty-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  margin: 0 auto 20rpx;
  background: #EFF6FF;
  color: #2563EB;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  font-weight: 700;
}

.approval-modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.42);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 24rpx;
  box-sizing: border-box;
  z-index: 20;
}

.approval-modal-card {
  width: 100%;
  border-radius: 32rpx;
  background: #FFFFFF;
  padding: 28rpx;
  box-sizing: border-box;
}

.approval-modal-sub,
.approval-modal-label {
  font-size: 22rpx;
  color: #94A3B8;
}

.approval-modal-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: #F8FAFC;
  color: #64748B;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.approval-modal-body {
  margin-top: 24rpx;
}

.approval-modal-row + .approval-modal-row {
  margin-top: 18rpx;
}

.approval-modal-value {
  font-size: 24rpx;
  color: #1E293B;
  font-weight: 600;
}

.approval-modal-remark {
  margin-top: 24rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: #F8FAFC;
  color: #475569;
  font-size: 22rpx;
  line-height: 1.7;
}

/* 就医申请进度条样式 */
.approval-progress {
  margin-top: 16rpx;
  padding: 24rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
}

/* 详情弹窗中的进度条样式 */
.approval-modal-progress {
  margin-top: 24rpx;
  padding: 24rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
}

.approval-modal-progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.approval-modal-progress-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.approval-modal-progress-step {
  font-size: 24rpx;
  font-weight: 600;
  color: #1E293B;
}

.approval-modal-progress-text {
  font-size: 22rpx;
  color: #9CA3AF;
}

.approval-modal-progress-bar {
  width: 100%;
  height: 8rpx;
  background: #E5E7EB;
  border-radius: 4rpx;
  overflow: hidden;
}

.approval-modal-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #2563EB 0%, #1D4ED8 100%);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.approval-progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.approval-progress-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.approval-progress-step {
  font-size: 24rpx;
  font-weight: 600;
  color: #1E293B;
}

.approval-progress-text {
  font-size: 22rpx;
  color: #9CA3AF;
}

.approval-progress-bar {
  width: 100%;
  height: 8rpx;
  background: #E5E7EB;
  border-radius: 4rpx;
  overflow: hidden;
}

.approval-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #2563EB 0%, #1D4ED8 100%);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.approval-modal-copy {
  margin-top: 24rpx;
  padding: 24rpx;
  background: #FEF3C7;
  border-radius: 12rpx;
  border: 1rpx solid #FCD34D;
}

.approval-modal-copy-text {
  font-size: 24rpx;
  color: #92400E;
  margin-bottom: 16rpx;
  line-height: 1.6;
}

.approval-copy-btn {
  width: 100%;
  background: linear-gradient(135deg, #2563EB 0%, #1D4ED8 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 16rpx;
  height: 88rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-sizing: border-box;
}

.approval-copy-btn::after {
  border: none;
}

/* 工作流日志样式 */
.approval-modal-logs {
  margin-top: 24rpx;
  padding: 24rpx;
  background: #F8FAFC;
  border-radius: 12rpx;
}

.approval-modal-logs-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 16rpx;
}

.approval-modal-logs-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.approval-modal-logs-item {
  padding: 16rpx;
  background: #FFFFFF;
  border-radius: 8rpx;
  border-left: 3rpx solid #2563EB;
}

.approval-modal-logs-item.is-error {
  border-left-color: #DC2626;
}

.approval-modal-logs-action {
  font-size: 26rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 8rpx;
}

.approval-modal-logs-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.approval-modal-logs-operator {
  font-size: 24rpx;
  color: #6B7280;
  font-weight: 500;
}

.approval-modal-logs-time {
  font-size: 22rpx;
  color: #9CA3AF;
}

.approval-modal-logs-desc {
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.6;
  padding-top: 8rpx;
  border-top: 1rpx solid #F3F4F6;
  margin-top: 8rpx;
}

/* 空状态提示 */
.approval-modal-logs-empty {
  font-size: 24rpx;
  color: #9CA3AF;
  text-align: center;
  padding: 32rpx 0;
  line-height: 1.6;
}

/* 中止申请按钮样式 */
.approval-modal-terminate {
  margin-top: 24rpx;
  padding: 24rpx;
  background: #FEE2E2;
  border-radius: 12rpx;
  border: 1rpx solid #FCA5A5;
}

.approval-modal-terminate-text {
  font-size: 24rpx;
  color: #991B1B;
  margin-bottom: 16rpx;
  line-height: 1.6;
}

.approval-terminate-btn {
  width: 100%;
  background: #DC2626;
  color: #FFFFFF;
  border: none;
  border-radius: 16rpx;
  height: 88rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  position: relative;
}

.approval-terminate-btn.is-disabled {
  opacity: 0.6;
  pointer-events: none;
}

/* 加载动画 */
.approval-terminate-btn.is-disabled::after {
  content: '';
  position: absolute;
  right: 20rpx;
  width: 28rpx;
  height: 28rpx;
  border: 3rpx solid #FFFFFF;
  border-top-color: transparent;
  border-right-color: transparent;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  opacity: 0.8;
}

@keyframes spin {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}


