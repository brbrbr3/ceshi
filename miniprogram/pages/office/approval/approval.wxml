<view class="office-page approval-page">
  <view class="office-gradient-header approval-header">
    <view class="office-header-top">
      <view>
        <view class="approval-title">审批中心</view>
        <view class="approval-subtitle">馆领导、部门负责人及管理员可处理申请，普通用户只能查看自己提交的申请</view>
      </view>
      <view class="approval-launch-btn" bindtap="showLaunchTip">
      {{canReview ? '有审批权' : '无审批权'}}
      </view>
    </view>

    <view class="approval-tabs-shell">
      <view
        wx:for="{{tabs}}"
        wx:key="key"
        class="approval-tab {{activeTab == item.key ? 'is-active' : ''}}"
        data-tab="{{item.key}}"
        bindtap="switchTab"
      >
        <text>{{item.label}}</text>
        <text class="approval-tab-count">{{item.count}}</text>
      </view>
    </view>
  </view>

  <view class="office-content">
    <!-- <view wx:if="{{activeTab == 'pending' && canReview}}" class="office-card approval-type-card">
      <view class="approval-type-grid">
        <view class="approval-type-item" wx:for="{{approvalTypes}}" wx:key="label">
          <view class="approval-type-icon" style="background: {{item.bg}}; color: {{item.color}};">{{item.icon}}</view>
          <view class="approval-type-label">{{item.label}}</view>
        </view>
      </view>
    </view> -->

    <view wx:if="{{!canReview}}" class="office-card approval-note-card">
      <view class="approval-note-title">当前账号暂无管理员权限</view>
      <view class="approval-note-desc">你仍可在"我发起的"分组中查看自己的申请状态。</view>
    </view>

    <view wx:if="{{canReview}}" class="office-card approval-summary-card">
      <view class="approval-summary-top">审批概览</view>
      <view class="approval-summary-grid is-three">
        <view>
          <view class="approval-summary-label">待审批</view>
          <view class="approval-summary-value">{{summary.pendingCount}} <text>条</text></view>
        </view>
        <view>
          <view class="approval-summary-label">已通过</view>
          <view class="approval-summary-value">{{summary.approvedCount}} <text>条</text></view>
        </view>
        <view>
          <view class="approval-summary-label">已驳回</view>
          <view class="approval-summary-value">{{summary.rejectedCount}} <text>条</text></view>
        </view>
      </view>
    </view>

    <view class="office-section-header approval-list-header">
      <view class="office-section-title">{{activeTab == 'pending' ? '待处理申请' : activeTab == 'mine' ? '我发起的申请' : '历史处理记录'}}</view>
      <view class="approval-filter">{{loading ? '加载中…' : '点击卡片查看详情'}}</view>
    </view>

    <view wx:if="{{currentList.length}}">
      <view class="office-card approval-list-card" wx:for="{{currentList}}" wx:key="id" data-id="{{item.id}}" bindtap="openRequestDetail">
        <view class="approval-list-top">
          <view class="approval-person">
            <view class="office-avatar" style="background: {{item.avatarColor}};">{{item.avatar}}</view>
            <view class="approval-person-main">
              <view class="approval-person-row">
                <view class="approval-person-name">{{item.name}}</view>
                <view wx:if="{{item.urgent}}" class="approval-urgent">管理员</view>
              </view>
              <view class="approval-person-sub">{{item.dept}}</view>
            </view>
          </view>
          <view class="office-pill" style="background: {{item.statusBg}}; color: {{item.statusColor}};">{{item.status}}</view>
        </view>

        <view class="approval-type-title">{{item.requestType}}</view>
        <view class="approval-detail">{{item.detail}}</view>
        <view class="approval-meta">{{item.requestNo}}</view>
        <view class="approval-time">{{item.time}}</view>

        <!-- 就医申请进度条 -->
        <view wx:if="{{item.showProgress && item.progress}}" class="approval-progress">
          <view class="approval-progress-header">
            <view class="approval-progress-info">
              <view class="approval-progress-step">第 {{item.progress.currentStep}}/{{item.progress.totalSteps}} 步</view>
              <view class="approval-progress-text">{{item.progress.currentText}}</view>
            </view>
          </view>
          <view class="approval-progress-bar">
            <view class="approval-progress-fill" style="width: {{item.progress.percent}}%;"></view>
          </view>
        </view>

        <view wx:if="{{activeTab == 'pending' && canReview}}" class="approval-actions">
          <view class="approval-reject-btn" data-id="{{item.id}}" data-decision="reject" catchtap="handleReview">驳回</view>
          <view class="office-btn-primary approval-approve-btn" data-id="{{item.id}}" data-decision="approve" catchtap="handleReview">同意</view>
        </view>
      </view>
    </view>

    <view wx:else class="office-card office-empty">
      <view class="approval-empty-icon">✓</view>
      <view>{{emptyText}}</view>
    </view>
  </view>

  <view wx:if="{{showDetail && selectedRequest}}" class="approval-modal-mask" bindtap="closeDetail">
    <view class="approval-modal-card" catchtap="noop">
      <view class="approval-modal-head">
        <view>
          <view class="approval-modal-title">{{selectedRequest.name}}的{{selectedRequest.requestType}}详情</view>
          <view class="approval-modal-sub">{{selectedRequest.requestNo}}</view>
        </view>
        <view class="approval-modal-close" bindtap="closeDetail">×</view>
      </view>

      <view class="approval-modal-body">
        <!-- 就医申请详情 -->
        <block wx:if="{{selectedRequest.orderType === 'medical_application'}}">
          <view class="approval-modal-row">
            <text class="approval-modal-label">就医人姓名</text>
            <text class="approval-modal-value">{{selectedRequest.patientName || ''}}</text>
          </view>
          <view class="approval-modal-row">
            <text class="approval-modal-label">与申请人关系</text>
            <text class="approval-modal-value">{{selectedRequest.relation || ''}}</text>
          </view>
          <view class="approval-modal-row">
            <text class="approval-modal-label">就医时间</text>
            <text class="approval-modal-value">{{selectedRequest.medicalDate || ''}}</text>
          </view>
          <view class="approval-modal-row">
            <text class="approval-modal-label">就医机构</text>
            <text class="approval-modal-value">{{selectedRequest.institution || ''}}</text>
          </view>
          <block wx:if="{{selectedRequest.institution === '其他'}}">
            <view class="approval-modal-row">
              <text class="approval-modal-label">机构名称</text>
              <text class="approval-modal-value">{{selectedRequest.otherInstitution || ''}}</text>
            </view>
            <view class="approval-modal-row">
              <text class="approval-modal-label">选择此机构的原因</text>
              <text class="approval-modal-value">{{selectedRequest.reasonForSelection || ''}}</text>
            </view>
          </block>
          <view class="approval-modal-row">
            <text class="approval-modal-label">就医原因</text>
            <text class="approval-modal-value">{{selectedRequest.reason || ''}}</text>
          </view>

          <!-- 进度条 -->
          <block wx:if="{{selectedRequest.showProgress && selectedRequest.progress}}">
            <view class="approval-modal-progress">
              <view class="approval-modal-progress-header">
                <view class="approval-modal-progress-info">
                  <view class="approval-modal-progress-step">第 {{selectedRequest.progress.currentStep}}/{{selectedRequest.progress.totalSteps}} 步</view>
                  <view class="approval-modal-progress-text">{{selectedRequest.progress.currentText}}</view>
                </view>
              </view>
              <view class="approval-modal-progress-bar">
                <view class="approval-modal-progress-fill" style="width: {{selectedRequest.progress.percent}}%;"></view>
              </view>
            </view>
          </block>
        </block>

        <!-- 注册申请详情 -->
        <block wx:else>
          <view class="approval-modal-row">
            <text class="approval-modal-label">姓名</text>
            <text class="approval-modal-value">{{selectedRequest.name}}</text>
          </view>
          <view class="approval-modal-row">
            <text class="approval-modal-label">性别</text>
            <text class="approval-modal-value">{{selectedRequest.gender}}</text>
          </view>
          <view class="approval-modal-row">
            <text class="approval-modal-label">出生日期</text>
            <text class="approval-modal-value">{{selectedRequest.birthday}}</text>
          </view>
          <view class="approval-modal-row">
            <text class="approval-modal-label">角色</text>
            <text class="approval-modal-value">{{selectedRequest.role}}</text>
          </view>
          <block wx:if="{{selectedRequest.relativeName}}">
            <view class="approval-modal-row">
              <text class="approval-modal-label">亲属姓名</text>
              <text class="approval-modal-value">{{selectedRequest.relativeName}}</text>
            </view>
          </block>
          <view class="approval-modal-row">
            <text class="approval-modal-label">岗位</text>
            <text class="approval-modal-value">{{selectedRequest.position}}</text>
          </view>
          <view class="approval-modal-row">
            <text class="approval-modal-label">管理员</text>
            <text class="approval-modal-value">{{selectedRequest.isAdmin ? '是' : '否'}}</text>
          </view>
        </block>

        <view class="approval-modal-row">
          <text class="approval-modal-label">当前状态</text>
          <text class="approval-modal-value">{{selectedRequest.status === 'approved' ? '已通过' : selectedRequest.status === 'rejected' ? '已驳回' : '待审批'}}</text>
        </view>
        <view wx:if="{{selectedRequest.reviewRemark}}" class="approval-modal-remark">{{selectedRequest.reviewRemark}}</view>
      </view>

      <view wx:if="{{canReview && selectedRequest.status === 'pending' && selectedRequest.isCurrentApprover}}" class="approval-modal-actions">
        <view class="approval-reject-btn" data-decision="reject" bindtap="handleReview">驳回</view>
        <view class="office-btn-primary approval-approve-btn" data-decision="approve" bindtap="handleReview">同意</view>
      </view>

      <!-- 就医申请被驳回后的复制申请按钮 -->
      <view wx:if="{{selectedRequest.status === 'rejected' && selectedRequest.orderType === 'medical_application'}}" class="approval-modal-copy">
        <view class="approval-modal-copy-text">该申请已被驳回，是否依据此申请信息重新创建？</view>
        <view class="office-btn-primary approval-copy-btn" bindtap="copyAndResubmitMedical">重新创建申请</view>
      </view>
    </view>
  </view>
</view>
