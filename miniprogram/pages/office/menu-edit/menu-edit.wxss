.menu-edit-page {
  min-height: 100%;
}

.menu-edit-header {
  text-align: center;
  padding-bottom: 100rpx;
}

.menu-edit-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.menu-edit-content {
  margin-top: -60rpx;
}

.menu-edit-form {
  padding: 28rpx;
}

.menu-editor-wrapper {
  border-radius: 24rpx;
  overflow: hidden;
  background: #F8FAFC;
  border: 2rpx solid transparent;
}

.menu-editor-wrapper editor {
  min-height: 500rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.menu-edit-submit {
  margin-top: 32rpx;
}

.menu-submit-btn {
  width: 100%;
  height: 96rpx;
  font-size: 28rpx;
}

