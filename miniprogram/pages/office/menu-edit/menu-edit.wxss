.menu-edit-page {
  min-height: 100%;
}

.menu-edit-page .auth-field-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
}

.menu-edit-header {
  padding: 60rpx 40rpx 80rpx;
}

.menu-edit-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  text-align: left;
}

.menu-edit-content {
  margin-top: -60rpx;
}

.menu-edit-form {
  padding: 28rpx;
}

.menu-editor-wrapper {
  border-radius: 24rpx;
  overflow: hidden;
  background: #F8FAFC;
  border: 2rpx solid transparent;
}

.menu-editor-wrapper editor {
  min-height: 500rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.menu-edit-submit {
  margin-top: 32rpx;
}

.menu-submit-btn {
  width: 100%;
  height: 96rpx;
  font-size: 28rpx;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
}

