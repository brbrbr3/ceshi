<view class="auth-page register-page">
  <view class="auth-hero">
    <view class="auth-brand">登</view>
    <view class="auth-title">填写注册申请</view>
    <view class="auth-subtitle">请补充真实资料。提交后，管理员将在审批页面收到一条新的注册申请并进行审核。</view>
    <view class="auth-tip-row">
      <view class="auth-tip-pill">姓名</view>
      <view class="auth-tip-pill">角色信息</view>
      <view class="auth-tip-pill">管理员标记</view>
    </view>
  </view>

  <view class="auth-card">
    <view class="auth-card-title">基础资料登记</view>
    <view class="auth-card-desc">资料将写入云数据库中的注册申请表，审批通过后自动成为正式用户。</view>

    <view wx:if="{{reviewRemark}}" class="auth-review-banner">
      <view class="auth-review-title">退回说明</view>
      <view class="auth-review-text">{{reviewRemark}}</view>
    </view>

    <view class="auth-form">
      <view class="auth-field">
        <view class="auth-field-label">姓名</view>
        <view class="auth-input-shell">
          <input value="{{form.name}}" placeholder="请输入真实姓名" placeholder-class="auth-input-placeholder" bindinput="handleNameInput" />
        </view>
      </view>

      <view class="auth-field">
        <view class="auth-field-label">性别</view>
        <view class="auth-segment">
          <view class="auth-segment-item {{form.gender === '男' ? 'is-active' : ''}}" data-value="男" bindtap="selectGender">男</view>
          <view class="auth-segment-item {{form.gender === '女' ? 'is-active' : ''}}" data-value="女" bindtap="selectGender">女</view>
        </view>
      </view>

      <view class="auth-field">
        <view class="auth-field-label">出生日期</view>
        <picker mode="date" value="{{form.birthday}}" bindchange="handleBirthdayChange">
          <view class="auth-picker-shell {{form.birthday ? '' : 'is-placeholder'}}">
            <view class="auth-picker-value">{{form.birthday || '请选择出生日期'}}</view>
            <view class="auth-picker-arrow">›</view>
          </view>
        </picker>
      </view>

      <view class="auth-field">
        <view class="auth-field-label">角色</view>
        <picker mode="selector" range="{{roleOptions}}" value="{{roleIndex >= 0 ? roleIndex : 0}}" bindchange="handleRoleChange">
          <view class="auth-picker-shell {{form.role ? '' : 'is-placeholder'}}">
            <view class="auth-picker-value">{{form.role || '请选择角色'}}</view>
            <view class="auth-picker-arrow">›</view>
          </view>
        </picker>
      </view>

      <view class="auth-field">
        <view class="auth-field-label">是否为管理员</view>
        <view class="auth-segment">
          <view class="auth-segment-item {{form.isAdmin ? 'is-active' : ''}}" data-value="true" bindtap="selectAdmin">是</view>
          <view class="auth-segment-item {{!form.isAdmin ? 'is-active' : ''}}" data-value="false" bindtap="selectAdmin">否</view>
        </view>
      </view>
    </view>

    <button class="auth-submit-btn" loading="{{loading}}" bindtap="submitRegistration">提交注册申请</button>
    <view class="auth-note">提交后若暂未通过，请等待管理员在审批中心处理；被退回后可再次进入本页修改并重新提交。</view>
  </view>
</view>
