/* 首个管理员初始化 */
.auth-bootstrap-card {
  margin-top: 30rpx;
  padding: 30rpx;
  background: #fff7ed;
  border: 1rpx solid #fed7aa;
  border-radius: 24rpx;
}

.auth-bootstrap-title {
  font-size: var(--fs-30);
  font-weight: 600;
  color: #9a3412;
}

.auth-bootstrap-desc {
  margin-top: 12rpx;
  font-size: var(--fs-24);
  line-height: 1.7;
  color: #9a3412;
}

.auth-bootstrap-btn {
  margin-top: 24rpx;
  height: 76rpx;
  line-height: 76rpx;
  text-align: center;
  border-radius: 999rpx;
  background: #ea580c;
  color: #fff;
  font-size: var(--fs-28);
  font-weight: 500;
}

/* 调试模式入口 */
.auth-debug-entry {
  margin: 40rpx auto;
  padding: 20rpx 40rpx;
  font-size: var(--fs-24);
  color: #999;
  text-align: center;
  text-decoration: underline;
}

/* 调试密码弹窗 */
.auth-modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.2s ease;
}

.auth-modal-overlay.is-closing {
  animation: fadeOut 0.25s ease forwards;
}

.auth-modal-overlay.is-closing .auth-modal {
  animation: scaleOut 0.25s ease forwards;
}

.auth-modal {
  width: 80%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  animation: scaleIn 0.2s ease;
}

@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
@keyframes fadeOut { from { opacity: 1; } to { opacity: 0; } }
@keyframes scaleIn { from { opacity: 0; transform: scale(0.9); } to { opacity: 1; transform: scale(1); } }
@keyframes scaleOut { from { opacity: 1; transform: scale(1); } to { opacity: 0; transform: scale(0.9); } }

.auth-modal-title {
  font-size: var(--fs-32);
  font-weight: 600;
  text-align: center;
  margin-bottom: 10rpx;
  color: #333;
}

.auth-modal-desc {
  font-size: var(--fs-24);
  text-align: center;
  color: #ff4d4f;
  margin-bottom: 20rpx;
}

.auth-modal-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  margin-top: 16rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  font-size: var(--fs-28);
  box-sizing: border-box;
}

.auth-modal-actions {
  display: flex;
  margin-top: 30rpx;
  gap: 20rpx;
}

.auth-modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 8rpx;
  font-size: var(--fs-28);
}

.auth-modal-btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.auth-modal-btn-confirm {
  background: #1890ff;
  color: #fff;
}

/* 调试面板 */
.auth-debug-panel {
  padding: 30rpx;
  background: #fff;
  border-radius: 26rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.auth-debug-panel-title {
  font-size: var(--fs-32);
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.auth-debug-panel-desc {
  font-size: var(--fs-24);
  color: #999;
  margin-bottom: 30rpx;
}

.auth-debug-buttons {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.auth-debug-btn {
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: #f0f5ff;
  color: #1890ff;
  border-radius: 8rpx;
  font-size: var(--fs-28);
}

.auth-debug-btn:active {
  background: #d6e4ff;
}

.auth-debug-close {
  margin-top: 30rpx;
  margin-bottom: 70rpx;
  text-align: center;
  font-size: var(--fs-26);
  color: #999;
  text-decoration: underline;
}

/* 调试结果 */
.auth-debug-results {
  margin-top: 30rpx;
  margin-bottom: 100rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid #eee;
}

.auth-debug-results-title {
  font-size: var(--fs-28);
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.auth-debug-result-item {
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

.auth-debug-result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.auth-debug-result-name {
  font-size: var(--fs-28);
  font-weight: 500;
  color: #333;
}

.auth-debug-result-status {
  font-size: var(--fs-24);
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.auth-debug-result-status.is-success {
  background: #e6fffb;
  color: #52c41a;
}

.auth-debug-result-status.is-fail {
  background: #fff1f0;
  color: #ff4d4f;
}

.auth-debug-result-message {
  margin-top: 10rpx;
  font-size: var(--fs-24);
  color: #666;
}

.auth-debug-result-data {
  margin-top: 10rpx;
  font-size: var(--fs-24);
  color: #999;
  word-break: break-all;
  white-space: pre-wrap;
  max-height: 300rpx;
  overflow-y: auto;
}

/* 危险操作按钮 */
.auth-debug-btn-danger {
  background: #fff1f0;
  color: #ff4d4f;
}

.auth-debug-btn-danger:active {
  background: #ffccc7;
}

/* 清除数据库面板 */
.auth-clear-db-panel {
  margin-top: 30rpx;
  padding: 30rpx;
  background: #fafafa;
  border-radius: 12rpx;
  border: 1rpx solid #eee;
}

.auth-clear-db-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.auth-clear-db-title {
  font-size: var(--fs-28);
  font-weight: 600;
  color: #333;
}

.auth-clear-db-select-all {
  font-size: var(--fs-24);
  color: #1890ff;
  text-decoration: underline;
}

.auth-clear-db-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  max-height: 400rpx;
  overflow-y: auto;
}

.auth-clear-db-item {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #fff;
  border-radius: 8rpx;
  border: 1rpx solid #e8e8e8;
}

.auth-clear-db-item-name {
  margin-left: 16rpx;
  font-size: var(--fs-26);
  color: #333;
}

.auth-clear-db-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.auth-clear-db-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 8rpx;
  font-size: var(--fs-28);
}

.auth-clear-db-btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.auth-clear-db-btn-confirm {
  background: #ff4d4f;
  color: #fff;
}

.auth-clear-db-btn-confirm.is-disabled {
  background: #ccc;
  color: #fff;
}
