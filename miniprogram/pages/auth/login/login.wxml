<view class="auth-page login-page">
  <view class="auth-hero">
    <view class="auth-brand" bindtap="handleAuthBrandTap">登录</view>
    <view class="auth-title">Embaixada da China</view>
    <view class="auth-subtitle">欢迎使用Embaixada da China办公小程序！</view>
    <view class="auth-tip-row">
      <view class="auth-tip-pill">微信身份校验</view>
      <view class="auth-tip-pill">审批后可用</view>
    </view>
  </view>

  <view class="auth-card">
    <view class="auth-card-title">微信一键登录</view>
    <text class="auth-card-desc">已注册用户：点击下方按钮直接进入首页
    未注册用户：将跳转到注册页面填写基础资料</text>

    <view class="auth-wechat-panel">
      <view class="auth-wechat-icon">微</view>
      <view>
        <view class="auth-wechat-title">当前登录方式</view>
        <view class="auth-wechat-desc">使用微信身份识别当前用户，无需手动输入用户名或密码。</view>
      </view>
    </view>

    <button class="auth-submit-btn" loading="{{loading}}" bindtap="handleWxLogin">点击使用微信登录</button>
  </view>

  <view wx:if="{{statusCard}}" class="auth-card auth-status-card {{statusCard.className}}">
    <view class="auth-status-head">
      <view class="auth-status-title">{{statusCard.title}}</view>
      <view class="auth-status-tag">{{statusCard.tag}}</view>
    </view>
    <view class="auth-status-desc">{{statusCard.desc}}</view>
    <view wx:if="{{statusCard.extra}}" class="auth-status-extra">{{statusCard.extra}}</view>
    <view wx:if="{{statusCard.time}}" class="auth-status-time">{{statusCard.time}}</view>
  </view>

  <view wx:if="{{showRegisterLink}}" class="auth-bottom-link" bindtap="goRegister">还没有登记资料？去填写注册申请</view>

  <!-- 调试模式入口（仅管理员可见） -->
  <view wx:if="{{isAdmin}}" class="auth-debug-entry" bindtap="showDebugPassword">调试模式</view>

  <!-- 调试密码输入弹窗 -->
  <view wx:if="{{showPasswordModal}}" class="auth-modal-overlay" bindtap="hideDebugPassword">
    <view class="auth-modal" catchtap>
      <view class="auth-modal-title">输入调试密码</view>
      <input class="auth-modal-input" type="password" password="{{true}}" placeholder="请输入密码" value="{{debugPassword}}" bindinput="onDebugPasswordInput" />
      <view class="auth-modal-actions">
        <view class="auth-modal-btn auth-modal-btn-cancel" bindtap="hideDebugPassword">取消</view>
        <view class="auth-modal-btn auth-modal-btn-confirm" bindtap="verifyDebugPassword">确认</view>
      </view>
    </view>
  </view>

  <!-- 调试面板 -->
  <view wx:if="{{showDebugPanel}}" class="auth-debug-panel">
    <view class="auth-debug-panel-title">调试面板</view>
    <view class="auth-debug-panel-desc">点击执行对应的初始化函数</view>
    <view class="auth-debug-buttons">
      <view class="auth-debug-btn" bindtap="callInitSystemConfig">初始化系统配置</view>
      <view class="auth-debug-btn" bindtap="callInitWorkflowDB">初始化工作流</view>
    </view>
    <view class="auth-debug-close" bindtap="hideDebugPanel">关闭调试面板</view>

    <!-- 调试结果输出区域 -->
    <view wx:if="{{debugResults.length > 0}}" class="auth-debug-results">
      <view class="auth-debug-results-title">执行结果</view>
      <view wx:for="{{debugResults}}" wx:key="id" class="auth-debug-result-item">
        <view class="auth-debug-result-header">
          <text class="auth-debug-result-name">{{item.name}}</text>
          <text class="auth-debug-result-status {{item.success ? 'is-success' : 'is-fail'}}">{{item.success ? '成功' : '失败'}}</text>
        </view>
        <view wx:if="{{item.message}}" class="auth-debug-result-message">{{item.message}}</view>
        <view wx:if="{{item.data}}" class="auth-debug-result-data">
          <text selectable="true" user-select="true">{{item.data}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 超级管理员登录弹窗 -->
  <view wx:if="{{showSuperAdminModal}}" class="auth-modal-overlay" bindtap="hideSuperAdminModal">
    <view class="auth-modal" catchtap>
      <view class="auth-modal-title">超级管理员登录</view>
      <input class="auth-modal-input" type="text" placeholder="用户名" value="{{superAdminUsername}}" bindinput="onSuperAdminUsernameInput" />
      <input class="auth-modal-input" type="password" password="{{true}}" placeholder="密码" value="{{superAdminPassword}}" bindinput="onSuperAdminPasswordInput" />
      <view class="auth-modal-actions">
        <view class="auth-modal-btn auth-modal-btn-cancel" bindtap="hideSuperAdminModal">取消</view>
        <view class="auth-modal-btn auth-modal-btn-confirm" bindtap="verifySuperAdmin">确认</view>
      </view>
    </view>
  </view>
</view>
