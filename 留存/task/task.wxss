page {
  background: #EEF2FF;
}

.work-header {
  padding-bottom: 160rpx;
}

.work-title {
  font-size: var(--fs-40);
  font-weight: 600;
}

.work-subtitle {
  margin-top: 10rpx;
  font-size: var(--fs-24);
  opacity: 0.76;
}

.work-create-btn {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  font-size: var(--fs-24);
  font-weight: 600;
}

.work-top-tabs {
  margin-top: 28rpx;
  padding: 6rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.15);
  display: flex;
}

.work-top-tab {
  flex: 1;
  height: 68rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255, 255, 255, 0.8);
  font-size: var(--fs-24);
}

.work-top-tab.is-active {
  background: rgba(255, 255, 255, 0.95);
  color: #2563EB;
  font-weight: 600;
}

.work-filter-scroll {
  margin-bottom: 24rpx;
}

.work-list-header {
  margin-bottom: 16rpx;
}

.work-card,
.work-calendar-card,
.work-schedule-card,
.work-project-card {
  padding: 24rpx;
}

.work-card + .work-card,
.work-project-card + .work-project-card,
.work-schedule-group + .work-schedule-group {
  margin-top: 20rpx;
}

.work-card-top,
.work-card-meta,
.work-card-footer,
.work-calendar-head,
.work-project-top,
.work-event-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.work-card-time,
.work-card-progress-text,
.work-event-time,
.work-event-location,
.work-project-members,
.work-group-title {
  font-size: var(--fs-24);
  color: #94A3B8;
}

.work-card-title,
.work-project-name,
.work-event-title {
  font-size: var(--fs-30);
  font-weight: 600;
  color: #1E293B;
  line-height: 1.45;
}

.work-card-title {
  margin: 20rpx 0 18rpx;
}

.work-card-title.is-done {
  color: #94A3B8;
  text-decoration: line-through;
}

.work-project-pill {
  background: #EFF6FF;
  color: #2563EB;
}

.work-progress-bar {
  height: 12rpx;
  border-radius: 999rpx;
  background: #E2E8F0;
  overflow: hidden;
  margin: 18rpx 0 22rpx;
}

.work-progress-bar.is-project {
  margin-top: 20rpx;
  margin-bottom: 0;
}

.work-progress-inner {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #1D4ED8 0%, #3B82F6 100%);
}

.work-avatars {
  display: flex;
  align-items: center;
}

.work-avatar-mini,
.work-avatar-more {
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: var(--fs-22);
  font-weight: 600;
  margin-right: -10rpx;
  border: 4rpx solid #FFFFFF;
}

.work-avatar-more {
  background: #E2E8F0;
  color: #64748B;
}

.work-action-btn {
  padding: 14rpx 26rpx;
}

.work-calendar-title {
  font-size: var(--fs-28);
}

.work-week-row,
.work-days-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 12rpx;
}

.work-week-row {
  margin: 20rpx 0 12rpx;
}

.work-week-item {
  text-align: center;
  font-size: var(--fs-22);
  color: #94A3B8;
}

.work-day-item {
  height: 64rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--fs-24);
  color: #1E293B;
}

.work-day-item.is-current {
  background: #2563EB;
  color: #FFFFFF;
  box-shadow: 0 12rpx 24rpx rgba(37, 99, 235, 0.18);
}

.work-day-item.is-weekend {
  color: #EF4444;
}

.work-group-title {
  margin: 24rpx 0 14rpx;
  padding-left: 4rpx;
  font-weight: 600;
}

.work-event-item {
  display: flex;
  gap: 16rpx;
}

.work-event-item + .work-event-item {
  margin-top: 22rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid rgba(37, 99, 235, 0.1);
}

.work-event-line {
  width: 8rpx;
  border-radius: 999rpx;
}

.work-event-main {
  flex: 1;
}

.work-event-time {
  margin-top: 8rpx;
}

.work-event-location {
  margin-top: 6rpx;
}

.work-project-top {
  align-items: flex-start;
}

.work-project-members {
  margin-top: 10rpx;
}

.work-project-value {
  font-size: var(--fs-30);
  font-weight: 700;
}

.work-project-avatars {
  margin-top: 18rpx;
}
